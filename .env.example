# TELIYA - Exemple de variables d'environnement locales
#
# Copier ce fichier vers .env ou .env.local selon le besoin local.
# Ne jamais committer de valeurs reelles dans ce fichier.
# Les fichiers .env, .env.local, .env.development et .env.production sont ignores par Git.

# Firebase Web App - valeurs a recuperer dans Firebase Console > Parametres du projet > Vos applications
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Analytics Firebase - optionnel
VITE_FIREBASE_MEASUREMENT_ID=

# App Check reCAPTCHA v3 - optionnel
VITE_RECAPTCHA_V3_KEY=

# App Check debug local - optionnel
# Valeur attendue: true ou false
VITE_APPCHECK_DEBUG=false

# Firestore long polling - optionnel
# Valeur attendue: true ou false
VITE_FIRESTORE_FORCE_LONG_POLLING=false

# Firebase Emulator Suite - optionnel
# Ne pas changer la valeur locale existante sans validation explicite.
# Valeur attendue: true ou false
VITE_USE_EMULATORS=false

# Dérogation exceptionnelle : autoriser explicitement localhost à cibler prod.
# Laisser impérativement à false pour le développement normal.
VITE_ALLOW_PRODUCTION_FROM_LOCAL=false

# Version affichee - optionnel
VITE_APP_VERSION=
