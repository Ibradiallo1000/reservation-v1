# Firebase — remplir avec les valeurs de la console Firebase
# Ne pas committer ce fichier avec des valeurs réelles ; utiliser .env (ignoré par Git)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optionnel — Analytics
# VITE_FIREBASE_MEASUREMENT_ID=

# Optionnel — App Check (reCAPTCHA v3)
# VITE_RECAPTCHA_V3_KEY=

# Optionnel — Émulateurs en local
# VITE_USE_EMULATORS=true

# Optionnel — Version affichée
# VITE_APP_VERSION=1.0.0
