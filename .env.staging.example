# TELIYA - Exemple de variables d'environnement staging
#
# Copier ce fichier vers .env.staging.local pour renseigner les valeurs locales
# du projet Firebase staging. Ne jamais committer les vraies valeurs.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=teliya-staging
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

VITE_RECAPTCHA_V3_KEY=
VITE_APPCHECK_DEBUG=false
VITE_FIRESTORE_FORCE_LONG_POLLING=false
VITE_USE_EMULATORS=false
VITE_APP_VERSION=staging
