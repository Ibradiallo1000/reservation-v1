[debug] [2026-06-19T11:04:49.720Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/monbillet-95b77/rulesets {"name":"projects/monbillet-95b77/rulesets/40ea425f-428c-428e-b1bd-491f4daae44a","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    function isAuth() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function getUserRole() {\r\n      let path = /databases/$(database)/documents/users/$(request.auth.uid);\r\n      let raw = exists(path) ? get(path).data.get('role', '') : '';\r\n      let tokenRole = request.auth != null ? request.auth.token.get('role', '') : '';\r\n      return raw != '' ? raw : tokenRole;\r\n    }\r\n    function hasUserRole(role) {\n      let path = /databases/$(database)/documents/users/$(request.auth.uid);\n      let raw = exists(path) ? get(path).data.get('role', '') : '';\n      let rawRoles = exists(path) ? get(path).data.get('roles', []) : [];\n      let tokenRole = request.auth != null ? request.auth.token.get('role', '') : '';\n      let tokenRoles = request.auth != null ? request.auth.token.get('roles', []) : [];\n      return (raw is string && raw == role)\n        || (rawRoles is list && rawRoles.hasAny([role]))\n        || (tokenRole is string && tokenRole == role)\n        || (tokenRoles is list && tokenRoles.hasAny([role]));\n    }\n    function isPlatformAdmin() {\r\n      return isAuth() && hasUserRole('admin_platforme');\r\n    }\r\n    function validSystemPlanValues(plan) {\r\n      return plan is map\r\n        && plan.keys().hasOnly(['price', 'includedOperations', 'overage'])\r\n        && plan.keys().hasAll(['price', 'includedOperations', 'overage'])\r\n        && plan.price is number\r\n        && plan.includedOperations is number\r\n        && plan.overage is number\r\n        && plan.price >= 0\r\n        && plan.includedOperations >= 0\r\n        && plan.overage >= 0;\r\n    }\r\n    function validSystemPlansSettings() {\r\n      return request.resource.data.keys().hasOnly(['standard', 'premium'])\r\n        && request.resource.data.keys().hasAll(['standard', 'premium'])\r\n        && validSystemPlanValues(request.resource.data.standard)\r\n        && validSystemPlanValues(request.resource.data.premium);\r\n    }\r\n    function validOperationQuotaIncrementOnly() {\r\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\r\n      let previousUsage = resource.data.get('currentMonthOperations', 0);\r\n      let previousMonth = resource.data.get('currentMonth', resource.data.get('currentOperationsMonth', ''));\r\n      let nextMonth = request.resource.data.currentMonth;\r\n      return changed.hasOnly(['currentMonthOperations', 'currentMonth', 'currentOperationsMonth', 'operationsUpdatedAt'])\r\n        && previousUsage is number\r\n        && request.resource.data.currentMonthOperations is number\r\n        && request.resource.data.currentMonth is string\r\n        && request.resource.data.currentOperationsMonth is string\r\n        && request.resource.data.currentMonth == request.resource.data.currentOperationsMonth\r\n        && request.resource.data.operationsUpdatedAt == request.time\r\n        && (\r\n          (\r\n            nextMonth == previousMonth\r\n            && request.resource.data.currentMonthOperations == previousUsage + 1\r\n          )\r\n          || (\r\n            nextMonth != previousMonth\r\n            && request.resource.data.currentMonthOperations == 1\r\n          )\r\n        );\r\n    }\r\n    function isComptable() {\n      return isAuth() && (\n        hasUserRole('agency_accountant') ||\n        hasUserRole('comptable') ||\n        hasUserRole('Comptable') ||\n        hasUserRole('admin_compagnie')\n      );\n    }\n    function isGuichetier() {\r\n      return isAuth() && hasUserRole('guichetier');\r\n    }\r\n    function isCourierAgent() {\r\n      return isAuth() && (\r\n        hasUserRole('agentCourrier') ||\r\n        hasUserRole('agentcourrier') ||\r\n        hasUserRole('agent_courrier') ||\r\n        hasUserRole('agentCourier') ||\r\n        hasUserRole('courier_agent')\r\n      );\r\n    }\r\n    function isBoardingOfficer() {\n      return isAuth() && (\n        hasUserRole('agency_boarding_officer') ||\n        hasUserRole('embarquement') ||\n        hasUserRole('chefEmbarquement') ||\n        hasUserRole('chefembarquement') ||\n        hasUserRole('chef_embarquement') ||\n        hasUserRole('controleur_embarquement') ||\n        hasUserRole('agent_embarquement') ||\n        hasUserRole('boarding_officer')\n      );\n    }\n    function isFleetController() {\r\n      return isAuth() && hasUserRole('agency_fleet_controller');\r\n    }\r\n    function isAgencyManager() {\r\n      return isAuth() && (\r\n        hasUserRole('chefAgence') ||\r\n        hasUserRole('chefagence') ||\r\n        hasUserRole('admin_compagnie')\r\n      );\r\n    }\r\n    function isEscaleManager() {\r\n      return isAuth() && hasUserRole('escale_manager');\r\n    }\r\n    function isEscaleOperator() {\r\n      return isAuth() && (hasUserRole('escale_agent') || hasUserRole('escale_manager'));\r\n    }\r\n    /* Chef d'agence ou chef d'escale : peuvent gérer l'équipe de leur agence. */\r\n    function canManageAgencyTeam(agencyId) {\r\n      return isAuth() && (hasUserRole('admin_compagnie') || hasUserRole('admin_platforme')\r\n        || ((hasUserRole('chefAgence') || hasUserRole('chefagence')) && getUserAgencyId() == agencyId)\r\n        || (hasUserRole('escale_manager') && getUserAgencyId() == agencyId));\r\n    }\r\n    /* Fleet & vehicle operations (ex chef_garage). Backward compat: accept both role names. */\r\n    function isResponsableLogistique() {\r\n      return isAuth() && (hasUserRole('responsable_logistique') || hasUserRole('chef_garage'));\r\n    }\r\n    /* Phase B — transition de statut réservation (guichetier, chef_agence, comptable, embarquement, validation en ligne). Valeurs canoniques uniquement. */\r\n    function validReservationStatutTransition() {\r\n      let oldS = resource.data.get('statut', '');\r\n      let newS = request.resource.data.get('statut', '');\r\n      return (isGuichetier() && (oldS == 'confirme' || oldS == 'paye' || oldS == 'payé') && newS == 'annulation_en_attente')\r\n        || (isGuichetier() && (oldS == 'paye' || oldS == 'payé') && newS == 'finance_side_effects_failed')\r\n        || (isAgencyManager() && oldS == 'annulation_en_attente' && newS == 'annule')\r\n        || (isComptable() && oldS == 'annule' && newS == 'rembourse')\r\n        || (isBoardingOfficer() && (\n          oldS == 'confirme' ||\n          oldS == 'confirmé' ||\n          oldS == 'paye' ||\n          oldS == 'payé' ||\n          oldS == 'valide' ||\n          oldS == 'validé' ||\n          oldS == 'preuve_recue'\n        ) && (\n          newS == 'embarque' ||\n          newS == 'embarqué'\n        ))\n        || ((hasUserRole('admin_compagnie') || hasUserRole('company_accountant') || isAgencyManager() || isComptable() || hasUserRole('operator_digital')) && (oldS == 'preuve_recue' || oldS == 'verification') && (newS == 'confirme' || newS == 'refuse'));\r\n    }\r\n    function operatorDigitalCanCommitOnlineReservation(companyId, agencyId) {\r\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\r\n      let online = resource.data.get('canal', '') in ['en_ligne', 'online']\r\n        || resource.data.get('paymentChannel', '') in ['en_ligne', 'online'];\r\n      let pending = resource.data.get('status', '') in ['preuve_recue', 'verification']\r\n        || resource.data.get('statut', '') in ['preuve_recue', 'verification'];\r\n      return isAuth()\r\n        && hasUserRole('operator_digital')\r\n        && resource.data.get('companyId', '') == companyId\r\n        && resource.data.get('agencyId', '') == agencyId\r\n        && online\r\n        && pending\r\n        && request.resource.data.get('status', '') == 'confirme'\r\n        && request.resource.data.get('statut', '') == 'confirme'\r\n        && request.resource.data.get('validatedBy', '') == request.auth.uid\r\n        && request.resource.data.get('paymentStatus', '') == 'paid'\r\n        && request.resource.data.get('payment', {}).get('status', '') == 'validated'\r\n        && request.resource.data.get('ticketValidatedAt', null) == request.time\r\n        && request.resource.data.get('seatHoldOnly', true) == false\r\n        && request.resource.data.get('seatsHeld', -1) == 0\r\n        && (\r\n          request.resource.data.get('seatsCommittedAt', null) == request.time\r\n          || (\r\n            resource.data.get('seatsCommittedAt', null) != null\r\n            && request.resource.data.get('seatsCommittedAt', null) == resource.data.get('seatsCommittedAt', null)\r\n          )\r\n        )\r\n        && request.resource.data.get('updatedAt', null) == request.time\r\n        && changed.hasAll([\r\n          'status',\r\n          'statut',\r\n          'paymentStatus',\r\n          'payment',\r\n          'ticketValidatedAt',\r\n          'validatedBy',\r\n          'auditLog',\r\n          'updatedAt'\r\n        ])\r\n        && changed.hasOnly([\r\n          'status',\r\n          'statut',\r\n          'paymentStatus',\r\n          'payment',\r\n          'ticketValidatedAt',\r\n          'validatedBy',\r\n          'auditLog',\r\n          'seatHoldOnly',\r\n          'seatsHeld',\r\n          'seatsCommittedAt',\r\n          'ticketRevenueCountedInDailyStats',\r\n          'updatedAt'\r\n        ]);\r\n    }\r\n    function operatorDigitalCanRejectOnlineReservation(companyId, agencyId) {\r\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\r\n      let online = resource.data.get('canal', '') in ['en_ligne', 'online']\r\n        || resource.data.get('paymentChannel', '') in ['en_ligne', 'online'];\r\n      let pending = resource.data.get('status', '') in ['preuve_recue', 'verification']\r\n        || resource.data.get('statut', '') in ['preuve_recue', 'verification'];\r\n      return isAuth()\r\n        && hasUserRole('operator_digital')\r\n        && resource.data.get('companyId', '') == companyId\r\n        && resource.data.get('agencyId', '') == agencyId\r\n        && online\r\n        && pending\r\n        && request.resource.data.get('status', '') == 'refuse'\r\n        && request.resource.data.get('statut', '') == 'refuse'\r\n        && request.resource.data.get('refusedBy', '') == request.auth.uid\r\n        && request.resource.data.get('refusedAt', null) == request.time\r\n        && request.resource.data.get('updatedAt', null) == request.time\r\n        && changed.hasAll([\r\n          'status',\r\n          'statut',\r\n          'refusalReason',\r\n          'refusedBy',\r\n          'refusedAt',\r\n          'auditLog',\r\n          'updatedAt'\r\n        ])\r\n        && changed.hasOnly([\r\n          'status',\r\n          'statut',\r\n          'refusalReason',\r\n          'refusedBy',\r\n          'refusedAt',\r\n          'auditLog',\r\n          'updatedAt'\r\n        ]);\r\n    }\r\n    function operatorDigitalCanFinalizeOnlineReservation(companyId, agencyId) {\r\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\r\n      let online = resource.data.get('canal', '') in ['en_ligne', 'online']\r\n        || resource.data.get('paymentChannel', '') in ['en_ligne', 'online'];\r\n      return isAuth()\r\n        && hasUserRole('operator_digital')\r\n        && resource.data.get('companyId', '') == companyId\r\n        && resource.data.get('agencyId', '') == agencyId\r\n        && online\r\n        && resource.data.get('status', '') == 'confirme'\r\n        && resource.data.get('statut', '') == 'confirme'\r\n        && resource.data.get('paymentStatus', '') == 'paid'\r\n        && resource.data.get('validatedBy', '') == request.auth.uid\r\n        && request.resource.data.get('cashTransactionId', '') is string\r\n        && request.resource.data.get('cashTransactionId', '').size() > 0\r\n        && request.resource.data.get('paymentStatus', '') == 'paid'\r\n        && request.resource.data.get('paymentMethod', '') in [\r\n          'cash',\r\n          'mobile_money',\r\n          'card',\r\n          'bank_transfer',\r\n          'transfer',\r\n          'online'\r\n        ]\r\n        && request.resource.data.get('updatedAt', null) == request.time\r\n        && changed.hasOnly([\r\n          'cashTransactionId',\r\n          'paymentStatus',\r\n          'paymentMethod',\r\n          'updatedAt'\r\n        ]);\r\n    }\r\n    /* Phase B — contrôleur embarquement : ne peut modifier que statut, statutEmbarquement, controleurId, checkInTime, auditLog, updatedAt */\r\n    function boardingOfficerAllowedKeysOnly() {\n      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n        \"statut\", \"statutEmbarquement\", \"boardingStatus\", \"journeyStatus\", \"controleurId\", \"checkInTime\", \"auditLog\", \"updatedAt\"\n      ]);\n    }\n    function boardingRoleValueIsAccepted(role) {\n      return role == 'agency_boarding_officer'\n        || role == 'embarquement'\n        || role == 'chefEmbarquement'\n        || role == 'chefembarquement'\n        || role == 'chef_embarquement'\n        || role == 'controleur_embarquement'\n        || role == 'agent_embarquement'\n        || role == 'boarding_officer';\n    }\n    function boardingOfficerStatutUpdateOk() {\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\n      let oldStatut = resource.data.get('statut', '');\n      let newStatut = request.resource.data.get('statut', oldStatut);\n      return !changed.hasAny(['statut'])\n        || (\n          (\n            oldStatut == 'confirme'\n            || oldStatut == 'confirmé'\n            || oldStatut == 'paye'\n            || oldStatut == 'payé'\n            || oldStatut == 'valide'\n            || oldStatut == 'validé'\n            || oldStatut == 'preuve_recue'\n            || oldStatut == 'embarque'\n            || oldStatut == 'embarqué'\n          )\n          && (\n            newStatut == 'embarque'\n            || newStatut == 'embarqué'\n          )\n        );\n    }\n    function boardingOfficerBoardingStatusOk() {\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\n      let boardingStatus = request.resource.data.get('boardingStatus', '');\n      return !changed.hasAny(['boardingStatus'])\n        || boardingStatus == 'boarded'\n        || boardingStatus == 'pending'\n        || boardingStatus == 'no_show';\n    }\n    function boardingOfficerStatutEmbarquementOk() {\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\n      let statutEmbarquement = request.resource.data.get('statutEmbarquement', '');\n      return !changed.hasAny(['statutEmbarquement'])\n        || statutEmbarquement == 'embarqué'\n        || statutEmbarquement == 'embarque'\n        || statutEmbarquement == 'en_attente'\n        || statutEmbarquement == 'absent';\n    }\n    function boardingOfficerCanUpdateReservation(companyId, agencyId) {\n      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);\n      let userData = get(userPath).data;\n      return isAuth()\n        && exists(userPath)\n        && boardingRoleValueIsAccepted(userData.get('role', ''))\n        && userData.get('agencyId', '') == agencyId\n        && (\n          userData.get('companyId', '') == companyId\n          || userData.get('compagnieId', '') == companyId\n        )\n        && boardingOfficerAllowedKeysOnly()\n        && boardingOfficerStatutUpdateOk()\n        && boardingOfficerBoardingStatusOk()\n        && boardingOfficerStatutEmbarquementOk();\n    }\n    function isSameAgencyReservation(companyId, agencyId) {\n      return isAuth()\n        && getUserAgencyId() == agencyId\n        && (\n          userCompanyId() == companyId\n          || userAgencyBelongsToCompany(companyId)\n          || getUserRole() == 'admin_platforme'\n        );\n    }\n    function isBoardingOperationalUpdate() {\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\n      return changed.hasOnly([\n        'boardingStatus',\n        'statutEmbarquement',\n        'controleurId',\n        'checkInTime'\n      ])\n      && (\n        request.resource.data.get('boardingStatus', resource.data.get('boardingStatus', '')) == 'pending'\n        || request.resource.data.get('boardingStatus', resource.data.get('boardingStatus', '')) == 'boarded'\n        || request.resource.data.get('boardingStatus', resource.data.get('boardingStatus', '')) == 'no_show'\n      )\n      && (\n        request.resource.data.get('statutEmbarquement', resource.data.get('statutEmbarquement', '')) == 'en_attente'\n        || request.resource.data.get('statutEmbarquement', resource.data.get('statutEmbarquement', '')) == 'embarqué'\n        || request.resource.data.get('statutEmbarquement', resource.data.get('statutEmbarquement', '')) == 'embarque'\n        || request.resource.data.get('statutEmbarquement', resource.data.get('statutEmbarquement', '')) == 'absent'\n      );\n    }\n    function canBoardingOfficerOperateReservation(companyId, agencyId) {\n      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);\n      let userData = get(userPath).data;\n      return isAuth()\n        && exists(userPath)\n        && (\n          boardingRoleValueIsAccepted(userData.get('role', ''))\n          || (userData.get('roles', []) is list && userData.get('roles', []).hasAny([\n            'agency_boarding_officer',\n            'embarquement',\n            'chefEmbarquement',\n            'chefembarquement',\n            'chef_embarquement',\n            'controleur_embarquement',\n            'agent_embarquement',\n            'boarding_officer'\n          ]))\n          || boardingRoleValueIsAccepted(request.auth.token.get('role', ''))\n          || (request.auth.token.get('roles', []) is list && request.auth.token.get('roles', []).hasAny([\n            'agency_boarding_officer',\n            'embarquement',\n            'chefEmbarquement',\n            'chefembarquement',\n            'chef_embarquement',\n            'controleur_embarquement',\n            'agent_embarquement',\n            'boarding_officer'\n          ]))\n        )\n        && (\n          userData.get('agencyId', '') == agencyId\n          || request.auth.token.get('agencyId', '') == agencyId\n        )\n        && (\n          userData.get('companyId', '') == companyId\n          || userData.get('compagnieId', '') == companyId\n          || request.auth.token.get('companyId', '') == companyId\n          || request.auth.token.get('compagnieId', '') == companyId\n          || userData.get('role', '') == 'admin_platforme'\n          || request.auth.token.get('role', '') == 'admin_platforme'\n        )\n        && isBoardingOperationalUpdate();\n    }\n    function getUserAgencyId() {\n      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);\n      let userData = exists(userPath) ? get(userPath).data : null;\n      let docAgencyId = userData == null ? '' : userData.get('agencyId', '');\n      let tokenAgencyId = request.auth != null ? request.auth.token.get('agencyId', '') : '';\r\n      return (docAgencyId is string && docAgencyId != '')\r\n        ? docAgencyId\r\n        : (tokenAgencyId is string ? tokenAgencyId : '');\r\n    }\r\n    /* Escale roles: allow read company data (agences, routes, stops) when their agency is under this company. */\r\n    function escaleUserCanReadCompany(companyId) {\r\n      return isAuth() && (getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager')\r\n        && getUserAgencyId() != ''\r\n        && exists(/databases/$(database)/documents/companies/$(companyId)/agences/$(getUserAgencyId()));\r\n    }\r\n    function userCompanyId() {\r\n      let path = /databases/$(database)/documents/users/$(request.auth.uid);\r\n      let userData = exists(path) ? get(path).data : null;\r\n      let docCompanyId = userData == null\r\n        ? ''\r\n        : (\r\n            userData.get('companyId', '') is string && userData.get('companyId', '') != ''\r\n              ? userData.get('companyId', '')\r\n              : (userData.get('compagnieId', '') is string ? userData.get('compagnieId', '') : '')\r\n          );\r\n      let tokenCompanyId = request.auth != null\r\n        ? (\r\n            request.auth.token.get('companyId', '') is string && request.auth.token.get('companyId', '') != ''\r\n              ? request.auth.token.get('companyId', '')\r\n              : (request.auth.token.get('compagnieId', '') is string ? request.auth.token.get('compagnieId', '') : '')\r\n          )\r\n        : '';\r\n      return docCompanyId != '' ? docCompanyId : tokenCompanyId;\r\n    }\r\n\r\n    /**\r\n     * Agence rattachée à la compagnie (guichet / escale / chef) — évite les 403 quand\r\n     * users/{uid}.companyId est absent ou désynchronisé mais agencyId est correct.\r\n     */\r\n    function userAgencyBelongsToCompany(companyId) {\r\n      return isAuth() && getUserAgencyId() != ''\r\n        && exists(/databases/$(database)/documents/companies/$(companyId)/agences/$(getUserAgencyId()));\r\n    }\r\n    /**\r\n     * Si paymentChannel est renseigné : en ligne sans poste/vendeur ; guichet avec agentId + sessionId.\r\n     * Les documents sans paymentChannel restent acceptés (données historiques).\r\n     */\r\n    function reservationCreatePaymentChannelShapeOk() {\r\n      let pc = request.resource.data.get('paymentChannel', '');\r\n      return pc == ''\r\n        || (\r\n          (pc == 'online' || pc == 'en_ligne')\r\n          && request.resource.data.get('agentId', '').size() == 0\r\n          && request.resource.data.get('sessionId', '').size() == 0\r\n          && request.resource.data.get('shiftId', '').size() == 0\r\n          && request.resource.data.get('guichetierId', '').size() == 0\r\n          && request.resource.data.get('createdInSessionId', '').size() == 0\r\n        )\r\n        || (\r\n          pc == 'guichet'\r\n          && request.resource.data.get('agentId', '').size() > 0\r\n          && request.resource.data.get('createdBy', '').size() > 0\r\n          && request.resource.data.get('agencyId', '').size() > 0\r\n          && request.resource.data.get('agencyId', '') == getUserAgencyId()\r\n          && request.resource.data.get('sessionId', '').size() > 0\r\n          && request.resource.data.get('shiftId', '').size() == 0\r\n          && request.resource.data.get('createdInSessionId', '').size() == 0\r\n          && request.resource.data.get('idempotencyKey', '').size() > 0\r\n        );\r\n    }\r\n    /** Écriture trésorerie / paiements guichet : même agence que le payload. */\r\n    function publicOnlineReservationCreate(companyId, agencyId) {\r\n      let canal = request.resource.data.get('canal', '');\r\n      let status = request.resource.data.get('status', '');\r\n      let statut = request.resource.data.get('statut', '');\r\n      return request.resource.data.get('paymentChannel', '') == 'online'\r\n        && canal is string\r\n        && canal.toLowerCase().replace(' ', '_') == 'en_ligne'\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('compagnieId', companyId) == companyId\r\n        && request.resource.data.get('agencyId', '') == agencyId\r\n        && status is string\r\n        && status.toLowerCase().replace(' ', '_') == 'en_attente'\r\n        && statut is string\r\n        && statut.toLowerCase().replace(' ', '_') == 'en_attente'\r\n        && request.resource.data.get('publicToken', '').size() > 0\r\n        && request.resource.data.get('publicUrl', '').size() > 0\r\n        && request.resource.data.get('seatHoldOnly', false) == true\r\n        && request.resource.data.get('seatsHeld', 0) > 0;\r\n    }\r\n    function publicOnlineProofSubmitOk(companyId, agencyId) {\r\n      let canal = resource.data.get('canal', '');\r\n      let paymentChannel = resource.data.get('paymentChannel', '');\r\n      let nextStatus = request.resource.data.get('status', '');\r\n\r\n      return (\r\n        paymentChannel == 'online'\r\n        || paymentChannel == 'en_ligne'\r\n        || (\r\n          canal is string\r\n          && (\r\n            canal.toLowerCase().replace(' ', '_') == 'en_ligne'\r\n            || canal.toLowerCase().replace(' ', '_') == 'online'\r\n          )\r\n        )\r\n      )\r\n      && reservationAwaitingOnlinePaymentProof()\r\n      && request.resource.data.get('companyId', '') == companyId\r\n      && request.resource.data.get('compagnieId', companyId) == companyId\r\n      && request.resource.data.get('agencyId', '') == agencyId\r\n      && nextStatus is string\r\n      && (nextStatus == 'preuve_recue' || nextStatus == 'verification')\r\n      && request.resource.data.get('updatedAt') is timestamp\r\n      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n        'status',\r\n        'statut',\r\n        'canal',\r\n        'paymentChannel',\r\n        'preuveMessage',\r\n        'paymentReference',\r\n        'transactionReference',\r\n        'preuveVia',\r\n        'payment',\r\n        'proofSubmittedAt',\r\n        'seatHoldOnly',\r\n        'seatsHeld',\r\n        'updatedAt'\r\n      ]);\r\n    }\r\n    function canWriteAgencyScopedFinance(companyId) {\n      return userAgencyBelongsToCompany(companyId) && (\n        isGuichetier() ||\n        hasUserRole('escale_agent') ||\n        hasUserRole('escale_manager') ||\n        (hasUserRole('chefAgence') && getUserAgencyId() != '') ||\n        isComptable()\n      );\n    }\n    function validPendingPaymentValidationPayload(companyId) {\r\n      return resource.data.get('status', '') == 'pending'\r\n        && request.resource.data.get('status', '') == 'validated'\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')\r\n        && request.resource.data.get('reservationId', '') == resource.data.get('reservationId', '')\r\n        && request.resource.data.get('amount', 0) == resource.data.get('amount', 0)\r\n        && request.resource.data.get('currency', 'XOF') == resource.data.get('currency', 'XOF')\r\n        && request.resource.data.get('validatedBy', '') == request.auth.uid\r\n        && request.resource.data.get('validatedAt', null) == request.time\r\n        && request.resource.data.get('updatedAt', null) == request.time\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n          'status', 'validatedBy', 'validatedAt', 'updatedAt'\r\n        ]);\r\n    }\r\n    function canValidateGuichetPayment(companyId) {\r\n      return canWriteAgencyScopedFinance(companyId)\r\n        && resource.data.get('channel', '') == 'guichet'\r\n        && validPendingPaymentValidationPayload(companyId);\r\n    }\r\n    function canValidateCourierPayment(companyId) {\r\n      return isCourierAgent()\r\n        && userAgencyBelongsToCompany(companyId)\r\n        && resource.data.get('agencyId', '') == getUserAgencyId()\r\n        && resource.data.get('channel', '') == 'courrier'\r\n        && validPendingPaymentValidationPayload(companyId);\r\n    }\r\n    function isHeadOfficeFinanceRole() {\r\n      return hasUserRole('admin_compagnie') ||\r\n        hasUserRole('company_ceo') ||\r\n        hasUserRole('company_accountant') ||\r\n        hasUserRole('financial_director') ||\r\n        hasUserRole('admin_platforme');\r\n    }\r\n    function canAccessSensitiveCompanyFinance(companyId) {\r\n      return isAuth()\r\n        && (userCompanyId() == companyId || hasUserRole('admin_platforme'))\r\n        && isHeadOfficeFinanceRole();\r\n    }\r\n    /**\r\n     * Comptable agence : création idempotente du compte miroir company_bank_* (ensureCompanyBankAccount),\r\n     * nécessaire pour lister la banque dans « versement caisse → banque ». Pas d’écriture ledger arbitraire.\r\n     */\r\n    function agencyAccountantCanCreateCompanyBankMirror(companyId, accountId) {\n      return isComptable()\n        && userCompanyId() == companyId\n        && userAgencyBelongsToCompany(companyId)\n        && accountId.matches('company_bank_.+')\r\n        && request.resource.data.get('accountType', '') == 'company_bank'\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('currentBalance', -1) == 0\r\n        && request.resource.data.get('isActive', false) == true\r\n        && (request.resource.data.get('agencyId', '') == '' || request.resource.data.agencyId == null);\r\n    }\r\n    function agencyAccountantCashLedgerPath(companyId, accountId, shiftId) {\r\n      let ledgerId = 'session_' + shiftId + '_accountant_validation';\r\n      return /databases/$(database)/documents/companies/$(companyId)/accounts/$(accountId)/ledger/$(ledgerId);\r\n    }\r\n    function agencyAccountantCanPostCashBalance(companyId, accountId, isCreate) {\n      let shiftId = request.resource.data.get('lastAccountantValidationShiftId', '');\n      let ledgerPath = agencyAccountantCashLedgerPath(companyId, accountId, shiftId);\n      let previousBalance = isCreate ? 0 : resource.data.get('balance', 0);\n      let nextBalance = request.resource.data.get('balance', 0);\n      let amount = nextBalance - previousBalance;\n      return isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && accountId == 'agency_' + getUserAgencyId() + '_cash'\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('agencyId', '') == getUserAgencyId()\r\n        && shiftId is string\r\n        && shiftId.size() > 0\r\n        && amount > 0\r\n        && amount < 100000000\r\n        && existsAfter(ledgerPath)\r\n        && getAfter(ledgerPath).data.get('companyId', '') == companyId\r\n        && getAfter(ledgerPath).data.get('agencyId', '') == getUserAgencyId()\r\n        && getAfter(ledgerPath).data.get('shiftId', '') == shiftId\r\n        && getAfter(ledgerPath).data.get('amount', 0) == amount\r\n        && getAfter(ledgerPath).data.get('source', '') == 'shift_accountant_validation'\r\n        && getAfter(ledgerPath).data.get('createdBy', '') == request.auth.uid\n        && getAfter(ledgerPath).data.get('status', '') == 'posted';\n    }\n    function canReadOwnAgencyCashAccount(companyId, accountId) {\n      return resource != null\n        && isAuth()\n        && userAgencyBelongsToCompany(companyId)\n        && (\n          hasUserRole('agency_accountant')\n          || hasUserRole('comptable')\n          || hasUserRole('Comptable')\n          || hasUserRole('chefAgence')\n          || hasUserRole('chefagence')\n          || hasUserRole('superviseur')\n        )\n        && accountId == 'agency_' + getUserAgencyId() + '_cash'\n        && resource.data.get('companyId', companyId) == companyId\n        && resource.data.get('agencyId', getUserAgencyId()) == getUserAgencyId();\n    }\n    function isAgencyAccountantDirectForCompany(companyId) {\n      return isAuth()\n        && (\n          getUserRole() == 'agency_accountant'\n          || getUserRole() == 'comptable'\n          || getUserRole() == 'Comptable'\n        )\n        && userAgencyBelongsToCompany(companyId);\n    }\n    function isOwnAgencyLiquidityAccountId(accountId) {\n      return accountId == 'agency_' + getUserAgencyId() + '_cash'\n        || accountId == 'agency_' + getUserAgencyId() + '_mobile_money';\n    }\n    function isOwnAgencyRemittanceLedgerAccountId(accountId) {\n      return accountId == 'agency_' + getUserAgencyId() + '_cash'\n        || accountId == 'agency_' + getUserAgencyId() + '_pending_cash';\n    }\n    function canAgencyAccountantReadOwnLiquidityAccount(companyId, accountId) {\n      return isAgencyAccountantDirectForCompany(companyId)\n        && isOwnAgencyLiquidityAccountId(accountId);\n    }\n    function canAgencyAccountantReadOwnRemittanceLedgerAccount(companyId, accountId) {\n      return agencyAccountantCanListCompanyScopedAccounting(companyId)\n        && isOwnAgencyRemittanceLedgerAccountId(accountId);\n    }\n    function canAgencyAccountantReadOwnShipment(companyId) {\n      return isAgencyAccountantDirectForCompany(companyId)\n        && (\n          resource.data.get('originAgencyId', '') == getUserAgencyId()\n          || resource.data.get('destinationAgencyId', '') == getUserAgencyId()\n          || resource.data.get('currentAgencyId', '') == getUserAgencyId()\n          || resource.data.get('currentLocationAgencyId', '') == getUserAgencyId()\n          || resource.data.get('agencyId', '') == getUserAgencyId()\n        );\n    }\n    function agencyAccountantCanListCompanyScopedAccounting(companyId) {\n      return isAuth()\n        && isComptable()\n        && getUserAgencyId() != ''\n        && userAgencyBelongsToCompany(companyId);\n    }\n    function canReadOwnAgencyAccountingData(companyId, agencyId) {\n      return isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && agencyId == getUserAgencyId();\n    }\n    function canReadOwnAgencyLedgerAccount(companyId) {\n      return resource != null\n        && isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && resource.data.get('companyId', companyId) == companyId\n        && resource.data.get('agencyId', '') == getUserAgencyId()\n        && resource.data.get('type', '') in ['cash', 'mobile_money', 'virtual_clearing'];\n    }\n    function guichetValidatedPaymentCreate(companyId) {\n      return request.resource.data.get('status', '') == 'validated'\r\n        && request.resource.data.get('channel', '') == 'guichet'\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('agencyId', '') == getUserAgencyId()\r\n        && request.resource.data.get('validatedBy', '') == request.auth.uid\r\n        && request.resource.data.get('amount', 0) > 0\r\n        && request.resource.data.get('amount', 0) < 100000000\r\n        && request.resource.data.get('currency', 'XOF') == 'XOF';\r\n    }\r\n    function financialTxAgencyStaffPayload(companyId) {\n      let t = request.resource.data.get('type', '');\n      let amt = request.resource.data.get('amount', 0);\n      return request.resource.data.get('companyId', '') == companyId\n        && request.resource.data.get('agencyId', '') == getUserAgencyId()\n        && (\r\n          (t == 'refund' && amt < 0 && amt > -100000000)\r\n          || (amt > 0 && amt < 100000000)\n        );\n    }\n    function comptaEncaissementCreateOk(companyId, agencyId) {\n      return isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && getUserAgencyId() == agencyId\n        && request.resource.data.keys().hasOnly([\n          'type',\n          'montant',\n          'source',\n          'sessionId',\n          'agencyId',\n          'companyId',\n          'createdAt'\n        ])\n        && request.resource.data.get('type', '') == 'encaissement'\n        && request.resource.data.get('companyId', '') == companyId\n        && request.resource.data.get('agencyId', '') == agencyId\n        && request.resource.data.get('source', '') in ['guichet', 'courrier']\n        && request.resource.data.get('sessionId', '').size() > 0\n        && request.resource.data.get('montant', 0) > 0\n        && request.resource.data.get('montant', 0) < 100000000\n        && request.resource.data.get('createdAt', null) == request.time;\n    }\n    function courierSessionAccountantValidationOk(companyId, agencyId) {\n      return isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && getUserAgencyId() == agencyId\n        && resource.data.get('status', '') == 'CLOSED'\n        && request.resource.data.get('status', '') == 'VALIDATED_AGENCY'\n        && request.resource.data.get('validatedAmount', -1) >= 0\n        && request.resource.data.get('validatedAmount', -1) < 100000000\n        && request.resource.data.get('validatedBy', {}).get('id', '') == request.auth.uid\n        && request.resource.data.get('validatedAt', null) == request.time\n        && request.resource.data.get('updatedAt', null) == request.time\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n          'status',\n          'validatedAt',\n          'validatedAmount',\n          'difference',\n          'remittanceStatus',\n          'remittanceDiscrepancyAmount',\n          'pendingCashLedgerVersion',\n          'validatedBy',\n          'updatedAt'\n        ]);\n    }\n    function agencyAccountantRemittanceLedgerAccountUpdateOk(companyId, accountId) {\n      let previousBalance = resource.data.get('balance', 0);\n      let nextBalance = request.resource.data.get('balance', 0);\n      let delta = nextBalance - previousBalance;\n      return isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && getUserAgencyId() != ''\n        && request.resource.data.get('id', '') == resource.data.get('id', '')\n        && request.resource.data.get('companyId', '') == companyId\n        && request.resource.data.get('companyId', '') == resource.data.get('companyId', '')\n        && request.resource.data.get('agencyId', '') == getUserAgencyId()\n        && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')\n        && request.resource.data.get('type', '') == resource.data.get('type', '')\n        && request.resource.data.get('currency', 'XOF') == resource.data.get('currency', 'XOF')\n        && request.resource.data.get('updatedAt', null) == request.time\n        && request.resource.data.get('balance', 0) is number\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'updatedAt'])\n        && (\n          (\n            accountId == 'agency_' + getUserAgencyId() + '_cash'\n            && resource.data.get('type', '') == 'cash'\n            && delta > 0\n            && delta < 100000000\n          )\n          || (\n            accountId == 'agency_' + getUserAgencyId() + '_pending_cash'\n            && resource.data.get('type', '') == 'virtual_clearing'\n            && delta < 0\n            && delta > -100000000\n          )\n        );\n    }\n    function agencyAccountantCashMirrorUpdateOk(companyId, accountId) {\n      let previousBalance = resource.data.get('currentBalance', 0);\n      let nextBalance = request.resource.data.get('currentBalance', 0);\n      let delta = nextBalance - previousBalance;\n      return isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && accountId == getUserAgencyId() + '_agency_cash'\n        && request.resource.data.get('companyId', '') == companyId\n        && request.resource.data.get('agencyId', '') == getUserAgencyId()\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBalance', 'updatedAt'])\n        && request.resource.data.get('updatedAt', null) == request.time\n        && request.resource.data.get('currentBalance', 0) is number\n        && delta > 0\n        && delta < 100000000;\n    }\n    function agencyAccountantCashMirrorReadOk(companyId, accountId) {\n      return isAuth()\n        && isComptable()\n        && userAgencyBelongsToCompany(companyId)\n        && accountId == getUserAgencyId() + '_agency_cash';\n    }\n    function courierCashPaymentCreateOk(companyId) {\r\n      return isCourierAgent()\r\n        && userAgencyBelongsToCompany(companyId)\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('agencyId', '') == getUserAgencyId()\r\n        && request.resource.data.get('channel', '') == 'courrier'\r\n        && request.resource.data.get('provider', '') == 'cash'\r\n        && request.resource.data.get('status', '') == 'validated'\r\n        && request.resource.data.get('validatedBy', '') == request.auth.uid\r\n        && request.resource.data.get('createdAt', null) == request.time\r\n        && request.resource.data.get('validatedAt', null) == request.time\r\n        && request.resource.data.get('amount', 0) > 0\r\n        && request.resource.data.get('amount', 0) < 100000000\r\n        && request.resource.data.get('currency', 'XOF') == 'XOF'\r\n        && request.resource.data.get('reservationId', '').size() > 0\r\n        && request.resource.data.keys().hasOnly([\r\n          'reservationId',\r\n          'companyId',\r\n          'agencyId',\r\n          'amount',\r\n          'currency',\r\n          'channel',\r\n          'provider',\r\n          'status',\r\n          'createdAt',\r\n          'validatedAt',\r\n          'validatedBy',\r\n          'rejectionReason'\r\n        ]);\r\n    }\r\n    function courierCashFinancialTxCreateOk(companyId) {\n      let amt = request.resource.data.get('amount', 0);\n      return isCourierAgent()\n        && userAgencyBelongsToCompany(companyId)\r\n        && request.resource.data.keys().hasOnly([\r\n          'type',\r\n          'source',\r\n          'amount',\r\n          'currency',\r\n          'companyId',\r\n          'agencyId',\r\n          'reservationId',\r\n          'debitAccountId',\r\n          'creditAccountId',\r\n          'debitAccountType',\r\n          'creditAccountType',\r\n          'balanceAfter',\r\n          'status',\r\n          'performedAt',\r\n          'createdAt',\r\n          'metadata',\r\n          'referenceType',\r\n          'referenceId',\r\n          'uniqueReferenceKey',\r\n          'paymentChannel',\r\n          'paymentMethod',\r\n          'paymentProvider'\r\n        ])\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('agencyId', '') == getUserAgencyId()\r\n        && request.resource.data.get('type', '') == 'payment_received'\r\n        && request.resource.data.get('source', '') == 'cash'\r\n        && request.resource.data.get('paymentChannel', '') == 'courrier'\r\n        && request.resource.data.get('paymentMethod', '') == 'cash'\r\n        && request.resource.data.get('paymentProvider', '') == 'cash'\r\n        && request.resource.data.get('status', '') == 'confirmed'\r\n        && request.resource.data.get('referenceType', '') == 'payment'\r\n        && request.resource.data.get('referenceId', '').size() > 0\r\n        && request.resource.data.get('reservationId', '').size() > 0\r\n        && amt > 0\r\n        && amt < 100000000\r\n        && request.resource.data.get('balanceAfter', 0) is number\r\n        && request.resource.data.get('performedAt', null) is timestamp\r\n        && request.resource.data.get('createdAt', null) is timestamp\r\n        && request.resource.data.get('uniqueReferenceKey', '').size() > 0\r\n        && request.resource.data.get('currency', 'XOF') == 'XOF'\r\n        && request.resource.data.get('creditAccountId', '') == 'agency_' + getUserAgencyId() + '_pending_cash'\n        && request.resource.data.get('debitAccountId', '') == 'company_clearing';\n    }\n    function courierCashFinancialTxReadOk(companyId) {\n      return isCourierAgent()\n        && userAgencyBelongsToCompany(companyId)\n        && resource.data.get('companyId', '') == companyId\n        && resource.data.get('agencyId', '') == getUserAgencyId()\n        && resource.data.get('type', '') == 'payment_received'\n        && resource.data.get('paymentChannel', '') == 'courrier'\n        && resource.data.get('status', '') == 'confirmed';\n    }\n    function courierCashFinancialIdempotencyOk(companyId) {\n      return isCourierAgent()\n        && userAgencyBelongsToCompany(companyId)\n        && request.resource.data.keys().hasOnly(['transactionId', 'createdAt'])\r\n        && request.resource.data.get('transactionId', '').size() > 0\r\n        && request.resource.data.get('createdAt', null) is timestamp;\r\n    }\r\n    function courierCashLedgerAccountIdOk(accountId) {\r\n      return accountId == 'company_clearing'\r\n        || accountId == 'agency_' + getUserAgencyId() + '_pending_cash';\r\n    }\r\n    function courierCashLedgerAccountCreateOk(companyId, accountId) {\r\n      return isCourierAgent()\r\n        && userAgencyBelongsToCompany(companyId)\r\n        && courierCashLedgerAccountIdOk(accountId)\r\n        && request.resource.data.keys().hasOnly([\r\n          'id',\r\n          'companyId',\r\n          'agencyId',\r\n          'type',\r\n          'label',\r\n          'balance',\r\n          'currency',\r\n          'includeInLiquidity',\r\n          'createdAt',\r\n          'updatedAt'\r\n        ])\r\n        && request.resource.data.get('id', '') == accountId\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('type', '') == 'virtual_clearing'\r\n        && request.resource.data.get('balance', 0) is number\r\n        && request.resource.data.get('includeInLiquidity', true) == false\r\n        && request.resource.data.get('currency', 'XOF') == 'XOF'\r\n        && request.resource.data.get('createdAt', null) == request.time\r\n        && request.resource.data.get('updatedAt', null) == request.time\r\n        && (\r\n          (\r\n            accountId == 'company_clearing'\r\n            && request.resource.data.get('agencyId', null) == null\r\n          )\r\n          || (\r\n            accountId == 'agency_' + getUserAgencyId() + '_pending_cash'\r\n            && request.resource.data.get('agencyId', '') == getUserAgencyId()\r\n          )\r\n        );\r\n    }\r\n    function courierCashLedgerAccountUpdateOk(companyId, accountId) {\r\n      return isCourierAgent()\r\n        && userAgencyBelongsToCompany(companyId)\r\n        && courierCashLedgerAccountIdOk(accountId)\r\n        && request.resource.data.get('id', '') == resource.data.get('id', '')\r\n        && request.resource.data.get('companyId', '') == companyId\r\n        && request.resource.data.get('companyId', '') == resource.data.get('companyId', '')\r\n        && request.resource.data.get('agencyId', null) == resource.data.get('agencyId', null)\r\n        && request.resource.data.get('type', '') == resource.data.get('type', '')\r\n        && request.resource.data.get('currency', 'XOF') == resource.data.get('currency', 'XOF')\r\n        && request.resource.data.get('updatedAt', null) == request.time\r\n        && request.resource.data.get('balance', 0) is number\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'updatedAt']);\r\n    }\r\n\r\n    function canWriteTripCosts(isCreate) {\r\n      let role = getUserRole();\r\n      return isAuth() && (\r\n        role == 'admin_compagnie' || role == 'admin_platforme' ||\r\n        role == 'company_accountant' || role == 'financial_director' ||\r\n        (role == 'chefAgence' && (\r\n          (isCreate && request.resource.data.get('agencyId', '') == getUserAgencyId()) ||\r\n          (!isCreate && resource.data.get('agencyId', '') == getUserAgencyId())\r\n        ))\r\n      );\r\n    }\r\n    function canModifyFleet() {\r\n      return isFleetController() || isAgencyManager();\r\n    }\r\n    function canReadFleet() {\r\n      return isFleetController() || isAgencyManager() || isBoardingOfficer() || isResponsableLogistique();\r\n    }\r\n    function vehicleStatusVehiculeShapeOk() {\r\n      let s = request.resource.data.get('statusVehicule', '');\r\n      let agency = request.resource.data.get('currentAgencyId', null);\r\n      return (s == 'disponible' || s == 'affecte' || s == 'en_transit' || s == 'en_maintenance')\r\n        && (s != 'en_transit' || agency == null);\r\n    }\r\n    function vehicleLiveStateCreateOk() {\r\n      return request.resource.data.keys().hasOnly([\r\n        'companyId', 'vehicleId', 'tripInstanceId', 'statutMetier', 'statusVehicule',\r\n        'currentAgencyId', 'destinationAgencyId', 'lastKnownAgencyId', 'isReturnToOrigin', 'updatedAt'\r\n      ]);\r\n    }\r\n    function vehicleLiveStateWriteOk() {\r\n      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n        'companyId', 'vehicleId', 'tripInstanceId', 'statutMetier', 'statusVehicule',\r\n        'currentAgencyId', 'destinationAgencyId', 'lastKnownAgencyId', 'isReturnToOrigin', 'updatedAt'\r\n      ]);\r\n    }\r\n    /** operationalStatus réservé au garage (changement technique) ou ignoré si pas touché. */\r\n    function vehicleOperationalStatusWriteOk() {\r\n      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['operationalStatus'])\r\n        || request.resource.data.diff(resource.data).affectedKeys().hasAny(['technicalStatus']);\r\n    }\r\n    /** Phase 3.5 — verrou embarquement sur tripAssignments (boardingSession uniquement). */\r\n    function tripAssignmentCoreUnchangedForBoarding() {\r\n      return request.resource.data.tripId == resource.data.tripId\r\n        && request.resource.data.date == resource.data.date\r\n        && request.resource.data.heure == resource.data.heure\r\n        && request.resource.data.vehicleId == resource.data.vehicleId\r\n        && request.resource.data.agencyId == resource.data.agencyId\r\n        && request.resource.data.status == resource.data.status;\r\n    }\r\n    /** Embarquement : chef / équipe / escale sur l’agence du créneau ; admins société ou plateforme (souvent sans agencyId) comme pour liveStatus. */\r\n    function canWriteTripAssignmentBoardingSession(companyId, agencyId) {\r\n      return isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (\r\n        hasUserRole('admin_compagnie')\r\n        || hasUserRole('admin_platforme')\r\n        || (\r\n          getUserAgencyId() == agencyId\r\n          && userAgencyBelongsToCompany(companyId)\r\n        )\r\n      );\r\n    }\r\n    function tripAssignmentBoardingSessionActivateOk() {\r\n      let next = request.resource.data.boardingSession;\r\n      let prev = resource.data.get('boardingSession', {});\r\n      return next.keys().hasAll(['startedBy', 'startedAt', 'status', 'clientInstanceId'])\r\n        && next.startedBy == request.auth.uid\r\n        && next.status == 'active'\r\n        && next.clientInstanceId is string\r\n        && (\r\n          prev.get('status', '') != 'active'\r\n          || (\r\n            prev.get('status', '') == 'active'\r\n            && prev.get('clientInstanceId', '') == next.clientInstanceId\r\n            && prev.get('startedBy', '') == request.auth.uid\r\n          )\r\n        );\r\n    }\r\n    function tripAssignmentBoardingSessionCloseOk() {\r\n      let prev = resource.data.get('boardingSession', {});\r\n      let next = request.resource.data.boardingSession;\r\n      return prev.get('status', '') == 'active'\r\n        && next.status == 'closed'\r\n        && next.clientInstanceId == prev.get('clientInstanceId', '')\r\n        && next.startedBy == prev.get('startedBy', '')\r\n        && next.startedAt == prev.get('startedAt', '')\r\n        && next.keys().hasAll(['startedBy', 'startedAt', 'status', 'clientInstanceId', 'closedAt']);\r\n    }\r\n    /** Phase 4 — liveStatus (supervision embarquement). */\r\n    function canWriteTripAssignmentLiveStatus(companyId, agencyId) {\r\n      return isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (\r\n        hasUserRole('admin_compagnie')\r\n        || hasUserRole('admin_platforme')\r\n        || (getUserAgencyId() == agencyId && userAgencyBelongsToCompany(companyId))\r\n      );\r\n    }\r\n    function tripAssignmentLiveStatusShapeOk() {\r\n      let next = request.resource.data.liveStatus;\r\n      return next.keys().hasAll(['boardedCount', 'expectedCount', 'status'])\r\n        && next.boardedCount is int\r\n        && next.boardedCount >= 0\r\n        && next.expectedCount is int\r\n        && next.expectedCount >= 0\r\n        && (next.status == 'waiting' || next.status == 'boarding' || next.status == 'completed');\r\n    }\r\n    /* Read access for company data: same company, platform admin, or responsable_logistique (same company). */\r\n    function canReadCompanyData(companyId) {\r\n      return isAuth() && (\r\n        userCompanyId() == companyId ||\r\n        getUserRole() == 'admin_platforme' ||\r\n        getUserRole() == 'admin_compagnie' ||\r\n        (isResponsableLogistique() && userCompanyId() == companyId)\r\n      );\r\n    }\r\n\r\n    /**\r\n     * Réservation en ligne en attente de preuve (upload preuve / transaction sièges).\r\n     * Flux actuel : statut legacy \"en_attente\" OU champ SaaS status \"en_attente\" + hold ; alias : \"en_attente_paiement\".\r\n     */\r\n    function reservationAwaitingOnlinePaymentProof() {\r\n      let s = resource.data.get('statut', '');\r\n      let lifecycle = resource.data.get('status', '');\r\n      let statutOk = s == 'en_attente_paiement'\r\n        || s == 'en_attente'\r\n        || (s is string && (\r\n          s.toLowerCase().replace(' ', '_') == 'en_attente_paiement'\r\n          || s.toLowerCase().replace(' ', '_') == 'en_attente'\r\n        ));\r\n      let statusOk = lifecycle == 'en_attente'\r\n        || lifecycle == 'en_attente_paiement'\r\n        || (lifecycle is string && (\r\n          lifecycle.toLowerCase().replace(' ', '_') == 'en_attente'\r\n          || lifecycle.toLowerCase().replace(' ', '_') == 'en_attente_paiement'\r\n        ));\r\n      return statutOk || statusOk;\r\n    }\r\n\r\n    /* =====================\r\n       DONNÉES PUBLIQUES\r\n    ===================== */\r\n    match /villes/{id} {\r\n      allow get, list: if true;\r\n    }\r\n\r\n    match /paymentMethods/{id} {\r\n      // Catalogue public.\r\n      // Note: pour préserver les anciennes règles, on garde get/list publics.\r\n      allow get, list: if true;\r\n\r\n      // CRUD : plateforme uniquement.\r\n      allow create, update, delete: if isPlatformAdmin();\r\n    }\r\n\r\n\r\n\r\n\r\n    /* Résolution publique des réservations par token uniquement. Doc id = publicToken ; accès par get(id) uniquement (pas de list). */\r\n    match /publicReservations/{docId} {\r\n      allow get, create, update: if true;\r\n      allow list, delete: if false;\r\n    }\r\n\r\n    /* Invitations (onboarding, accept link). Get by id for accept flow; list/create/update/delete authenticated. */\r\n    match /invitations/{invitationId} {\r\n      allow get: if true;\r\n      // CEO invitation activation: page uses queries (getDocs) before auth.\r\n      // Allow list so query(where(\"token\",\"==\",...)) works for anonymous.\r\n      allow list: if true;\r\n      allow create, update, delete: if isAuth();\r\n    }\r\n\r\n    /* Medias (platform / company assets). Authenticated read/write. */\r\n    match /medias/{mediaId} {\r\n      allow get, list, create, update, delete: if isAuth();\r\n    }\r\n\r\n    /* Plans catalog (subscription plans). Public read for plan selection; write authenticated (platform admin). */\r\n    match /plans/{planId} {\r\n      allow get, list: if true;\r\n      allow create, update, delete: if isAuth();\r\n    }\r\n\r\n    /* Metadata (e.g. plansCatalog document). Public read; write authenticated. */\r\n    match /_meta/{docId} {\r\n      allow get, list: if true;\r\n      allow create, update, delete: if isAuth();\r\n    }\r\n\r\n    /* Admin-controlled system plan pricing. */\r\n    match /adminSettings/plans {\r\n      allow get: if isAuth();\r\n      allow list: if false;\r\n      allow create, update: if isPlatformAdmin() && validSystemPlansSettings();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /subscriptionRequests/{requestId} {\r\n      allow create: if isAuth()\r\n        && request.resource.data.keys().hasOnly([\r\n          'companyId',\r\n          'companyName',\r\n          'currentPlan',\r\n          'requestedPlan',\r\n          'status',\r\n          'createdAt'\r\n        ])\r\n        && request.resource.data.keys().hasAll([\r\n          'companyId',\r\n          'companyName',\r\n          'currentPlan',\r\n          'requestedPlan',\r\n          'status',\r\n          'createdAt'\r\n        ])\r\n        && request.resource.data.companyId is string\r\n        && request.resource.data.companyName is string\r\n        && request.resource.data.currentPlan is string\r\n        && request.resource.data.requestedPlan is string\r\n        && request.resource.data.status == 'pending'\r\n        && request.resource.data.createdAt is timestamp\r\n        && (userCompanyId() == request.resource.data.companyId || isPlatformAdmin());\r\n      allow get, list: if isPlatformAdmin();\r\n      allow update: if isPlatformAdmin()\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])\r\n        && request.resource.data.status in ['pending', 'approved', 'rejected'];\r\n      allow delete: if isPlatformAdmin();\r\n    }\r\n\r\n    match /upgradeRequests/{requestId} {\r\n      allow create: if isAuth()\r\n        && request.resource.data.keys().hasOnly(['companyId', 'fromPlan', 'toPlan', 'createdAt', 'status'])\r\n        && request.resource.data.keys().hasAll(['companyId', 'fromPlan', 'toPlan', 'createdAt', 'status'])\r\n        && request.resource.data.companyId is string\r\n        && request.resource.data.fromPlan is string\r\n        && request.resource.data.toPlan is string\r\n        && request.resource.data.status == 'pending'\r\n        && (userCompanyId() == request.resource.data.companyId || isPlatformAdmin());\r\n      allow get, list, update, delete: if isPlatformAdmin();\r\n    }\r\n\r\n    /* =====================\r\n       COMPAGNIES / AGENCES\r\n       Multi-tenant: write restricted to own company; read for vitrine: anyone can read company doc + agences (public page).\r\n       Platform admin (admin_platforme) may write any company. Public vitrine: get/list companies allowed for all (visitor may be logged in as another company).\r\n    ===================== */\r\n    match /companies/{companyId} {\r\n      allow get, list: if true;\r\n      allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n      allow update: if validOperationQuotaIncrementOnly();\r\n\r\n      // Payment method configurations per company (used by CompanyPaymentSettingsPage)\r\n      match /paymentConfigs/{configId} {\r\n        allow get, list: if (resource.data.get('active', false) == true)\r\n          && (resource.data.get('isEnabled', false) == true);\r\n\r\n        allow create, update, delete: if isAuth()\r\n          && (userCompanyId() == companyId || isPlatformAdmin());\r\n      }\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n      /* Avis clients (vitrine publique) : lecture publique sans auth pour page compagnie */\r\n      match /avis/{avisId} {\r\n        allow read: if request.auth == null || userCompanyId() == companyId || getUserRole() == 'admin_platforme';\r\n        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n      }\r\n\r\n      /* Journal d’activité commercial (CA terrain) : append-only, hors ledger. */\r\n      match /activityLogs/{logId} {\r\n        allow get, list: if isAuth() && (\r\n          userCompanyId() == companyId\r\n          || getUserRole() == 'admin_platforme'\r\n          || (\r\n            userAgencyBelongsToCompany(companyId)\r\n            && resource.data.get('agencyId', '') == getUserAgencyId()\r\n          )\r\n        );\r\n        /* Même logique que guichetSaleLocks / dailyStats : companyId doc OU agence rattachée à la compagnie (évite 403 si companyId token désynchronisé). */\r\n        allow create: if isAuth()\r\n          && request.resource.data.companyId == companyId\r\n          && (\r\n            userCompanyId() == companyId\r\n            || getUserRole() == 'admin_platforme'\r\n            || (\r\n              userAgencyBelongsToCompany(companyId)\r\n              && request.resource.data.agencyId == getUserAgencyId()\r\n            )\r\n          )\r\n          && request.resource.data.keys().hasAll(['type', 'source', 'amount', 'seats', 'agencyId', 'companyId', 'createdAt', 'status'])\r\n          && request.resource.data.agencyId is string\r\n          && request.resource.data.status == 'confirmed'\r\n          && request.resource.data.amount is number\r\n          && request.resource.data.seats is number\r\n          && request.resource.data.type in ['ticket', 'online', 'courier']\r\n          && request.resource.data.source in ['guichet', 'online']\r\n          && request.resource.data.createdAt is timestamp;\r\n        allow update, delete: if false;\r\n      }\r\n\r\n      /* Routes réseau. Lecture publique pour calcul places (résa en ligne) ; écriture = compagnie / admin. */\r\n      match /routes/{routeId} {\r\n        allow get, list: if true;\r\n        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId));\r\n        /* Escales (stops) : lecture publique pour quota par segment. */\r\n        match /stops/{stopId} {\r\n          allow get, list: if true;\r\n          allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId));\r\n        }\r\n      }\r\n\r\n      /* Company banks (used by agency accounting transfer flow and CEO settings). */\r\n      match /companyBanks/{bankId} {\r\n        allow get, list: if canAccessSensitiveCompanyFinance(companyId);\r\n        allow create, update: if canAccessSensitiveCompanyFinance(companyId);\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Agrégats planification (totalPlannedVehicles, totalTrips) — recalcul côté client après mutations. */\r\n      match /planningStats/{docId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          getUserRole() == 'admin_compagnie' ||\r\n          getUserRole() == 'chefAgence' ||\r\n          getUserRole() == 'chefagence' ||\r\n          getUserRole() == 'superviseur' ||\r\n          getUserRole() == 'agency_fleet_controller' ||\r\n          getUserRole() == 'responsable_logistique' ||\r\n          getUserRole() == 'admin_platforme'\r\n        );\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Compteurs incrémentaux par véhicule (planification) — transactions client create/update/delete. */\r\n      match /planningVehicleTripCount/{vehicleId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          getUserRole() == 'admin_compagnie' ||\r\n          getUserRole() == 'chefAgence' ||\r\n          getUserRole() == 'chefagence' ||\r\n          getUserRole() == 'superviseur' ||\r\n          getUserRole() == 'agency_fleet_controller' ||\r\n          getUserRole() == 'responsable_logistique' ||\r\n          getUserRole() == 'admin_platforme'\r\n        );\r\n      }\r\n\r\n      /* Trip instances (daily departures). Read: public. Create: public only when initial state (lazy creation on search). Update: (1) same company or platform for full updates; (2) unauthenticated allowed only to increment reservedSeats + updatedAt (public reservation flow). Status: code uses lowercase 'scheduled'. */\r\n      match /tripInstances/{tripInstanceId} {\r\n        allow get, list: if true;\r\n        allow create: if request.resource.data.get('reservedSeats', 0) == 0\r\n          && (request.resource.data.get('status', '') == 'scheduled' || request.resource.data.get('status', '') == 'SCHEDULED')\r\n          && request.resource.data.get('agencyId', '') != ''\r\n          && request.resource.data.get('date', '') != ''\r\n          && request.resource.data.get('departureTime', '') != ''\r\n          && request.resource.data.get('departureCity', '') != ''\r\n          && request.resource.data.get('arrivalCity', '') != '';\r\n        /* Réservation définitive de sièges : utilisateurs internes authentifiés uniquement. */\r\n        allow update: if (\r\n            isAuth()\r\n            && (\r\n              userCompanyId() == companyId\r\n              || userAgencyBelongsToCompany(companyId)\r\n              || getUserRole() == 'admin_platforme'\r\n              || getUserRole() == 'operator_digital'\r\n            )\r\n            && (\r\n              isGuichetier()\r\n              || getUserRole() == 'escale_agent'\r\n              || getUserRole() == 'escale_manager'\r\n              || getUserRole() == 'operator_digital'\r\n              || getUserRole() == 'admin_compagnie'\r\n              || getUserRole() == 'admin_platforme'\r\n            )\r\n            && request.resource.data.diff(resource.data).affectedKeys()\r\n              .hasOnly(['reservedSeats', 'remainingSeats', 'passengerCount', 'updatedAt', 'segments'])\r\n            && (\r\n              getUserRole() == 'operator_digital'\r\n              || (\r\n                request.resource.data.get('reservedSeats', 0) >= resource.data.get('reservedSeats', 0)\r\n                && request.resource.data.get('passengerCount', 0) >= resource.data.get('passengerCount', 0)\r\n                && request.resource.data.get('remainingSeats', 999999) <= resource.data.get('remainingSeats', 999999)\r\n              )\r\n            )\r\n          );\r\n        allow delete: if false;\r\n        /* Progression bus par escale (arrivée/départ). Lecture: public. Écriture: embarquement (départ origine), chef agence, escales, admin. */\r\n        match /progress/{stopOrder} {\r\n          allow get, list: if true;\r\n          allow create, update: if isAuth() && (\r\n              getUserRole() == 'chefAgence' || getUserRole() == 'chefagence'\r\n              || getUserRole() == 'escale_manager' || getUserRole() == 'escale_agent'\r\n              || getUserRole() == 'admin_platforme'\r\n              || isBoardingOfficer()\r\n            ) && (\r\n              userCompanyId() == companyId\r\n              || getUserRole() == 'admin_platforme'\r\n              || escaleUserCanReadCompany(companyId)\r\n              || userAgencyBelongsToCompany(companyId)\r\n            );\r\n          allow delete: if false;\r\n        }\r\n        match /inventory/{docId} {\r\n          allow get, list: if true;\r\n          allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow delete: if false;\r\n        }\r\n      }\r\n\r\n      /* Suivi temps réel inter-agences : tripExecutions */\r\n      function userAgencyCity() {\r\n        let userPath = /databases/$(database)/documents/companies/$(companyId)/agences/$(getUserAgencyId());\r\n        let userData = exists(userPath) ? get(userPath).data : null;\r\n        return userData == null\r\n          ? ''\r\n          : (userData.get('city', '') != ''\r\n            ? userData.get('city', '')\r\n            : (userData.get('villeNorm', '') != ''\r\n              ? userData.get('villeNorm', '')\r\n              : userData.get('ville', '')));\r\n      }\r\n\r\n      match /tripExecutions/{executionId} {\r\n        /* Lecture : chaque agence ne voit que les destinations qui correspondent à sa ville. */\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (\r\n          getUserRole() == 'admin_platforme'\r\n          || getUserRole() == 'admin_compagnie'\r\n          || resource.data.get('destinationCity', '') == userAgencyCity()\r\n        );\r\n\r\n        /* Écriture : uniquement par les rôles qui mettent à jour le cycle (embarquement/escale/fleet/logistique). */\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (\r\n          isBoardingOfficer()\r\n          || isAgencyManager()\r\n          || hasUserRole('escale_manager')\r\n          || hasUserRole('escale_agent')\r\n          || isFleetController()\r\n          || isResponsableLogistique()\r\n          || getUserRole() == 'admin_platforme'\r\n          || getUserRole() == 'admin_compagnie'\r\n        );\r\n        /* Exception ciblée chefEmbarquement: update borné à quelques champs opérationnels. */\r\n        allow update: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId))\r\n          && (hasUserRole('chefEmbarquement') || hasUserRole('chefembarquement'))\r\n          && request.resource.data.diff(resource.data).changedKeys().hasOnly([\r\n            'status', 'departureTime', 'checkpoints', 'updatedAt'\r\n          ]);\r\n\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Caisse (cashTransactions, cashClosures, cashRefunds, cashTransfers). Read/write: same company, platform admin, or escale user whose agency is in this company. */\r\n      match /cashTransactions/{txId} {\r\n        function operatorDigitalCanCreateOnlineCashTransaction() {\r\n          let agencyId = request.resource.data.get('locationId', '');\r\n          let reservationId = request.resource.data.get('reservationId', '');\r\n          let reservationPath = /databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/reservations/$(reservationId);\r\n          return isAuth()\r\n            && hasUserRole('operator_digital')\r\n            && request.resource.data.get('sourceType', '') == 'online'\r\n            && request.resource.data.get('createdBy', '') == request.auth.uid\r\n            && request.resource.data.get('status', '') == 'paid'\r\n            && agencyId is string\r\n            && agencyId != ''\r\n            && reservationId is string\r\n            && reservationId != ''\r\n            && request.resource.data.get('amount', 0) > 0\r\n            && exists(reservationPath)\r\n            && get(reservationPath).data.get('status', '') == 'confirme'\r\n            && get(reservationPath).data.get('statut', '') == 'confirme'\r\n            && get(reservationPath).data.get('validatedBy', '') == request.auth.uid\r\n            && request.resource.data.keys().hasOnly([\r\n              'reservationId',\r\n              'sessionId',\r\n              'sourceType',\r\n              'sourceSessionId',\r\n              'tripInstanceId',\r\n              'amount',\r\n              'currency',\r\n              'paymentMethod',\r\n              'locationType',\r\n              'locationId',\r\n              'routeId',\r\n              'createdBy',\r\n              'date',\r\n              'paidAt',\r\n              'status',\r\n              'seats',\r\n              'routeLabel',\r\n              'accountId',\r\n              'createdAt',\r\n              'paidAtAt'\r\n            ]);\r\n        }\r\n        allow get, list: if isAuth() && (\r\n          userCompanyId() == companyId ||\r\n          getUserRole() == 'admin_platforme' ||\r\n          escaleUserCanReadCompany(companyId) ||\r\n          canWriteAgencyScopedFinance(companyId)\r\n        );\r\n        allow create: if operatorDigitalCanCreateOnlineCashTransaction() || (isAuth() && (\r\n          userCompanyId() == companyId ||\r\n          getUserRole() == 'admin_platforme' ||\r\n          escaleUserCanReadCompany(companyId) ||\r\n          canWriteAgencyScopedFinance(companyId) ||\r\n          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId))\r\n        ));\r\n        allow update: if isAuth() && (\r\n          userCompanyId() == companyId ||\r\n          getUserRole() == 'admin_platforme' ||\r\n          escaleUserCanReadCompany(companyId) ||\r\n          canWriteAgencyScopedFinance(companyId) ||\r\n          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId))\r\n        );\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Virtual sessions (online cash): companies/{companyId}/virtualSessions/{sessionId}\r\n         Created/updated idempotently by cashService.ensureVirtualSession(). */\r\n      match /virtualSessions/{sessionId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if isAuth() && (\r\n          userCompanyId() == companyId\r\n          || getUserRole() == 'admin_platforme'\r\n          || (\r\n            hasUserRole('operator_digital')\r\n            && sessionId.matches('^virtual_online_.*')\r\n            && request.resource.data.get('companyId', '') == companyId\r\n            && request.resource.data.get('agencyId', '') != ''\r\n            && request.resource.data.get('sourceType', '') == 'online'\r\n            && request.resource.data.keys().hasOnly([\r\n              'companyId',\r\n              'agencyId',\r\n              'paidAt',\r\n              'sourceType',\r\n              'updatedAt'\r\n            ])\r\n          )\r\n        );\r\n        allow update: if isAuth() && (\r\n          userCompanyId() == companyId\r\n          || getUserRole() == 'admin_platforme'\r\n          || (\r\n            hasUserRole('operator_digital')\r\n            && sessionId.matches('^virtual_online_.*')\r\n            && resource.data.get('companyId', '') == companyId\r\n            && request.resource.data.get('companyId', '') == companyId\r\n            && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')\r\n            && request.resource.data.get('sourceType', '') == 'online'\r\n            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n              'paidAt',\r\n              'updatedAt'\r\n            ])\r\n          )\r\n        );\r\n        allow delete: if false;\r\n      }\r\n      match /cashClosures/{closureId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));\r\n        allow delete: if false;\r\n      }\r\n      match /cashRefunds/{refundId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));\r\n        allow delete: if false;\r\n      }\r\n      match /cashTransfers/{transferId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));\r\n        allow delete: if false;\r\n      }\r\n\r\n      match /connections/{connectionId} {\r\n        allow get, list, create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));\r\n        allow delete: if false;\r\n      }\r\n\r\n      match /agences/{agencyId} {\r\n        allow get: if request.auth == null || userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId)\r\n          || (isAuth() && (getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && agencyId == getUserAgencyId());\r\n        allow list: if request.auth == null || (request.auth != null && (\r\n          request.auth.token.role == 'admin_platforme' ||\r\n          request.auth.token.companyId != null ||\r\n          request.auth.token.compagnieId != null\r\n        ));\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow delete: if false;\r\n\r\n        match /users/{agencyUserId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow create: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n            request.resource.data.get('role', '') != 'chefAgence'\r\n            || getUserRole() == 'admin_compagnie'\r\n            || getUserRole() == 'admin_platforme'\r\n          )) || (canManageAgencyTeam(agencyId) && request.resource.data.get('role', '') != 'chefAgence');\r\n          allow update: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])\r\n            || request.resource.data.get('role', '') != 'chefAgence'\r\n            || getUserRole() == 'admin_compagnie'\r\n            || getUserRole() == 'admin_platforme'\r\n          )) || (canManageAgencyTeam(agencyId) && (\r\n            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])\r\n            || request.resource.data.get('role', '') != 'chefAgence'\r\n          ));\r\n          allow delete: if false;\r\n        }\r\n\r\n        match /weeklyTrips/{tripId} {\r\n          allow get, list: if request.auth == null || userCompanyId() == companyId || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId)\r\n            || (getUserAgencyId() != '' && agencyId == getUserAgencyId());\r\n          allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n            getUserRole() == 'admin_compagnie' ||\r\n            getUserRole() == 'admin_platforme' ||\r\n            (getUserRole() == 'chefAgence' && getUserAgencyId() == agencyId)\r\n          );\r\n        }\r\n\r\n        /* Verrou créneau planification (concurrence) — holderUid = request.auth.uid, TTL côté client. */\r\n        match /planningLocks/{lockId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (\r\n            (getUserAgencyId() == agencyId && (\r\n              getUserRole() == 'chefAgence' ||\r\n              getUserRole() == 'chefagence' ||\r\n              getUserRole() == 'superviseur' ||\r\n              getUserRole() == 'agency_fleet_controller' ||\r\n              getUserRole() == 'admin_compagnie'\r\n            ))\r\n            || getUserRole() == 'admin_compagnie'\r\n            || (isResponsableLogistique() && userCompanyId() == companyId)\r\n          );\r\n          allow create, update: if isAuth() && userCompanyId() == companyId && (\r\n            (\r\n              getUserAgencyId() == agencyId && (\r\n                getUserRole() == 'chefAgence' ||\r\n                getUserRole() == 'chefagence' ||\r\n                getUserRole() == 'superviseur' ||\r\n                getUserRole() == 'admin_compagnie'\r\n              )\r\n            )\r\n            || getUserRole() == 'admin_compagnie'\r\n          )\r\n            && request.resource.data.keys().hasAll(['holderUid', 'acquiredAt'])\r\n            && request.resource.data.holderUid == request.auth.uid;\r\n          allow delete: if isAuth() && userCompanyId() == companyId && (\r\n            (\r\n              getUserAgencyId() == agencyId && (\r\n                getUserRole() == 'chefAgence' ||\r\n                getUserRole() == 'chefagence' ||\r\n                getUserRole() == 'superviseur' ||\r\n                getUserRole() == 'admin_compagnie'\r\n              )\r\n            )\r\n            || getUserRole() == 'admin_compagnie'\r\n          )\r\n            && resource.data.get('holderUid', '') == request.auth.uid;\r\n        }\r\n\r\n        /* Index miroir créneau véhicule (atomicité planification). */\r\n        match /tripAssignmentVehicleSlots/{slotId} {\r\n          allow get, list: if isAuth() && userCompanyId() == companyId && (\r\n            (getUserAgencyId() == agencyId && (\r\n              getUserRole() == 'chefAgence' ||\r\n              getUserRole() == 'chefagence' ||\r\n              getUserRole() == 'superviseur' ||\r\n              getUserRole() == 'chefEmbarquement' ||\r\n              getUserRole() == 'chefembarquement' ||\r\n              getUserRole() == 'agency_boarding_officer' ||\r\n              getUserRole() == 'embarquement' ||\r\n              getUserRole() == 'escale_agent' ||\r\n              getUserRole() == 'escale_manager' ||\r\n              getUserRole() == 'agency_fleet_controller'\r\n            ))\r\n            || getUserRole() == 'admin_compagnie'\r\n            || (isResponsableLogistique() && userCompanyId() == companyId)\r\n          );\r\n          allow create, update: if isAuth() && userCompanyId() == companyId && (\r\n            (\r\n              getUserAgencyId() == agencyId && (\r\n                getUserRole() == 'chefAgence' ||\r\n                getUserRole() == 'chefagence' ||\r\n                getUserRole() == 'superviseur' ||\r\n                getUserRole() == 'admin_compagnie' ||\r\n                getUserRole() == 'agency_fleet_controller'\r\n              )\r\n            )\r\n            || getUserRole() == 'admin_compagnie'\r\n            || (isResponsableLogistique() && userCompanyId() == companyId)\r\n          )\r\n            && request.resource.data.keys().hasAll(['assignmentId', 'vehicleId', 'tripId', 'date', 'heure', 'status', 'updatedAt'])\r\n            && request.resource.data.assignmentId is string\r\n            && request.resource.data.vehicleId is string\r\n            && request.resource.data.tripId is string\r\n            && request.resource.data.date is string\r\n            && request.resource.data.heure is string\r\n            && (request.resource.data.status == 'planned' || request.resource.data.status == 'validated');\r\n          allow delete: if isAuth() && userCompanyId() == companyId && (\r\n            (\r\n              getUserAgencyId() == agencyId && (\r\n                getUserRole() == 'chefAgence' ||\r\n                getUserRole() == 'chefagence' ||\r\n                getUserRole() == 'superviseur' ||\r\n                getUserRole() == 'admin_compagnie'\r\n              )\r\n            )\r\n            || getUserRole() == 'admin_compagnie'\r\n            || (isResponsableLogistique() && userCompanyId() == companyId)\r\n          );\r\n        }\r\n\r\n        /* Affectations trajet + date + heure → véhicule (planifié par chef/superviseur, validé par logistique). */\r\n        match /tripAssignments/{assignmentId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (\r\n            (getUserAgencyId() == agencyId && (\r\n              getUserRole() == 'chefAgence' ||\r\n              getUserRole() == 'chefagence' ||\r\n              getUserRole() == 'superviseur' ||\r\n              getUserRole() == 'chefEmbarquement' ||\r\n              getUserRole() == 'chefembarquement' ||\r\n              getUserRole() == 'agency_boarding_officer' ||\r\n              getUserRole() == 'embarquement' ||\r\n              getUserRole() == 'escale_agent' ||\r\n              getUserRole() == 'escale_manager' ||\r\n              getUserRole() == 'agency_fleet_controller'\r\n            ))\r\n            || getUserRole() == 'admin_compagnie'\r\n            || (isResponsableLogistique() && userCompanyId() == companyId)\r\n          );\r\n          allow create: if isAuth() && userCompanyId() == companyId && (\r\n            (getUserAgencyId() == agencyId && (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur'))\r\n            || getUserRole() == 'admin_compagnie'\r\n          )\r\n            && request.resource.data.keys().hasAll(['tripId', 'date', 'heure', 'vehicleId', 'agencyId', 'status', 'liveStatus'])\r\n            && request.resource.data.agencyId == agencyId\r\n            && request.resource.data.status == 'planned'\r\n            && request.resource.data.tripId is string\r\n            && request.resource.data.date is string\r\n            && request.resource.data.heure is string\r\n            && request.resource.data.vehicleId is string\r\n            && request.resource.data.liveStatus.keys().hasAll(['boardedCount', 'expectedCount', 'status'])\r\n            && request.resource.data.liveStatus.boardedCount == 0\r\n            && request.resource.data.liveStatus.status == 'waiting'\r\n            && request.resource.data.liveStatus.expectedCount is int\r\n            && request.resource.data.liveStatus.expectedCount >= 0;\r\n          allow update: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (\r\n            (\r\n              getUserAgencyId() == agencyId &&\r\n              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&\r\n              (resource.data.status == 'cancelled' || resource.data.status == 'rejected') &&\r\n              request.resource.data.status == 'planned' &&\r\n              request.resource.data.agencyId == agencyId &&\r\n              request.resource.data.tripId is string &&\r\n              request.resource.data.date is string &&\r\n              request.resource.data.heure is string &&\r\n              request.resource.data.vehicleId is string &&\r\n              request.resource.data.liveStatus.keys().hasAll(['boardedCount', 'expectedCount', 'status']) &&\r\n              request.resource.data.liveStatus.boardedCount == 0 &&\r\n              request.resource.data.liveStatus.status == 'waiting' &&\r\n              request.resource.data.liveStatus.expectedCount is int &&\r\n              request.resource.data.liveStatus.expectedCount >= 0\r\n            )\r\n            || (\r\n              getUserAgencyId() == agencyId &&\r\n              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&\r\n              resource.data.status == 'planned' &&\r\n              request.resource.data.status == 'planned'\r\n            )\r\n            || (\r\n              getUserAgencyId() == agencyId &&\r\n              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&\r\n              resource.data.status == 'planned' &&\r\n              request.resource.data.status == 'cancelled' &&\r\n              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])\r\n            )\r\n            || (\r\n              getUserAgencyId() == agencyId &&\r\n              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&\r\n              resource.data.status == 'validated' &&\r\n              request.resource.data.status == 'cancelled' &&\r\n              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])\r\n            )\r\n            || (\r\n              resource.data.status == 'planned' &&\r\n              request.resource.data.status == 'validated' &&\r\n              (\r\n                (getUserAgencyId() == agencyId && getUserRole() == 'agency_fleet_controller') ||\r\n                getUserRole() == 'admin_compagnie' ||\r\n                (isResponsableLogistique() && userCompanyId() == companyId)\r\n              )\r\n            )\r\n            || (\r\n              canWriteTripAssignmentBoardingSession(companyId, agencyId)\r\n              && tripAssignmentCoreUnchangedForBoarding()\r\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['boardingSession', 'updatedAt'])\r\n              && (\r\n                tripAssignmentBoardingSessionActivateOk()\r\n                || tripAssignmentBoardingSessionCloseOk()\r\n              )\r\n            )\r\n            || (\r\n              canWriteTripAssignmentBoardingSession(companyId, agencyId)\r\n              && tripAssignmentCoreUnchangedForBoarding()\r\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['boardingSession', 'updatedAt'])\r\n              && request.resource.data.boardingSession.status == 'active'\r\n              && request.resource.data.boardingSession.clientInstanceId is string\r\n            )\r\n            || (\r\n              canWriteTripAssignmentBoardingSession(companyId, agencyId)\r\n              && tripAssignmentCoreUnchangedForBoarding()\r\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['boardingSession', 'updatedAt'])\r\n              && request.resource.data.boardingSession.status == 'closed'\r\n              && request.resource.data.boardingSession.clientInstanceId is string\r\n            )\r\n            || (\r\n              canWriteTripAssignmentLiveStatus(companyId, agencyId)\r\n              && tripAssignmentCoreUnchangedForBoarding()\r\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['liveStatus', 'updatedAt'])\r\n              && tripAssignmentLiveStatusShapeOk()\r\n            )\r\n          );\r\n          allow delete: if false;\r\n        }\r\n\r\n        /* Verrou idempotence vente guichet (créé dans la même transaction que la réservation). */\r\n        match /guichetSaleLocks/{lockId} {\r\n          allow get: if isAuth() && userAgencyBelongsToCompany(companyId) && getUserAgencyId() == agencyId;\r\n          allow create: if isAuth() && userAgencyBelongsToCompany(companyId) && getUserAgencyId() == agencyId\r\n            && request.resource.data.keys().hasAll(['reservationId', 'sessionId', 'agentId'])\r\n            && request.resource.data.get('reservationId', '').size() > 0\r\n            && request.resource.data.get('sessionId', '').size() > 0\r\n            && request.resource.data.agentId == request.auth.uid\r\n            && (\r\n              isGuichetier()\r\n              || getUserRole() == 'escale_agent'\r\n              || getUserRole() == 'escale_manager'\r\n            );\r\n          allow update, delete: if false;\r\n          allow list: if false;\n        }\r\n\r\n        match /reservations/{reservationId} {\r\n\r\n          /* 🔓 Création publique. Lecture réservée aux utilisateurs compagnie ; accès billet public = via publicReservations (doc id = publicToken) uniquement. */\r\n          allow create: if (\r\n            request.auth == null\r\n            || publicOnlineReservationCreate(companyId, agencyId)\r\n            || userCompanyId() == companyId\r\n            || getUserRole() == 'admin_platforme'\r\n            || (\r\n              userAgencyBelongsToCompany(companyId)\r\n              && getUserAgencyId() == request.resource.data.get('agencyId', '')\r\n            )\r\n          )\r\n            && reservationCreatePaymentChannelShapeOk();\r\n          /* get : compagnie / agence rattachée / admin_platforme ; ou public pour résa en_ligne (upload preuve, reçu, mon-billet). list : jamais en public. */\r\n          allow get: if (isAuth() && (\r\n              userCompanyId() == companyId\r\n              || getUserRole() == 'admin_platforme'\r\n              || userAgencyBelongsToCompany(companyId)\r\n              || (getUserRole() == 'operator_digital' && userCompanyId() == companyId)\r\n            ))\r\n            || (isAuth()\r\n              && hasUserRole('operator_digital')\r\n              && resource.data.get('companyId', '') == companyId\r\n              && resource.data.get('agencyId', '') == agencyId\r\n              && (\r\n                resource.data.get('canal', '') in ['en_ligne', 'online']\r\n                || resource.data.get('paymentChannel', '') in ['en_ligne', 'online']\r\n              ))\r\n            || (\r\n              request.auth == null\r\n              && resource.data.get('companyId', '') == companyId\r\n              && resource.data.get('agencyId', '') == agencyId\r\n              && (\r\n                resource.data.get('canal', '') in ['en_ligne', 'online']\r\n                || resource.data.get('paymentChannel', '') in ['en_ligne', 'online']\r\n              )\r\n              && (\r\n                resource.data.get('status', '') in ['en_attente', 'en_attente_paiement']\r\n                || resource.data.get('statut', '') in ['en_attente', 'en_attente_paiement']\r\n                || resource.data.get('payment', {}).get('status', '') == 'pending'\r\n              )\r\n            );\r\n          allow list: if isAuth() && (\r\n            getUserRole() == 'admin_platforme'\r\n            || userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || (getUserRole() == 'operator_digital' && userCompanyId() == companyId)\r\n            || request.auth.token.companyId == companyId\r\n            || request.auth.token.compagnieId == companyId\r\n          );\r\n\r\n          /* =============================\r\n             UPDATE 1 — APRÈS CRÉATION\r\n             (publicToken / publicUrl ; updatedAt optionnel pour conformité)\r\n          ============================= */\r\n          allow update: if (\r\n            request.auth == null &&\r\n            resource.data.canal == \"en_ligne\" &&\r\n            reservationAwaitingOnlinePaymentProof() &&\r\n            (\r\n              request.resource.data.diff(resource.data).changedKeys().hasOnly([\"publicToken\", \"publicUrl\"])\r\n              || request.resource.data.diff(resource.data).changedKeys().hasOnly([\"publicToken\", \"publicUrl\", \"updatedAt\"])\r\n            )\r\n          );\r\n\r\n          /* =============================\r\n             UPDATE 2 — SOUMISSION PREUVE (public ou utilisateur connecté)\r\n             Passage en_attente_paiement → preuve_recue. UploadPreuvePage.\r\n          ============================= */\r\n          allow update: if (\r\n            publicOnlineProofSubmitOk(companyId, agencyId)\r\n          );\r\n          allow update: if (\r\n            (resource.data.get('canal', '') == '' || (resource.data.get('canal', '') is string && resource.data.get('canal', '').toLowerCase().replace(' ', '_') == \"en_ligne\")) &&\r\n            reservationAwaitingOnlinePaymentProof() &&\r\n            (request.resource.data.get('statut', '') == \"preuve_recue\" || (request.resource.data.get('statut', '') is string && request.resource.data.get('statut', '').toLowerCase() == \"preuve_recue\"))\r\n          );\r\n          allow update: if (\r\n            reservationAwaitingOnlinePaymentProof() &&\r\n            request.resource.data.get('statut', '') == \"preuve_recue\"\r\n          );\r\n          allow update: if operatorDigitalCanCommitOnlineReservation(companyId, agencyId);\r\n          allow update: if operatorDigitalCanRejectOnlineReservation(companyId, agencyId);\r\n          allow update: if operatorDigitalCanFinalizeOnlineReservation(companyId, agencyId);\r\n\r\n          /* ✅ Embarquement mobile: autoriser update ciblé même si shift validé.\n             Nécessaire pour scan terrain (boardingStatus/journeyStatus + audit). */\n          allow update: if canBoardingOfficerOperateReservation(companyId, agencyId);\n          allow update: if boardingOfficerCanUpdateReservation(companyId, agencyId);\n\n          /* 🔐 Phase B — Utilisateurs internes : transition de statut autorisée par rôle ;\n             contrôleur embarquement : champs restreints.\r\n             operator_digital : peut valider/refuser même si shiftId est présent/validé, mais\r\n             pour les updates \"non-statut\" on limite les clés autorisées (cash/paiement). */\r\n          allow update, delete: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          ) && (\r\n            (\r\n              getUserRole() == 'operator_digital' ||\r\n              /* Validation finale chef/compta : autoriser le marquage validatedAt/updatedAt\r\n                 même si le shift est déjà VALIDATED (sans changement de statut réservation). */\r\n              (\r\n                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['statut']) &&\r\n                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['validatedAt', 'updatedAt']) &&\r\n                (isAgencyManager() || isComptable() || getUserRole() == 'admin_platforme')\r\n              ) ||\r\n              (resource.data.get('shiftId', '') == '' ||\r\n              !exists(/databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/shifts/$(resource.data.shiftId)) ||\r\n              get(/databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/shifts/$(resource.data.shiftId)).data.get('status', '') != 'validated')\r\n            )\r\n            && (\r\n              (\r\n                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['statut'])\r\n                ? (getUserRole() != 'operator_digital'\r\n                  || request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n                    'cashTransactionId',\r\n                    'paymentStatus',\r\n                    'paymentMethod',\r\n                    'updatedAt',\r\n                    'payment',\r\n                    'status',\r\n                    'refusedBy',\r\n                    'refusedAt',\r\n                    'refusalReason',\r\n                    'ticketValidatedAt',\r\n                    'auditLog',\r\n                    'validatedBy',\r\n                    'ticketRevenueCountedInDailyStats'\r\n                  ]))\r\n                : true\r\n              )\r\n              && (\r\n                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['statut'])\r\n                || (validReservationStatutTransition() && (\r\n                  !isBoardingOfficer()\r\n                  || boardingOfficerAllowedKeysOnly()\r\n                ))\r\n              )\r\n            )\r\n          );\r\n        }\r\n\r\n        match /shifts/{shiftId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'\r\n            || isComptable()\n            || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && agencyId == getUserAgencyId()));\r\n          allow create: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId) || getUserRole() == 'admin_platforme'\r\n            || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && agencyId == getUserAgencyId()))\r\n            && request.resource.data.get('companyId', '') == companyId\r\n            && request.resource.data.get('agencyId', '') == agencyId\r\n            && request.resource.data.get('userId', '').size() > 0\r\n            && request.resource.data.get('status', '') in ['active', 'pending'];\r\n          /* Pause billetterie (active → paused) : uniquement le guichetier titulaire du poste (pas le comptable). */\r\n          allow update: if isAuth() && (\r\n            (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId) || getUserRole() == 'admin_platforme') && (\r\n              resource.data.status != 'validated' &&\r\n              (resource.data.status != 'active' || request.resource.data.status != 'paused'\r\n                || (isGuichetier() && resource.data.userId == request.auth.uid && getUserAgencyId() == agencyId)) &&\r\n              (request.resource.data.status != 'closed' || (isGuichetier() && resource.data.userId == request.auth.uid && getUserAgencyId() == agencyId)) &&\r\n              /* CLOSED → validated_agency : comptable d'agence (validateSessionByAccountant) ou chef / admin compagnie */\r\n              (request.resource.data.status != 'validated_agency' || ((isAgencyManager() || isComptable()) && getUserAgencyId() == agencyId)) &&\r\n              (request.resource.data.status != 'validated' || (isAgencyManager() && getUserAgencyId() == agencyId))\r\n            )\r\n            || (isEscaleManager() && agencyId == getUserAgencyId() && resource.data.status == 'pending' && request.resource.data.status == 'active')\r\n          )\r\n          && request.resource.data.get('companyId', '') == companyId\r\n          && request.resource.data.get('agencyId', '') == agencyId;\r\n          allow delete: if false;\r\n        }\r\n\r\nmatch /shiftReports/{reportId} {\r\n  allow get, list: if isAuth() && (\r\n    userCompanyId() == companyId\r\n    || getUserRole() == 'admin_platforme'\r\n    || (\r\n      userAgencyBelongsToCompany(companyId)\r\n      && getUserAgencyId() == agencyId\r\n      && (\r\n        isGuichetier()\r\n        || getUserRole() == 'agentCourrier'\r\n        || isComptable()\n        || getUserRole() == 'escale_agent'\r\n        || getUserRole() == 'escale_manager'\r\n      )\r\n    )\r\n  );\r\n\r\n  allow create: if isAuth() && (\r\n    userCompanyId() == companyId\r\n    || getUserRole() == 'admin_platforme'\r\n    || (\r\n      userAgencyBelongsToCompany(companyId)\r\n      && getUserAgencyId() == agencyId\r\n      && (\r\n        isGuichetier()\r\n        || getUserRole() == 'agentCourrier'\r\n        || isComptable()\n        || getUserRole() == 'escale_agent'\r\n        || getUserRole() == 'escale_manager'\r\n      )\r\n    )\r\n  );\r\n\r\n  allow update: if isAuth() && (\r\n    (\r\n      userCompanyId() == companyId\r\n      || userAgencyBelongsToCompany(companyId)\r\n      || getUserRole() == 'admin_platforme'\r\n    )\r\n    && (\r\n      resource.data.get('status', '') != 'validated'\r\n      && (\r\n        request.resource.data.get('status', '') != 'validated_agency'\r\n        || ((isAgencyManager() || isComptable()) && getUserAgencyId() == agencyId)\r\n      )\r\n      && (\r\n        request.resource.data.get('status', '') != 'validated'\r\n        || (isAgencyManager() && getUserAgencyId() == agencyId)\r\n      )\r\n    )\r\n  )\r\n  || (isEscaleManager() && agencyId == getUserAgencyId());\r\n\r\n  allow delete: if false;\r\n}\r\n\r\n        /* Courier sessions (agency-scoped, Ticket-like lifecycle) */\n        match /courierSessions/{sessionId} {\n          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || isComptable());\n          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\n          allow update: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))\n            || courierSessionAccountantValidationOk(companyId, agencyId);\n          allow delete: if false;\n        }\n\r\n        match /boardingClosures/{closureId} {\r\n          allow get, list: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow create, update: if (isBoardingOfficer() || isAgencyManager()) && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow delete: if false;\r\n        }\r\n\r\n        match /boardingLogs/{logId} {\r\n          allow get, list: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow create: if (isBoardingOfficer() || isAgencyManager() || isEscaleOperator()) && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow update, delete: if false;\r\n        }\r\n\r\n        match /boardingLocks/{lockId} {\r\n          allow get, list, create: if (isBoardingOfficer() || isAgencyManager() || isEscaleOperator()) && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow update, delete: if false;\r\n        }\r\n\r\n        /* Phase 4.5 — idempotence compteur live (un doc par affectation + réservation). Création seule, pas de MAJ. */\r\n        match /boardingEmbarkDedup/{dedupId} {\r\n          allow get, list: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          /* Même périmètre que liveStatus (escale + boarding) et que boardingLogs/boardingLocks (chef / contrôleur). */\r\n          allow create: if isAuth() && (\r\n              ((isBoardingOfficer() || isAgencyManager()) && (\r\n                userCompanyId() == companyId\r\n                || userAgencyBelongsToCompany(companyId)\r\n                || getUserRole() == 'admin_platforme'\r\n              ))\r\n              || canWriteTripAssignmentLiveStatus(companyId, agencyId)\r\n            )\r\n            && request.resource.data.keys().hasOnly(['reservationId', 'tripAssignmentId', 'scannedAt'])\r\n            && request.resource.data.reservationId is string\r\n            && request.resource.data.tripAssignmentId is string\r\n            && request.resource.data.scannedAt is timestamp;\r\n          allow update, delete: if false;\r\n        }\r\n\r\n        /** Journal centralisé des actions agents (lecture : supervision ; écriture : opérationnels). */\r\n        match /agentHistory/{eventId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && getUserAgencyId() == agencyId && (\r\n            isComptable() || isAgencyManager()\r\n            || getUserRole() == 'superviseur'\r\n            || getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow create: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && getUserAgencyId() == agencyId && (\r\n            isGuichetier() || isComptable() || isAgencyManager() || isBoardingOfficer()\r\n            || getUserRole() == 'agentCourrier' || getUserRole() == 'superviseur'\r\n            || getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager'\r\n            || getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow update, delete: if false;\r\n        }\r\n\r\n        /* Phase 4.5 — Aggregated state (dailyStats, boardingStats, agencyLiveState). responsable_logistique: read-only (no accounting). */\r\n        match /dailyStats/{dateId} {\r\n          allow get, list: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow create, update: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          ) && !isResponsableLogistique();\r\n          allow delete: if false;\r\n        }\r\n        match /boardingStats/{tripKey} {\r\n          allow get, list: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow create, update: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          ) && !isResponsableLogistique();\r\n          allow delete: if false;\r\n        }\r\n        match /agencyLiveState/current {\r\n          allow get, list: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow create, update: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || userAgencyBelongsToCompany(companyId)\r\n            || getUserRole() == 'admin_platforme'\r\n          ) && !isResponsableLogistique();\r\n          allow delete: if false;\r\n        }\r\n\r\n        match /affectations/{affectationId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow create, update: if (canModifyFleet() || isAgencyManager() || isResponsableLogistique()) && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow delete: if false;\r\n        }\r\n\r\n        /* Phase 3: Courier batches (lots) — agency-scoped. Create + DRAFT updates: any auth. DEPARTED/CLOSED: chefAgence or admin_compagnie only. */\r\n        match /batches/{batchId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n            resource.data.get('status', '') == 'DRAFT'\r\n            || (request.resource.data.get('status', '') == 'READY' && resource.data.get('status', '') == 'DRAFT')\r\n            || (request.resource.data.get('status', '') == 'DEPARTED' && isAgencyManager())\r\n            || (request.resource.data.get('status', '') == 'CLOSED' && isAgencyManager())\r\n          );\r\n          allow delete: if false;\r\n        }\r\n\r\n        /* Agency cash receipts (guichet encaissements) used by accounting cash dashboard. */\n        match /cashReceipts/{receiptId} {\n          allow get, list: if isAuth() && (\n            userCompanyId() == companyId\n            || getUserRole() == 'admin_platforme'\n            || canReadOwnAgencyAccountingData(companyId, agencyId)\n          );\n          allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\n          allow delete: if false;\n        }\n\n        /* Ledger-based cash control snapshots (no financial impact). Accountant compares physical cash vs ledger solde. */\n        match /cashAudits/{auditId} {\n          allow get, list: if isAuth() && (\n            userCompanyId() == companyId\n            || getUserRole() == 'admin_platforme'\n            || canReadOwnAgencyAccountingData(companyId, agencyId)\n          );\n          allow create: if isAuth() && (\n            userCompanyId() == companyId\n            || getUserRole() == 'admin_platforme'\n            || (\n              canReadOwnAgencyAccountingData(companyId, agencyId)\n              && request.resource.data.get('companyId', '') == companyId\n              && request.resource.data.get('agencyId', '') == agencyId\n              && request.resource.data.get('validatedBy', {}).get('id', '') == request.auth.uid\n            )\n          );\n          allow update, delete: if false;\n        }\n\r\n        /* Écritures comptables encaissement (une par validation de session guichet / courrier). */\n        match /comptaEncaissements/{entryId} {\n          allow get, list: if isAuth() && (\r\n            userCompanyId() == companyId\r\n            || getUserRole() == 'admin_platforme'\r\n            || (\r\n              userAgencyBelongsToCompany(companyId)\r\n              && getUserAgencyId() == agencyId\r\n            )\r\n          );\r\n          allow create: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))\n            || comptaEncaissementCreateOk(companyId, agencyId);\n          allow update: if false;\n          /* Suppression réservée au renvoi courrier chef → comptable (doc `courier_*` uniquement). */\r\n          allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n            getUserRole() == 'admin_platforme' ||\r\n            isAgencyManager()\r\n          ) && entryId.matches('courier_.+');\r\n        }\r\n\r\n        /* Agency cash movements (comptabilité). Authenticated read/write. */\n        match /cashMovements/{movementId} {\n          allow get, list: if isAuth() && (\n            userCompanyId() == companyId\n            || getUserRole() == 'admin_platforme'\n            || canReadOwnAgencyAccountingData(companyId, agencyId)\n          );\n          allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\n          allow delete: if false;\n        }\n\r\n        /* Agency personnel. Authenticated read/write. */\r\n        match /personnel/{personnelId} {\r\n          allow get, list, create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow delete: if false;\r\n        }\r\n\r\n        /* Agency-level counters (e.g. agent courrier codes). Authenticated read/write. */\r\n        match /counters/{counterId} {\r\n          allow get, list, create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow delete: if false;\r\n        }\r\n\r\n        /* Cash control sessions (agent cash: open/close/validate). Close: only agentId; Validate/Reject: accountant only. */\r\n        match /cashSessions/{sessionId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n            resource.data.get('agentId', '') == request.auth.uid\r\n            || isComptable()\n            || getUserRole() == 'admin_compagnie'\r\n            || getUserRole() == 'admin_platforme'\r\n          );\r\n          allow delete: if false;\r\n        }\r\n\r\n        match /cashSessionExpenses/{expenseId} {\r\n          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n          allow update, delete: if false;\r\n        }\r\n      }\r\n\r\n      /* ============================================================\r\n         Treasury — financialAccounts (Phase 6 hardening)\r\n         - currentBalance must NEVER be set directly; only via\r\n           financialMovements module using increment() in transaction.\r\n         - Firestore cannot distinguish increment from direct set;\r\n           we allow updates that touch only (currentBalance, updatedAt)\r\n           for the movement flow, and only metadata otherwise.\r\n         - Creation: admin_compagnie | company_accountant | agency_manager (chefAgence).\r\n         - Update: only allowed fields; forbid changing accountType, agencyId, companyId.\r\n      ============================================================ */\n      match /financialAccounts/{accountId} {\n        allow get, list: if canAccessSensitiveCompanyFinance(companyId);\n        allow get: if agencyAccountantCashMirrorReadOk(companyId, accountId);\n        allow create: if canAccessSensitiveCompanyFinance(companyId)\n          && request.resource.data.get('companyId', '') == companyId;\n        allow update: if canAccessSensitiveCompanyFinance(companyId) && (\n          request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['accountName', 'isActive', 'description', 'updatedAt'])\n          ||\n          request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['currentBalance', 'updatedAt'])\n        )\n        || agencyAccountantCashMirrorUpdateOk(companyId, accountId);\n        allow delete: if false;\r\n      }\r\n      /* Treasury — immutable ledger: no update/delete. Phase 6: reconciliationStatus update allowed for admin_compagnie | company_accountant only. */\r\n      match /financialMovements/{movementId} {\r\n        allow get, list: if canAccessSensitiveCompanyFinance(companyId);\r\n        allow create: if canAccessSensitiveCompanyFinance(companyId);\r\n        allow update: if canAccessSensitiveCompanyFinance(companyId)\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reconciliationStatus', 'updatedAt']);\r\n        allow delete: if false;\r\n      }\r\n      match /expenses/{expenseId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if isAuth() && (\r\n          getUserRole() == 'admin_platforme' ||\r\n          (userCompanyId() == companyId && (\r\n            getUserRole() == 'admin_compagnie' ||\r\n            ((getUserRole() == 'chefAgence' || isComptable())\n              && request.resource.data.get('agencyId', '') == getUserAgencyId()) ||\r\n            ((getUserRole() == 'company_accountant' || getUserRole() == 'financial_director')\r\n              && (request.resource.data.get('agencyId', '') == '' || request.resource.data.agencyId == null))\r\n          ))\r\n        );\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow delete: if false;\r\n      }\r\n      /* Versements caisse agence → banque : workflow pending_manager → executed | rejected */\r\n      match /treasuryTransferRequests/{requestId} {\r\n        allow get, list: if isAuth() && (\r\n          userCompanyId() == companyId ||\r\n          getUserRole() == 'admin_platforme' ||\r\n          getUserRole() == 'admin_compagnie' ||\r\n          (\r\n            userAgencyBelongsToCompany(companyId) &&\r\n            resource.data.get('agencyId', '') == getUserAgencyId() &&\r\n            (\r\n              isComptable() ||\n              getUserRole() == 'chefAgence' ||\r\n              getUserRole() == 'chefagence' ||\r\n              getUserRole() == 'superviseur'\r\n            )\r\n          )\r\n        );\r\n        allow create: if isAuth() && userCompanyId() == companyId && (\r\n          getUserRole() == 'admin_platforme' ||\r\n          (\r\n            getUserRole() == 'admin_compagnie' &&\r\n            request.resource.data.get('companyId', '') == companyId\r\n          ) ||\r\n          (\r\n            isComptable() &&\n            request.resource.data.get('agencyId', '') == getUserAgencyId() &&\r\n            request.resource.data.get('companyId', '') == companyId\r\n          )\r\n        )\r\n          && request.resource.data.get('status', '') == 'pending_manager'\r\n          && request.resource.data.get('initiatedBy', '') == request.auth.uid\r\n          && request.resource.data.get('amount', 0) is number\r\n          && request.resource.data.get('amount', 0) > 0\r\n          && request.resource.data.get('amount', 0) < 100000000\r\n          && request.resource.data.get('fromAccountId', '').size() > 0\r\n          && request.resource.data.get('toAccountId', '').size() > 0;\r\n        allow update: if isAuth() && userCompanyId() == companyId\r\n          && resource.data.get('status', '') == 'pending_manager'\r\n          && request.auth.uid != resource.data.get('initiatedBy', '')\r\n          && (\r\n            getUserRole() == 'admin_platforme' ||\r\n            getUserRole() == 'admin_compagnie' ||\r\n            (\r\n              resource.data.get('agencyId', '') == getUserAgencyId() &&\r\n              (\r\n                getUserRole() == 'chefAgence' ||\r\n                getUserRole() == 'chefagence' ||\r\n                getUserRole() == 'superviseur'\r\n              )\r\n            )\r\n          )\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n            'status', 'managerDecisionBy', 'managerDecisionAt', 'managerDecisionReason',\r\n            'executedBy', 'executedAt', 'updatedAt'\r\n          ])\r\n          && (\r\n            (request.resource.data.get('status', '') == 'executed'\r\n              && request.resource.data.get('executedBy', '') == request.auth.uid)\r\n            || request.resource.data.get('status', '') == 'rejected'\r\n          );\r\n        allow delete: if false;\r\n      }\r\n      /* Phase B1.5 — Trip costs: create/update by agency_manager (own agency), company_accountant, admin_compagnie. No delete. */\r\n      match /tripCosts/{tripCostId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || getUserRole() == 'admin_compagnie');\r\n        allow create: if canWriteTripCosts(true) && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow update: if canWriteTripCosts(false) && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow delete: if false;\r\n      }\r\n      /* Idempotency sentinels for financialMovements (Phase 6): prevent duplicate movements. Create/get only. */\r\n      match /financialMovementIdempotency/{key} {\r\n        allow get, create: if canAccessSensitiveCompanyFinance(companyId);\r\n        allow update, delete: if false;\r\n      }\r\n\r\n      /* Financial transactions ledger (Phase robuste)\r\n         - financialTransactions: immutable entries (create/read), optional status-only update by finance roles\r\n         - financialTransactionIdempotency: idempotence sentinels for tx writes\r\n         - accounts: ledger balances updated atomically by transaction service\r\n      */\n      match /financialTransactions/{transactionId} {\n        allow get: if courierCashFinancialTxReadOk(companyId);\n        allow get: if canAccessSensitiveCompanyFinance(companyId)\n          || (\n            isAuth()\n            && isComptable()\n            && userAgencyBelongsToCompany(companyId)\n            && resource.data.get('companyId', '') == companyId\n            && resource.data.get('agencyId', '') == getUserAgencyId()\n          )\n          || (\n            isAgencyAccountantDirectForCompany(companyId)\n            && resource.data.get('companyId', '') == companyId\n            && resource.data.get('agencyId', '') == getUserAgencyId()\n          );\n        allow list: if canAccessSensitiveCompanyFinance(companyId)\n          || agencyAccountantCanListCompanyScopedAccounting(companyId);\n        allow create: if courierCashFinancialTxCreateOk(companyId)\n          || canAccessSensitiveCompanyFinance(companyId)\n          || (canWriteAgencyScopedFinance(companyId) && financialTxAgencyStaffPayload(companyId));\n        allow update: if canAccessSensitiveCompanyFinance(companyId)\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'metadata']);\r\n        allow delete: if false;\r\n      }\r\n\r\n      match /financialTransactionIdempotency/{key} {\n        allow get: if isAuth()\n          && userAgencyBelongsToCompany(companyId)\n          && (\n            hasUserRole('agency_accountant')\n            || hasUserRole('comptable')\n            || hasUserRole('Comptable')\n          )\n          && key.matches('remittance_courier_session_.+');\n        allow get: if canAccessSensitiveCompanyFinance(companyId)\n          || canWriteAgencyScopedFinance(companyId)\n          || (isCourierAgent() && userAgencyBelongsToCompany(companyId))\n          || agencyAccountantCanListCompanyScopedAccounting(companyId);\n        allow create: if courierCashFinancialIdempotencyOk(companyId)\n          || canAccessSensitiveCompanyFinance(companyId)\n          || (\n            agencyAccountantCanListCompanyScopedAccounting(companyId)\n            && request.resource.data.keys().hasAll(['transactionId', 'createdAt'])\n            && request.resource.data.get('transactionId', '').size() > 0\n            && request.resource.data.get('createdAt') is timestamp\n          )\n          || (\n            canWriteAgencyScopedFinance(companyId)\n            && request.resource.data.keys().hasAll(['transactionId', 'createdAt'])\n            && request.resource.data.get('transactionId', '').size() > 0\n            && request.resource.data.get('createdAt') is timestamp\n          );\n        allow update, delete: if false;\r\n      }\r\n\r\n      match /accounts/{accountId} {\n        allow get: if isAuth()\n          && userAgencyBelongsToCompany(companyId)\n          && (\n            hasUserRole('agency_accountant')\n            || hasUserRole('comptable')\n            || hasUserRole('Comptable')\n          )\n          && (\n            accountId == 'agency_' + getUserAgencyId() + '_cash'\n            || accountId == 'agency_' + getUserAgencyId() + '_pending_cash'\n          );\n        allow get, list: if canAccessSensitiveCompanyFinance(companyId);\n        allow get: if canAgencyAccountantReadOwnLiquidityAccount(companyId, accountId);\n        allow get: if canAgencyAccountantReadOwnRemittanceLedgerAccount(companyId, accountId);\n        allow get: if isCourierAgent()\n          && userAgencyBelongsToCompany(companyId)\n          && courierCashLedgerAccountIdOk(accountId);\n        allow get: if canReadOwnAgencyCashAccount(companyId, accountId)\n          || canReadOwnAgencyLedgerAccount(companyId)\n          || (\n          resource != null\n          &&\n          canWriteAgencyScopedFinance(companyId)\n          && resource.data.get('companyId', '') == companyId\n          && resource.data.get('agencyId', '') == getUserAgencyId()\n        );\n        allow list: if canReadOwnAgencyLedgerAccount(companyId);\n        allow create: if courierCashLedgerAccountCreateOk(companyId, accountId)\n          || canAccessSensitiveCompanyFinance(companyId)\n          || (\n            agencyAccountantCanPostCashBalance(companyId, accountId, true)\n            && request.resource.data.keys().hasOnly([\n              'id', 'companyId', 'agencyId', 'type', 'label', 'balance', 'currency',\n              'includeInLiquidity', 'lastAccountantValidationShiftId', 'createdAt', 'updatedAt'\n            ])\n            && request.resource.data.get('type', '') == 'cash'\n            && request.resource.data.get('includeInLiquidity', false) == true\n          );\n        allow update: if courierCashLedgerAccountUpdateOk(companyId, accountId)\n        || agencyAccountantRemittanceLedgerAccountUpdateOk(companyId, accountId)\n        || (\n          canAccessSensitiveCompanyFinance(companyId)\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n            'balance', 'updatedAt', 'currency', 'accountType', 'type', 'label',\n            'includeInLiquidity', 'id', 'companyId', 'agencyId', 'createdAt',\n            'lastAccountantValidationShiftId'\n          ])\r\n        ) || (\r\n          agencyAccountantCanPostCashBalance(companyId, accountId, false)\n          && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['balance', 'lastAccountantValidationShiftId', 'updatedAt'])\n        );\n        allow delete: if false;\r\n\r\n        match /ledger/{ledgerId} {\r\n          allow get: if canAccessSensitiveCompanyFinance(companyId)\n            || (\n              isAuth()\n              && isComptable()\n              && userAgencyBelongsToCompany(companyId)\n              && accountId == 'agency_' + getUserAgencyId() + '_cash'\r\n              && ledgerId.matches('session_.+_accountant_validation')\r\n            );\r\n          allow list: if isAuth()\n            && isComptable()\n            && userAgencyBelongsToCompany(companyId)\n            && accountId == 'agency_' + getUserAgencyId() + '_cash';\n          allow create: if isAuth()\r\n            && (\n              (\n                isComptable()\n                && userAgencyBelongsToCompany(companyId)\n                && request.resource.data.get('agencyId', '') == getUserAgencyId()\r\n              )\r\n              || canAccessSensitiveCompanyFinance(companyId)\r\n            )\r\n            && accountId == 'agency_' + request.resource.data.get('agencyId', '') + '_cash'\r\n            && ledgerId == 'session_' + request.resource.data.get('shiftId', '') + '_accountant_validation'\r\n            && request.resource.data.keys().hasOnly([\r\n              'companyId', 'agencyId', 'shiftId', 'type', 'source', 'amount',\r\n              'expectedAmount', 'differenceAmount', 'createdAt', 'createdBy', 'status'\r\n            ])\r\n            && request.resource.data.get('companyId', '') == companyId\r\n            && request.resource.data.get('agencyId', '') != ''\r\n            && request.resource.data.get('type', '') == 'cash_in'\r\n            && request.resource.data.get('source', '') == 'shift_accountant_validation'\r\n            && request.resource.data.get('amount', 0) > 0\r\n            && request.resource.data.get('amount', 0) < 100000000\r\n            && request.resource.data.get('createdBy', '') == request.auth.uid\r\n            && request.resource.data.get('status', '') == 'posted'\r\n            && getAfter(/databases/$(database)/documents/companies/$(companyId)/agences/$(request.resource.data.agencyId)/shifts/$(request.resource.data.shiftId)).data.get('status', '') == 'validated_agency'\r\n            && getAfter(/databases/$(database)/documents/companies/$(companyId)/agences/$(request.resource.data.agencyId)/shifts/$(request.resource.data.shiftId)).data.get('validationAudit', {}).get('receivedCashAmount', 0) == request.resource.data.get('amount', 0)\r\n            && getAfter(/databases/$(database)/documents/companies/$(companyId)/agences/$(request.resource.data.agencyId)/shifts/$(request.resource.data.shiftId)).data.get('validationAudit', {}).get('validatedBy', {}).get('id', '') == request.auth.uid;\r\n          allow update, delete: if false;\r\n        }\r\n      }\r\n\r\n      /*\r\n        Supplier master data.\r\n        Intended architecture mapping:\r\n        - suppliers collection remains explicit\r\n        - supplierInvoices are implemented via payables\r\n        - supplierPayments are implemented via paymentProposals + payable payment execution\r\n      */\r\n      match /suppliers/{supplierId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          isComptable() ||\n          getUserRole() == 'company_accountant' ||\r\n          getUserRole() == 'financial_director' ||\r\n          getUserRole() == 'admin_compagnie'\r\n        );\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Phase C — Payables domain (mapped to supplier invoices). */\r\n      match /payables/{payableId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          isComptable() ||\n          getUserRole() == 'chefAgence' ||\r\n          getUserRole() == 'admin_compagnie' ||\r\n          getUserRole() == 'company_accountant' ||\r\n          getUserRole() == 'financial_director'\r\n        );\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          getUserRole() == 'company_accountant' ||\r\n          getUserRole() == 'financial_director' ||\r\n          getUserRole() == 'admin_compagnie'\r\n        );\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Phase C1.1 — Financial settings. Read: authenticated. Update: admin_compagnie only. */\r\n      match /financialSettings/current {\r\n        allow get: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && getUserRole() == 'admin_compagnie';\r\n        allow delete: if false;\r\n      }\r\n      /* Phase C3 — Vehicle financial history. Client-side aggregation; read/write authenticated. No delete. */\r\n      match /vehicleFinancialHistory/{docId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Fuel logs — transport-first operational finance (not ERP stock). */\r\n      match /fuelLogs/{fuelLogId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && !isResponsableLogistique();\r\n        allow delete: if false;\r\n      }\r\n      /* Phase C1.1/C1.2 — Payment proposals domain (mapped to supplier payment requests). */\r\n      match /paymentProposals/{proposalId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          isComptable() ||\n          getUserRole() == 'company_accountant' ||\r\n          getUserRole() == 'financial_director'\r\n        );\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && getUserRole() == 'admin_compagnie'\r\n          && request.resource.data.diff(resource.data).affectedKeys()\r\n            .hasOnly(['approvalStatus', 'approvedBy', 'approvedAt', 'executedMovementId', 'rejectionReason', 'approvalHistory', 'expiresAt', 'approvedByRole']);\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Company notifications center (expense workflow events). */\r\n      match /notifications/{notificationId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme')\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Erreurs système / incohérences critiques (écriture côté client pour journalisation ; pas de mise à jour). */\r\n      match /systemErrors/{errorId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow update, delete: if false;\r\n      }\r\n\r\n      /* Vue matérialisée trajet → véhicule (mise à jour dans la même transaction que vehicles). */\r\n      match /vehicleLiveState/{liveId} {\r\n        allow get, list: if canReadCompanyData(companyId)\r\n          || (isBoardingOfficer() && userAgencyBelongsToCompany(companyId))\r\n          || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && userAgencyBelongsToCompany(companyId));\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          canModifyFleet() ||\r\n          isResponsableLogistique() ||\r\n          isBoardingOfficer()\r\n        ) && vehicleLiveStateCreateOk();\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          canModifyFleet() ||\r\n          isResponsableLogistique() ||\r\n          isBoardingOfficer()\r\n        ) && vehicleLiveStateWriteOk();\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Vehicles (company-level). Read: company, platform, responsable_logistique. Write: fleet roles only (not responsable_logistique). */\r\n      match /vehicles/{vehicleId} {\r\n        allow get, list: if canReadCompanyData(companyId)\r\n          || (isBoardingOfficer() && userAgencyBelongsToCompany(companyId))\r\n          || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && userAgencyBelongsToCompany(companyId));\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          canModifyFleet() || isResponsableLogistique()\r\n        ) && vehicleStatusVehiculeShapeOk();\r\n        /* Pas d’écriture operationStatus / currentTripId / operationStatus côté client (hors maintenance explicite via champs techniques). */\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          canModifyFleet() ||\r\n          isResponsableLogistique() ||\r\n          (\r\n            (\r\n              getUserRole() == 'chefAgence' ||\r\n              getUserRole() == 'chefagence' ||\r\n              getUserRole() == 'superviseur' ||\r\n              getUserRole() == 'agency_fleet_controller' ||\r\n              getUserRole() == 'escale_agent' ||\r\n              getUserRole() == 'escale_manager' ||\r\n              isBoardingOfficer() ||\r\n              getUserRole() == 'admin_compagnie'\r\n            ) &&\r\n            request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n              'currentAssignmentId',\r\n              'destinationCity',\r\n              'currentCity',\r\n              'updatedAt',\r\n              'defaultDriverName',\r\n              'defaultDriverPhone',\r\n              'defaultConvoyeurName',\r\n              'defaultConvoyeurPhone'\r\n            ])\r\n          )\r\n        ) &&\r\n        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['operationStatus', 'currentTripId']) &&\r\n        vehicleOperationalStatusWriteOk() &&\r\n        vehicleStatusVehiculeShapeOk();\r\n        allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && canModifyFleet();\r\n      }\r\n\r\n      /* Vehicle models catalog (autocomplete). Read for same company/logistics visibility; write for fleet managers only. */\r\n      match /vehicleModels/{modelId} {\r\n        allow get, list: if canReadCompanyData(companyId);\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          canModifyFleet() || isResponsableLogistique()\r\n        );\r\n        allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && canModifyFleet();\r\n      }\r\n\r\n      /* Fleet costs — read for logistics/CEO; write excluded for responsable_logistique. */\r\n      match /fleetCosts/{costId} {\r\n        allow get, list: if canReadCompanyData(companyId);\r\n        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && !isResponsableLogistique();\r\n        allow delete: if false;\r\n      }\r\n\r\n      /* Phase C — Fleet maintenance (Enterprise). */\r\n      match /fleetMaintenance/{maintenanceId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          getUserRole() == 'admin_compagnie' ||\r\n          getUserRole() == 'company_accountant' ||\r\n          getUserRole() == 'financial_director' ||\r\n          (getUserRole() == 'chefAgence' && request.resource.data.get('agencyId', '') == getUserAgencyId())\r\n        );\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          getUserRole() == 'admin_compagnie' ||\r\n          getUserRole() == 'company_accountant' ||\r\n          getUserRole() == 'financial_director' ||\r\n          (getUserRole() == 'chefAgence' && resource.data.get('agencyId', '') == getUserAgencyId())\r\n        );\r\n        allow delete: if false;\r\n      }\r\n\r\n      match /fleetVehicles/{vehicleId} {\r\n        allow get, list: if canReadCompanyData(companyId);\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && canModifyFleet();\r\n        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (\r\n          (canModifyFleet() && (\r\n            resource.data.get('status', '') != 'in_transit' ||\r\n            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'lastMovementAt', 'lastMovementBy', 'currentAgencyId', 'destinationAgencyId'])\r\n          )) ||\r\n          (isBoardingOfficer() && resource.data.get('status', '') == 'assigned' && request.resource.data.get('status', '') == 'in_transit' &&\r\n            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'lastMovementAt', 'lastMovementBy']))\r\n        );\r\n        allow delete: if false;\r\n      }\r\n\r\n      match /fleetMovements/{movementId} {\r\n        allow get, list: if canReadCompanyData(companyId);\r\n        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (canModifyFleet() || isBoardingOfficer());\r\n        allow update, delete: if false;\r\n      }\r\n\r\n      /* Company-level personnel. Authenticated read/write. */\r\n      match /personnel/{personnelId} {\r\n        allow get: if isAuth() && (\r\n          userCompanyId() == companyId\r\n          || getUserRole() == 'admin_platforme'\r\n          || (\r\n            userAgencyBelongsToCompany(companyId)\r\n            && (\r\n              isBoardingOfficer()\r\n              || getUserRole() == 'escale_agent'\r\n              || getUserRole() == 'escale_manager'\r\n            )\r\n          )\r\n        );\r\n        allow list: if request.auth != null && (\r\n          request.auth.token.role == 'admin_platforme' ||\r\n          request.auth.token.companyId != null ||\r\n          request.auth.token.compagnieId != null\r\n        );\r\n        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n      }\r\n\r\n      /* Plan change requests. Authenticated read/write. */\r\n      match /planRequests/{requestId} {\r\n        allow get, list, create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n      }\r\n\r\n      /* Billing requests. Authenticated read/write. */\r\n      match /billingRequests/{requestId} {\r\n        allow get, list, create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n      }\r\n\r\n      /* Audit trail confirm/reject/refund (createPayment → logPaymentAction). */\r\n      match /paymentLogs/{logId} {\r\n        function operatorDigitalCanCreateOnlinePaymentLog() {\r\n          let paymentId = request.resource.data.get('paymentId', '');\r\n          let paymentPath = /databases/$(database)/documents/companies/$(companyId)/payments/$(paymentId);\r\n          return isAuth()\r\n            && hasUserRole('operator_digital')\r\n            && paymentId is string\r\n            && paymentId != ''\r\n            && request.resource.data.get('userId', '') == request.auth.uid\r\n            && request.resource.data.get('action', '') in ['confirm', 'reject']\r\n            && request.resource.data.keys().hasOnly([\r\n              'paymentId',\r\n              'action',\r\n              'userId',\r\n              'timestamp'\r\n            ])\r\n            && exists(paymentPath)\r\n            && get(paymentPath).data.get('companyId', '') == companyId\r\n            && get(paymentPath).data.get('channel', '') == 'online'\r\n            && get(paymentPath).data.get('status', '') in ['validated', 'rejected'];\r\n        }\r\n        function agencyCourierCanCreatePaymentLog() {\r\n          let paymentId = request.resource.data.get('paymentId', '');\r\n          let paymentPath = /databases/$(database)/documents/companies/$(companyId)/payments/$(paymentId);\r\n          return isAuth()\r\n            && isCourierAgent()\r\n            && userAgencyBelongsToCompany(companyId)\r\n            && paymentId is string\r\n            && paymentId != ''\r\n            && request.resource.data.get('userId', '') == request.auth.uid\r\n            && request.resource.data.get('action', '') in ['confirm', 'reject']\r\n            && request.resource.data.keys().hasOnly([\r\n              'paymentId',\r\n              'action',\r\n              'userId',\r\n              'timestamp'\r\n            ])\r\n            && exists(paymentPath)\r\n            && get(paymentPath).data.get('companyId', '') == companyId\r\n            && get(paymentPath).data.get('agencyId', '') == getUserAgencyId()\r\n            && get(paymentPath).data.get('channel', '') == 'courrier'\r\n            && get(paymentPath).data.get('status', '') in ['validated', 'rejected'];\r\n        }\r\n        allow get, list: if isAuth() && (\r\n          userCompanyId() == companyId ||\r\n          getUserRole() == 'admin_platforme' ||\r\n          canWriteAgencyScopedFinance(companyId) ||\r\n          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId))\r\n        );\r\n        allow create: if isAuth() && (\r\n          userCompanyId() == companyId ||\r\n          getUserRole() == 'admin_platforme' ||\r\n          (canWriteAgencyScopedFinance(companyId) && request.resource.data.get('userId', '') == request.auth.uid) ||\r\n          agencyCourierCanCreatePaymentLog() ||\r\n          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId) && request.resource.data.get('userId', '') == request.auth.uid) ||\r\n          operatorDigitalCanCreateOnlinePaymentLog()\r\n        );\r\n        allow update, delete: if false;\r\n      }\r\n\r\n      /**\r\n       * Paiements unifiés (guichet + online) — companies/{companyId}/payments\r\n       * - Lecture / mise à jour : même tenant (userCompanyId) ou admin plateforme.\r\n       * - Création visiteur (avec ou sans auth) : pending + channel online + companyId cohérent\r\n       *   (évite l’échec si l’utilisateur est connecté avec un autre tenant que la compagnie du billet).\r\n       */\r\n      match /payments/{paymentId} {\r\n        /** Visiteur (auth ou anonyme) : création pending+online pour la caisse digitale. */\r\n        function visitorOnlinePendingPaymentCreate() {\r\n          return request.resource.data.get('status', '') == 'pending'\r\n            && request.resource.data.get('channel', '') == 'online'\r\n            && request.resource.data.get('companyId', '') == companyId\r\n            && request.resource.data.get('reservationId', '') == paymentId\r\n            && request.resource.data.get('agencyId', '') != ''\r\n            && request.resource.data.get('amount', 0) > 0\r\n            && request.resource.data.get('amount', 0) < 100000000\r\n            && request.resource.data.get('currency', 'XOF') == 'XOF';\r\n        }\r\n        /* get : staff ; visiteur = doc online dont l’id == reservationId (ou doc absent pour getDoc idempotent). */\r\n        allow get: if resource == null\r\n          || (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))\r\n          || (resource.data.get('companyId', '') == companyId\r\n            && resource.data.get('reservationId', '') == paymentId\r\n            && resource.data.get('channel', '') == 'online');\r\n        allow list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create: if visitorOnlinePendingPaymentCreate()\r\n          || courierCashPaymentCreateOk(companyId)\r\n          || (\r\n            isAuth()\r\n            && (userCompanyId() == companyId || getUserRole() == 'admin_platforme')\r\n            && (\r\n              request.resource.data.get('status', 'pending') != 'validated'\r\n              || canAccessSensitiveCompanyFinance(companyId)\r\n            )\r\n          )\r\n          || (\r\n            canWriteAgencyScopedFinance(companyId)\r\n            && request.resource.data.get('status', 'pending') != 'validated'\r\n          );\r\n        /* setDoc sur doc existant = update : idempotence (double envoi preuve / course). */\r\n        /* Mise à jour staff : même tenant (companyId profil / token) ou rôles siège / opérateur digital rattaché à la compagnie. */\r\n        allow update: if (isAuth() && (\r\n            userCompanyId() == companyId\r\n            || getUserRole() == 'admin_platforme'\r\n            || getUserRole() == 'operator_digital'\r\n          ) && (\r\n            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])\r\n            || request.resource.data.get('status', '') == 'rejected'\r\n            || canAccessSensitiveCompanyFinance(companyId)\r\n            || (\r\n              getUserRole() == 'operator_digital'\r\n              && resource.data.get('companyId', '') == companyId\r\n              && resource.data.get('channel', '') == 'online'\r\n              && resource.data.get('status', '') == 'pending'\r\n              && request.resource.data.get('status', '') == 'validated'\r\n              && request.resource.data.get('validatedBy', '') == request.auth.uid\r\n              && request.resource.data.get('validatedAt', null) == request.time\r\n              && request.resource.data.get('updatedAt', null) == request.time\r\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'validatedAt', 'validatedBy', 'updatedAt'])\r\n            )\r\n          ))\r\n          || canValidateGuichetPayment(companyId)\r\n          || canValidateCourierPayment(companyId)\r\n          || (\r\n            resource.data.get('status', '') == 'pending'\r\n            && resource.data.get('channel', '') == 'online'\r\n            && resource.data.get('companyId', '') == companyId\r\n            && resource.data.get('reservationId', '') == paymentId\r\n            && visitorOnlinePendingPaymentCreate()\r\n            && request.resource.data.get('amount', 0) == resource.data.get('amount', -1)\r\n            && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')\r\n          );\r\n        allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n      }\r\n\r\n      /* Subscription (plan) — required for useCapabilities / menus. CEO and company users must read. */\r\n      match /subscription/{docId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n        allow create, update, delete: if isAuth() && (getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme') && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n      }\r\n\r\n      /**\r\n       * Bibliothèque d’images (métadonnées après upload Cloudinary).\r\n       * Avant : aucune règle explicite → refus par défaut (permission-denied sur listen / addDoc).\r\n       */\r\n      match /imagesBibliotheque/{imageId} {\r\n        allow get, list: if isAuth() && (userCompanyId() == companyId || hasUserRole('admin_platforme'));\r\n        allow create: if isAuth() && (userCompanyId() == companyId || hasUserRole('admin_platforme')) && (\r\n          hasUserRole('admin_compagnie') ||\r\n          hasUserRole('admin_platforme') ||\r\n          hasUserRole('operator_digital') ||\r\n          hasUserRole('company_ceo')\r\n        )\r\n          && request.resource.data.keys().hasAll(['url', 'type', 'createdAt'])\r\n          && request.resource.data.url is string\r\n          && request.resource.data.type is string\r\n          && request.resource.data.get('url', '').size() > 0;\r\n        allow update: if false;\r\n        allow delete: if isAuth() && (userCompanyId() == companyId || hasUserRole('admin_platforme')) && (\r\n          hasUserRole('admin_compagnie') ||\r\n          hasUserRole('admin_platforme') ||\r\n          hasUserRole('company_ceo')\r\n        );\r\n      }\r\n    }\r\n\r\n    /* =====================\r\n       COLLECTION GROUP\r\n       (requis pour getCountFromServer / agrégation sur la landing)\r\n    ===================== */\r\n    match /{path=**}/weeklyTrips/{tripId} {\r\n      allow get, list: if true;\r\n    }\r\n\r\n    match /{path=**}/agences/{agencyId} {\r\n      allow get, list: if true;\r\n    }\r\n\r\n      /* Collection group reservations : lecture pour admin, même compagnie (companyId/compagnieId), ou même agence (guichetier, chefAgence, etc.). */\r\n    match /{path=**}/reservations/{reservationId} {\r\n      allow get: if (\r\n        isAuth() && (\r\n          getUserRole() == 'admin_platforme'\r\n          || resource.data.get('companyId', '') == userCompanyId()\r\n          || resource.data.get('compagnieId', '') == userCompanyId()\r\n          || (getUserAgencyId() != '' && resource.data.get('agencyId', '') == getUserAgencyId())\r\n        )\r\n      )\r\n      || (\r\n        request.auth == null\r\n        && (\r\n          resource.data.get('canal', '') in ['en_ligne', 'online']\r\n          || resource.data.get('paymentChannel', '') in ['en_ligne', 'online']\r\n        )\r\n        && (\r\n          resource.data.get('status', '') in ['en_attente', 'en_attente_paiement']\r\n          || resource.data.get('statut', '') in ['en_attente', 'en_attente_paiement']\r\n          || resource.data.get('payment', {}).get('status', '') == 'pending'\r\n        )\r\n      );\r\n\r\n      allow list: if request.auth != null && (\r\n        request.auth.token.role == 'admin_platforme'\r\n        || request.auth.token.companyId != null\r\n        || request.auth.token.compagnieId != null\r\n        || userCompanyId() != ''\r\n        || hasUserRole('operator_digital')\r\n      );\r\n    }\r\n\r\n    /* Collection group dailyStats (e.g. CompanyFinancesPage). CEO / platform: same-tenant by document companyId. */\r\n    match /{path=**}/dailyStats/{dateId} {\r\n      allow get: if isAuth() && (\r\n        getUserRole() == 'admin_platforme' ||\r\n        resource.data.get('companyId', '') == userCompanyId()\r\n      );\r\n      allow list: if request.auth != null && (\r\n        request.auth.token.role == 'admin_platforme' ||\r\n        request.auth.token.companyId != null ||\r\n        request.auth.token.compagnieId != null\r\n      );\r\n    }\r\n\r\n    /* Suivi colis public : lecture pour tous ; écriture par utilisateurs de la même compagnie (sync depuis l’app). */\r\n    match /publicShipmentTrack/{trackId} {\r\n      allow get, list: if true;\r\n      allow create: if isAuth() && userCompanyId() == request.resource.data.companyId;\r\n      allow update: if isAuth() && userCompanyId() == resource.data.companyId;\r\n      allow delete: if false;\r\n    }\r\n\r\n    /* =====================\r\n       LOGISTICS (Courrier) — company-scoped, same-tenant only.\r\n       responsable_logistique: read-only (visibility, no courier finance management).\r\n    ===================== */\r\n    match /companies/{companyId}/logistics/{path=**} {\r\n      allow read: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId));\r\n      allow write: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && !isResponsableLogistique();\r\n    }\r\n\r\n    /* Courier shipments (courrier) live under: companies/{companyId}/logistics/data/shipments/{shipmentId}\r\n       Firestore queries with filters require the exact sub-path to be covered. */\r\n    match /companies/{companyId}/logistics/data/shipments/{shipmentId} {\n      allow get: if canAgencyAccountantReadOwnShipment(companyId);\n      allow list: if agencyAccountantCanListCompanyScopedAccounting(companyId);\n      allow get, list: if isAuth() && (\n        userCompanyId() == companyId\n        || getUserRole() == 'admin_platforme'\n        || (isComptable() && userAgencyBelongsToCompany(companyId))\n        || (isResponsableLogistique() && userCompanyId() == companyId)\n      );\n    }\n\r\n\r\n    /* =====================\r\n       REVENUE (events) — company-scoped, same-tenant only\r\n    ===================== */\r\n    match /companies/{companyId}/revenue/{path=**} {\r\n      allow read, write: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');\r\n    }\r\n\r\n    /* =====================\r\n       DONNÉES INTERNES\r\n    ===================== */\r\n    match /users/{userId} {\r\n      allow get: if request.auth != null && request.auth.uid == userId;\r\n      allow list: if isAuth();\r\n      allow create: if isAuth() && (\r\n        request.auth.uid == userId\r\n        || request.resource.data.get('role', '') != 'chefAgence'\r\n        || getUserRole() == 'admin_compagnie'\r\n        || getUserRole() == 'admin_platforme'\r\n      );\r\n      allow update: if isAuth() && (\r\n        request.auth.uid == userId\r\n        || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])\r\n        || request.resource.data.get('role', '') != 'chefAgence'\r\n        || getUserRole() == 'admin_compagnie'\r\n        || getUserRole() == 'admin_platforme'\r\n      );\r\n    }\r\n\r\n    /* =====================\r\n       COUNTERS (company-level, e.g. trip instance refs)\r\n       - Auth: same-tenant only.\r\n       - Public: get + create/update with only lastSeq/updatedAt (résa en ligne generateWebReferenceCode).\r\n    ===================== */\r\n    match /companies/{companyId}/counters/byTrip/trips/{tripInstanceId} {\r\n      allow get: if true;\r\n      allow create: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))\r\n        || (request.auth == null\r\n          && request.resource.data.keys().hasOnly(['lastSeq', 'updatedAt'])\r\n          && request.resource.data.get('lastSeq', 0) is int);\r\n      allow update: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))\r\n        || (request.auth == null\r\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeq', 'updatedAt'])\r\n          && request.resource.data.get('lastSeq', 0) is int);\r\n      allow delete: if false;\r\n    }\r\n\r\n    /* =====================\r\n       PLATFORM (landing, settings, leads)\r\n    ===================== */\r\n    match /platform/settings {\r\n      allow get: if true;\r\n      allow create, update, delete: if isAuth() && getUserRole() == 'admin_platforme';\r\n    }\r\n\r\n    match /platformLeads/{leadId} {\r\n      allow create: if true;\r\n      allow get, list: if isAuth() && getUserRole() == 'admin_platforme';\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    /* =====================\r\n       DENY BY DEFAULT — no fallback read/write\r\n       All collections used by the app must be declared above.\r\n    ===================== */\r\n    match /{path=**} {\r\n      allow get, list, create, update, delete: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-06-19T11:04:49.752399Z","metadata":{"services":["cloud.firestore"]}}
