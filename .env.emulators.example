# Copier vers .env.emulators.local pour `npm run dev:emulators`.
# Les valeurs Web Firebase peuvent être factices mais doivent être non vides.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-teliya-local.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-teliya-local
VITE_FIREBASE_STORAGE_BUCKET=demo-teliya-local.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:demo
VITE_USE_EMULATORS=true
VITE_ALLOW_PRODUCTION_FROM_LOCAL=false
VITE_APPCHECK_DEBUG=false
VITE_FIRESTORE_FORCE_LONG_POLLING=false
VITE_APP_VERSION=emulators
