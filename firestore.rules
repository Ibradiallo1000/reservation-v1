        && get(settingsPath).data.get('expenseApprovalThresholds', {}).get('agencyManagerLimit', -1) is number
        && (
          (direct && amount <= get(settingsPath).data.get('expenseApprovalThresholds', {}).get('agencyManagerLimit', -1))
          || (!direct && amount > get(settingsPath).data.get('expenseApprovalThresholds', {}).get('agencyManagerLimit', -1))
        );
