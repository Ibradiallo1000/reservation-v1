      let cashAccountId = 'agency_' + agencyId + '_cash';
      let clearingAccountId = 'agency_' + agencyId + '_expense_clearing';
      let cashPath = /databases/$(database)/documents/companies/$(companyId)/accounts/$(cashAccountId);
      let clearingPath = /databases/$(database)/documents/companies/$(companyId)/accounts/$(clearingAccountId);
      let transactionPath = /databases/$(database)/documents/companies/$(companyId)/financialTransactions/$(transactionId);
      let idempotencyPath = /databases/$(database)/documents/companies/$(companyId)/financialTransactionIdempotency/$(transactionId);
      return request.resource.data.get('status', '') == 'paid'
        && isAgencyAccountantForCompany(companyId)
