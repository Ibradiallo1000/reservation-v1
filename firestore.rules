        && request.resource.data.get('createdAt', null) is timestamp
        && request.resource.data.get('updatedAt', null) == request.time
        && amount is number
        && amount > 0
        && amount < 100000000
        && agencyDirectExpenseThresholdOk(companyId, amount, true)
        && exists(cashPath)
