function accountantValidationShiftAfterOk(companyId, agencyId, shiftId, amount) {
  let shiftAfterData = getAfter(/databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/shifts/$(shiftId)).data;
  return shiftAfterData.get('status', '') == 'validated_agency'
    && shiftAfterData.get('validationAudit', {}).get('receivedCashAmount', 0) == amount
    && shiftAfterData.get('validationAudit', {}).get('validatedBy', {}).get('id', '') == request.auth.uid;
}
function agencyAccountantCanPostCashBalance(companyId, accountId, isCreate) {
  let userAgencyId = getUserAgencyId();
  let shiftId = request.resource.data.get('lastAccountantValidationShiftId', '');
  let previousBalance = isCreate ? 0 : resource.data.get('balance', 0);
  let nextBalance = request.resource.data.get('balance', 0);
  let amount = nextBalance - previousBalance;
  let changed = isCreate
    ? request.resource.data.keys()
    : request.resource.data.diff(resource.data).affectedKeys();

  return isAuth()
    && isComptable()
    && userAgencyBelongsToCompany(companyId)
    && userAgencyId != ''
    && accountId == 'agency_' + userAgencyId + '_cash'
    && request.resource.data.get('companyId', companyId) == companyId
    && request.resource.data.get('agencyId', userAgencyId) == userAgencyId
    && shiftId is string
    && shiftId.size() > 0
    && request.resource.data.get('balance', 0) is number
    && amount > 0
    && amount < 100000000
    && request.resource.data.get('updatedAt', null) == request.time
    && accountantValidationShiftAfterOk(companyId, userAgencyId, shiftId, amount)
    && (
      (
        isCreate
        && changed.hasOnly([
          'id',
          'companyId',
          'agencyId',
          'type',
          'label',
          'balance',
          'currency',
          'includeInLiquidity',
          'lastAccountantValidationShiftId',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.get('type', '') == 'cash'
        && request.resource.data.get('currency', 'XOF') == 'XOF'
        && request.resource.data.get('includeInLiquidity', false) == true
        && request.resource.data.get('createdAt', null) == request.time
      )
      ||
      (
        !isCreate
        && changed.hasOnly([
          'balance',
          'lastAccountantValidationShiftId',
          'updatedAt'
        ])
      )
    );
}
