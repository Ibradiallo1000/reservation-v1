          .hasOnly(['balance', 'updatedAt', 'lastOnlinePaymentTransactionId']);
    }
    function operatorDigitalOnlinePaymentIdempotencyCreateOk(companyId, key) {
      let transactionId = request.resource.data.get('transactionId', '');
      return isOperatorDigitalForCompany(companyId)
        && request.resource.data.keys().hasOnly(['transactionId', 'createdAt'])
        && request.resource.data.get('createdAt', null) == request.time
        && transactionId is string
        && transactionId.size() > 0
        && transactionId.matches('tx_.+')
        && key.matches('payment_received_.+');
    }
    function courierCashLedgerAccountUpdateOk(companyId, accountId) {
      return isCourierAgent()
        && userAgencyBelongsToCompany(companyId)
        && courierCashLedgerAccountIdOk(accountId)
        && request.resource.data.get('id', '') == resource.data.get('id', '')
        && request.resource.data.get('companyId', '') == companyId
        && request.resource.data.get('companyId', '') == resource.data.get('companyId', '')
        && request.resource.data.get('agencyId', null) == resource.data.get('agencyId', null)
        && request.resource.data.get('type', '') == resource.data.get('type', '')
        && request.resource.data.get('currency', 'XOF') == resource.data.get('currency', 'XOF')
        && request.resource.data.get('updatedAt', null) == request.time
        && request.resource.data.get('balance', 0) is number
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'updatedAt']);
    }

    function canWriteTripCosts(isCreate) {
      let role = getUserRole();
      return isAuth() && (
        role == 'admin_compagnie' || role == 'admin_platforme' ||
        role == 'company_accountant' || role == 'financial_director' ||
        (role == 'chefAgence' && (
          (isCreate && request.resource.data.get('agencyId', '') == getUserAgencyId()) ||
          (!isCreate && resource.data.get('agencyId', '') == getUserAgencyId())
        ))
      );
    }
    function canModifyFleet() {
      return isFleetController() || isAgencyManager();
    }
    function canReadFleet() {
      return isFleetController() || isAgencyManager() || isBoardingOfficer() || isResponsableLogistique();
    }
    function vehicleStatusVehiculeShapeOk() {
      let s = request.resource.data.get('statusVehicule', '');
      let agency = request.resource.data.get('currentAgencyId', null);
      return (s == 'disponible' || s == 'affecte' || s == 'en_transit' || s == 'en_maintenance')
        && (s != 'en_transit' || agency == null);
    }
    function vehicleLiveStateCreateOk() {
      return request.resource.data.keys().hasOnly([
        'companyId', 'vehicleId', 'tripInstanceId', 'statutMetier', 'statusVehicule',
        'currentAgencyId', 'destinationAgencyId', 'lastKnownAgencyId', 'isReturnToOrigin', 'updatedAt'
      ]);
    }
    function vehicleLiveStateWriteOk() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'companyId', 'vehicleId', 'tripInstanceId', 'statutMetier', 'statusVehicule',
        'currentAgencyId', 'destinationAgencyId', 'lastKnownAgencyId', 'isReturnToOrigin', 'updatedAt'
      ]);
    }
    /** operationalStatus reserve au garage (changement technique) ou ignore si pas touche. */
    function vehicleOperationalStatusWriteOk() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['operationalStatus'])
        || request.resource.data.diff(resource.data).affectedKeys().hasAny(['technicalStatus']);
    }
    /** Phase 3.5 — verrou embarquement sur tripAssignments (boardingSession uniquement). */
    function tripAssignmentCoreUnchangedForBoarding() {
      return request.resource.data.tripId == resource.data.tripId
        && request.resource.data.date == resource.data.date
        && request.resource.data.heure == resource.data.heure
        && request.resource.data.vehicleId == resource.data.vehicleId
        && request.resource.data.agencyId == resource.data.agencyId
        && request.resource.data.status == resource.data.status;
    }
    /** Embarquement : chef / equipe / escale sur l'agence du creneau ; admins societe ou plateforme (souvent sans agencyId) comme pour liveStatus. */
    function canWriteTripAssignmentBoardingSession(companyId, agencyId) {
      return isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (
        hasUserRole('admin_compagnie')
        || hasUserRole('admin_platforme')
        || (
          getUserAgencyId() == agencyId
          && userAgencyBelongsToCompany(companyId)
        )
      );
    }
    function tripAssignmentBoardingSessionActivateOk() {
      let next = request.resource.data.boardingSession;
      let prev = resource.data.get('boardingSession', {});
      return next.keys().hasAll(['startedBy', 'startedAt', 'status', 'clientInstanceId'])
        && next.startedBy == request.auth.uid
        && next.status == 'active'
        && next.clientInstanceId is string
        && (
          prev.get('status', '') != 'active'
          || (
            prev.get('status', '') == 'active'
            && prev.get('clientInstanceId', '') == next.clientInstanceId
            && prev.get('startedBy', '') == request.auth.uid
          )
        );
    }
    function tripAssignmentBoardingSessionCloseOk() {
      let prev = resource.data.get('boardingSession', {});
      let next = request.resource.data.boardingSession;
      return prev.get('status', '') == 'active'
        && next.status == 'closed'
        && next.clientInstanceId == prev.get('clientInstanceId', '')
        && next.startedBy == prev.get('startedBy', '')
        && next.startedAt == prev.get('startedAt', '')
        && next.keys().hasAll(['startedBy', 'startedAt', 'status', 'clientInstanceId', 'closedAt']);
    }
    /** Phase 4 — liveStatus (supervision embarquement). */
    function canWriteTripAssignmentLiveStatus(companyId, agencyId) {
      return isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (
        hasUserRole('admin_compagnie')
        || hasUserRole('admin_platforme')
        || (getUserAgencyId() == agencyId && userAgencyBelongsToCompany(companyId))
      );
    }
    function tripAssignmentLiveStatusShapeOk() {
      let next = request.resource.data.liveStatus;
      return next.keys().hasAll(['boardedCount', 'expectedCount', 'status'])
        && next.boardedCount is int
        && next.boardedCount >= 0
        && next.expectedCount is int
        && next.expectedCount >= 0
        && (next.status == 'waiting' || next.status == 'boarding' || next.status == 'completed');
    }
    /* Read access for company data: same company, platform admin, or responsable_logistique (same company). */
    function canReadCompanyData(companyId) {
      return isAuth() && (
        userCompanyId() == companyId ||
        getUserRole() == 'admin_platforme' ||
        getUserRole() == 'admin_compagnie' ||
        (isResponsableLogistique() && userCompanyId() == companyId)
      );
    }

    /**
     * Reservation en ligne en attente de preuve (upload preuve / transaction sieges).
     * Flux actuel : statut legacy en_attente OU champ SaaS status en_attente + hold ; alias : en_attente_paiement.
     */
    function reservationAwaitingOnlinePaymentProof() {
      let s = resource.data.get('statut', '');
      let lifecycle = resource.data.get('status', '');
      let statutOk = s == 'en_attente_paiement'
        || s == 'en_attente'
        || (s is string && (
          s.toLowerCase().replace(' ', '_') == 'en_attente_paiement'
          || s.toLowerCase().replace(' ', '_') == 'en_attente'
        ));
      let statusOk = lifecycle == 'en_attente'
        || lifecycle == 'en_attente_paiement'
        || (lifecycle is string && (
          lifecycle.toLowerCase().replace(' ', '_') == 'en_attente'
          || lifecycle.toLowerCase().replace(' ', '_') == 'en_attente_paiement'
        ));
      return statutOk || statusOk;
    }

    /* =====================
       DONNEES PUBLIQUES
    ===================== */
    match /villes/{id} {
      allow get, list: if true;
    }

    match /paymentMethods/{id} {
      // Catalogue public.
      // Note: pour preserver les anciennes regles, on garde get/list publics.
      allow get, list: if true;

      // CRUD : plateforme uniquement.
      allow create, update, delete: if isPlatformAdmin();
    }




    /* Resolution publique des reservations par token uniquement. Doc id = publicToken ; acces par get(id) uniquement (pas de list). */
    match /publicReservations/{docId} {
      function publicReservationSourceExists(companyId, agencyId, reservationId) {
        let reservationPath = /databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/reservations/$(reservationId);
        return exists(reservationPath)
          && get(reservationPath).data.get('companyId', '') == companyId
          && get(reservationPath).data.get('agencyId', '') == agencyId;
      }
      function publicReservationTokenMatchesSource(companyId, agencyId, reservationId, publicToken) {
        let reservationPath = /databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/reservations/$(reservationId);
        return exists(reservationPath)
          && get(reservationPath).data.get('publicToken', '') == publicToken;
      }
      function publicReservationBaseStringsOk() {
        return request.resource.data.get('companyId', '') is string
          && request.resource.data.get('companyId', '').size() > 0
          && request.resource.data.get('agencyId', '') is string
          && request.resource.data.get('agencyId', '').size() > 0
          && request.resource.data.get('slug', '') is string
          && request.resource.data.get('slug', '').size() > 0;
      }
      function publicReservationFullCreateOk() {
        return request.resource.data.keys().hasOnly([
          'reservationId',
          'companyId',
          'agencyId',
          'slug',
          'publicToken',
          'nomClient',
          'telephone',
          'depart',
          'arrivee',
          'date',
          'heure',
          'montant',
          'seatsGo',
          'seatsReturn',
          'tripType',
          'status',
          'canal',
          'referenceCode',
          'companyName',
          'agencyNom',
          'companySlug',
          'trajetId',
          'tripInstanceId',
          'createdAt',
          'updatedAt'
        ])
          && request.resource.data.keys().hasAll([
            'reservationId',
            'companyId',
            'agencyId',
            'slug',
            'publicToken',
            'nomClient',
            'telephone',
            'depart',
            'arrivee',
            'date',
            'heure',
            'montant',
            'seatsGo',
            'status',
            'canal',
            'referenceCode',
            'createdAt',
            'updatedAt'
          ])
          && publicReservationBaseStringsOk()
          && request.resource.data.publicToken == docId
          && request.resource.data.publicToken is string
          && request.resource.data.publicToken.size() >= 4
          && request.resource.data.publicToken.size() <= 64
          && request.resource.data.reservationId is string
          && request.resource.data.reservationId.size() > 0
          && request.resource.data.status in ['en_attente', 'en_attente_paiement']
          && request.resource.data.canal in ['en_ligne', 'online']
          && request.resource.data.montant is number
          && request.resource.data.montant > 0
          && request.resource.data.montant < 100000000
          && request.resource.data.seatsGo is int
          && request.resource.data.seatsGo > 0
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time
          && publicReservationSourceExists(
            request.resource.data.companyId,
            request.resource.data.agencyId,
            request.resource.data.reservationId
          )
          && publicReservationTokenMatchesSource(
            request.resource.data.companyId,
            request.resource.data.agencyId,
            request.resource.data.reservationId,
            docId
          );
      }
      function publicReservationPointerCreateOk() {
        return request.resource.data.keys().hasOnly(['token', 'companyId', 'agencyId', 'slug'])
          && request.resource.data.keys().hasAll(['token', 'companyId', 'agencyId', 'slug'])
          && publicReservationBaseStringsOk()
          && request.resource.data.token is string
          && request.resource.data.token.size() >= 4
          && request.resource.data.token.size() <= 64
          && request.resource.data.token != docId
          && publicReservationSourceExists(
            request.resource.data.companyId,
            request.resource.data.agencyId,
            docId
          )
          && publicReservationTokenMatchesSource(
            request.resource.data.companyId,
            request.resource.data.agencyId,
            docId,
            request.resource.data.token
          );
      }
      function publicReservationProofUpdateOk() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return changed.hasOnly(['status', 'paymentReference', 'updatedAt'])
          && resource.data.get('status', '') in ['en_attente', 'en_attente_paiement']
          && request.resource.data.get('status', '') == 'preuve_recue'
          && request.resource.data.get('paymentReference', '') is string
          && request.resource.data.get('paymentReference', '').size() >= 4
          && request.resource.data.get('paymentReference', '').size() <= 120
          && request.resource.data.get('updatedAt', null) == request.time;
      }
      function publicReservationOperatorConfirmUpdateOk() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return isAuth()
          && (isOperatorDigitalForCompany(resource.data.get('companyId', '')) || isPlatformAdmin())
          && changed.hasOnly(['status', 'statut', 'paymentStatus', 'payment', 'ticketValidatedAt', 'updatedAt'])
          && request.resource.data.get('status', '') == 'confirme'
          && request.resource.data.get('statut', '') == 'confirme'
          && request.resource.data.get('paymentStatus', '') == 'paid'
          && request.resource.data.get('payment', {}).get('status', '') == 'validated'
          && request.resource.data.get('ticketValidatedAt', null) == request.time
          && request.resource.data.get('updatedAt', null) == request.time;
      }
      allow get: if true;
      allow create: if publicReservationFullCreateOk() || publicReservationPointerCreateOk();
      allow update: if publicReservationProofUpdateOk() || publicReservationOperatorConfirmUpdateOk();
      allow list, delete: if false;
    }

    /* Invitations (onboarding, accept link). Anonymous access is limited to direct get of a pending token-as-id invitation. */
    match /invitations/{invitationId} {
      function invitationAdminRole() {
        return hasUserRole('admin_compagnie') || hasUserRole('company_ceo');
      }
      function invitationAgencyManagerRole() {
        return hasUserRole('chefAgence') || hasUserRole('chefagence') || hasUserRole('escale_manager');
      }
      function invitationAllowedKeys() {
        return [
          'email',
          'role',
          'status',
          'token',
          'createdAt',
          'createdBy',
          'companyId',
          'agencyId',
          'fullName',
          'phone'
        ];
      }
      function invitationTokenMatchesId(data) {
        return data.get('token', invitationId) == invitationId;
      }
      function publicInvitationGetOk() {
        return request.auth == null
          && resource.data.get('status', '') == 'pending'
          && invitationTokenMatchesId(resource.data);
      }
      function invitationBelongsToAuthEmail(data) {
        return isAuth()
          && request.auth.token.get('email', '') is string
          && data.get('email', '') is string
          && request.auth.token.get('email', '') == data.get('email', '');
      }
      function canManageInvitationData(data) {
        return isAuth() && (
          isPlatformAdmin()
          || (
            invitationAdminRole()
            && userCompanyId() != ''
            && data.get('companyId', '') == userCompanyId()
          )
          || (
            invitationAgencyManagerRole()
            && userCompanyId() != ''
            && getUserAgencyId() != ''
            && data.get('companyId', '') == userCompanyId()
            && data.get('agencyId', '') == getUserAgencyId()
          )
        );
      }
      function validInvitationCreateData() {
        return request.resource.data.keys().hasOnly(invitationAllowedKeys())
          && request.resource.data.keys().hasAll(['role', 'status', 'token', 'createdAt'])
          && request.resource.data.get('status', '') == 'pending'
          && request.resource.data.get('role', '') is string
          && request.resource.data.get('role', '').size() > 0
          && request.resource.data.get('token', '') is string
          && request.resource.data.get('token', '').size() > 0
          && request.resource.data.get('token', '') == invitationId
          && request.resource.data.get('createdAt', null) == request.time
          && (
            request.resource.data.get('email', null) == null
            || request.resource.data.get('email', '') is string
          )
          && (
            request.resource.data.get('companyId', '') == ''
            || request.resource.data.get('companyId', '') is string
          )
          && (
            request.resource.data.get('agencyId', '') == ''
            || request.resource.data.get('agencyId', '') is string
          );
      }
      function canCreateInvitation() {
        return isAuth()
          && validInvitationCreateData()
          && (
            isPlatformAdmin()
            || (
              invitationAdminRole()
              && userCompanyId() != ''
              && request.resource.data.get('companyId', '') == userCompanyId()
              && request.resource.data.get('role', '') != 'admin_platforme'
            )
            || (
              invitationAgencyManagerRole()
              && userCompanyId() != ''
              && getUserAgencyId() != ''
              && request.resource.data.get('companyId', '') == userCompanyId()
              && request.resource.data.get('agencyId', '') == getUserAgencyId()
              && !(request.resource.data.get('role', '') in ['admin_platforme', 'admin_compagnie', 'company_ceo'])
            )
          );
      }
      function invitationAcceptUpdateOk() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return invitationBelongsToAuthEmail(resource.data)
          && resource.data.get('status', '') == 'pending'
          && request.resource.data.get('status', '') == 'accepted'
          && request.resource.data.get('uid', '') == request.auth.uid
          && request.resource.data.get('acceptedAt', null) == request.time
          && changed.hasOnly(['status', 'acceptedAt', 'uid']);
      }
      function invitationAdminUpdateOk() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return canManageInvitationData(resource.data)
          && request.resource.data.get('email', null) == resource.data.get('email', null)
          && request.resource.data.get('role', '') == resource.data.get('role', '')
          && request.resource.data.get('companyId', '') == resource.data.get('companyId', '')
          && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')
          && request.resource.data.get('token', '') == resource.data.get('token', '')
          && changed.hasOnly(['status', 'acceptedAt', 'uid', 'updatedAt']);
      }

      allow get: if publicInvitationGetOk()
        || invitationBelongsToAuthEmail(resource.data)
        || canManageInvitationData(resource.data);
      allow list: if canManageInvitationData(resource.data);
      allow create: if canCreateInvitation();
      allow update: if invitationAcceptUpdateOk() || invitationAdminUpdateOk();
      allow delete: if canManageInvitationData(resource.data);
    }

    /* Medias (platform assets). Authenticated read; platform admin writes only. */
    match /medias/{mediaId} {
      allow get, list: if isAuth();
      allow create, update, delete: if isPlatformAdmin();
    }

    /* Plans catalog (subscription plans). Public read for plan selection; platform admin writes only. */
    match /plans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if isPlatformAdmin();
    }

    /* Metadata (e.g. plansCatalog document). Public read; platform admin writes only. */
    match /_meta/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isPlatformAdmin();
    }

    /* Admin-controlled system plan pricing. */
    match /adminSettings/plans {
      allow get: if isAuth();
      allow list: if false;
      allow create, update: if isPlatformAdmin() && validSystemPlansSettings();
      allow delete: if false;
    }

    match /subscriptionRequests/{requestId} {
      allow create: if isAuth()
        && request.resource.data.keys().hasOnly([
          'companyId',
          'companyName',
          'currentPlan',
          'requestedPlan',
          'status',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'companyId',
          'companyName',
          'currentPlan',
          'requestedPlan',
          'status',
          'createdAt'
        ])
        && request.resource.data.companyId is string
        && request.resource.data.companyName is string
        && request.resource.data.currentPlan is string
        && request.resource.data.requestedPlan is string
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp
        && (userCompanyId() == request.resource.data.companyId || isPlatformAdmin());
      allow get, list: if isPlatformAdmin();
      allow update: if isPlatformAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['pending', 'approved', 'rejected'];
      allow delete: if isPlatformAdmin();
    }

    match /upgradeRequests/{requestId} {
      allow create: if isAuth()
        && request.resource.data.keys().hasOnly(['companyId', 'fromPlan', 'toPlan', 'createdAt', 'status'])
        && request.resource.data.keys().hasAll(['companyId', 'fromPlan', 'toPlan', 'createdAt', 'status'])
        && request.resource.data.companyId is string
        && request.resource.data.fromPlan is string
        && request.resource.data.toPlan is string
        && request.resource.data.status == 'pending'
        && (userCompanyId() == request.resource.data.companyId || isPlatformAdmin());
      allow get, list, update, delete: if isPlatformAdmin();
    }

    /* =====================
       COMPAGNIES / AGENCES
       Multi-tenant: write restricted to own company; read for vitrine: anyone can read company doc + agences (public page).
       Platform admin (admin_platforme) may write any company. Public vitrine: get/list companies allowed for all (visitor may be logged in as another company).
    ===================== */
    match /companies/{companyId} {
      allow get, list: if true;
      allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
      allow update: if validOperationQuotaIncrementOnly();

      // Payment method configurations per company (used by CompanyPaymentSettingsPage)
      match /paymentConfigs/{configId} {
        allow get, list: if (resource.data.get('active', false) == true)
          && (resource.data.get('isEnabled', false) == true);

        allow create, update, delete: if isAuth()
          && (userCompanyId() == companyId || isPlatformAdmin());
      }







      /* Avis clients (vitrine publique) : lecture publique sans auth pour page compagnie */
      match /avis/{avisId} {
        allow read: if request.auth == null || userCompanyId() == companyId || getUserRole() == 'admin_platforme';
        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
      }

      /* Journal d'activite commercial (CA terrain) : append-only, hors ledger. */
      match /activityLogs/{logId} {
        allow get, list: if isAuth() && (
          userCompanyId() == companyId
          || getUserRole() == 'admin_platforme'
          || (
            userAgencyBelongsToCompany(companyId)
            && resource.data.get('agencyId', '') == getUserAgencyId()
          )
        );
        /* Meme logique que guichetSaleLocks / dailyStats : companyId doc OU agence rattachee a la compagnie (evite 403 si companyId token desynchronise). */
        allow create: if isAuth()
          && request.resource.data.companyId == companyId
          && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || (
              userAgencyBelongsToCompany(companyId)
              && request.resource.data.agencyId == getUserAgencyId()
            )
          )
          && request.resource.data.keys().hasAll(['type', 'source', 'amount', 'seats', 'agencyId', 'companyId', 'createdAt', 'status'])
          && request.resource.data.agencyId is string
          && request.resource.data.status == 'confirmed'
          && request.resource.data.amount is number
          && request.resource.data.seats is number
          && request.resource.data.type in ['ticket', 'online', 'courier']
          && request.resource.data.source in ['guichet', 'online']
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if false;
      }

      /* Routes reseau. Lecture publique pour calcul places (resa en ligne) ; ecriture = compagnie / admin. */
      match /routes/{routeId} {
        allow get, list: if true;
        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId));
        /* Escales (stops) : lecture publique pour quota par segment. */
        match /stops/{stopId} {
          allow get, list: if true;
          allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId));
        }
      }

      /* Company banks (used by agency accounting transfer flow and CEO settings). */
      match /companyBanks/{bankId} {
        allow get, list: if canAccessSensitiveCompanyFinance(companyId);
        allow get, list: if isAuth()
          && isComptable()
          && userCompanyId() == companyId
          && userAgencyBelongsToCompany(companyId)
          && resource.data.get('isActive', false) == true;
        allow create, update: if canAccessSensitiveCompanyFinance(companyId);
        allow delete: if false;
      }

      /* Agregats planification (totalPlannedVehicles, totalTrips) — recalcul cote client apres mutations. */
      match /planningStats/{docId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          getUserRole() == 'admin_compagnie' ||
          getUserRole() == 'chefAgence' ||
          getUserRole() == 'chefagence' ||
          getUserRole() == 'superviseur' ||
          getUserRole() == 'agency_fleet_controller' ||
          getUserRole() == 'responsable_logistique' ||
          getUserRole() == 'admin_platforme'
        );
        allow delete: if false;
      }

      /* Compteurs incrementaux par vehicule (planification) — transactions client create/update/delete. */
      match /planningVehicleTripCount/{vehicleId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          getUserRole() == 'admin_compagnie' ||
          getUserRole() == 'chefAgence' ||
          getUserRole() == 'chefagence' ||
          getUserRole() == 'superviseur' ||
          getUserRole() == 'agency_fleet_controller' ||
          getUserRole() == 'responsable_logistique' ||
          getUserRole() == 'admin_platforme'
        );
      }

      /* Trip instances (daily departures). Read: public. Create: public only when initial state (lazy creation on search). Update: (1) same company or platform for full updates; (2) unauthenticated allowed only to increment reservedSeats + updatedAt (public reservation flow). Status: code uses lowercase 'scheduled'. */
      match /tripInstances/{tripInstanceId} {
        allow get, list: if true;
        allow create: if request.resource.data.get('reservedSeats', 0) == 0
          && (request.resource.data.get('status', '') == 'scheduled' || request.resource.data.get('status', '') == 'SCHEDULED')
          && request.resource.data.get('agencyId', '') != ''
          && request.resource.data.get('date', '') != ''
          && request.resource.data.get('departureTime', '') != ''
          && request.resource.data.get('departureCity', '') != ''
          && request.resource.data.get('arrivalCity', '') != '';
        /* Reservation definitive de sieges : utilisateurs internes authentifies uniquement. */
        allow update: if (
            isAuth()
            && (
              userCompanyId() == companyId
              || userAgencyBelongsToCompany(companyId)
              || getUserRole() == 'admin_platforme'
              || getUserRole() == 'operator_digital'
            )
            && (
              isGuichetier()
              || getUserRole() == 'escale_agent'
              || getUserRole() == 'escale_manager'
              || getUserRole() == 'operator_digital'
              || isBoardingOfficer()
              || getUserRole() == 'admin_compagnie'
              || getUserRole() == 'admin_platforme'
            )
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['reservedSeats', 'remainingSeats', 'passengerCount', 'updatedAt', 'segments'])
            && (
              getUserRole() == 'operator_digital'
              || (
                request.resource.data.get('reservedSeats', 0) >= resource.data.get('reservedSeats', 0)
                && request.resource.data.get('passengerCount', 0) >= resource.data.get('passengerCount', 0)
                && request.resource.data.get('remainingSeats', 999999) <= resource.data.get('remainingSeats', 999999)
              )
            )
          );
        allow delete: if false;
        /* Progression bus par escale (arrivee/depart). Lecture: public. Ecriture: embarquement (depart origine), chef agence, escales, admin. */
        match /progress/{stopOrder} {
          allow get, list: if true;
          allow create, update: if isAuth() && (
              getUserRole() == 'chefAgence' || getUserRole() == 'chefagence'
              || getUserRole() == 'escale_manager' || getUserRole() == 'escale_agent'
              || getUserRole() == 'admin_platforme'
              || isBoardingOfficer()
            ) && (
              userCompanyId() == companyId
              || getUserRole() == 'admin_platforme'
              || escaleUserCanReadCompany(companyId)
              || userAgencyBelongsToCompany(companyId)
            );
          allow delete: if false;
        }
        match /inventory/{docId} {
          allow get, list: if true;
          allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow delete: if false;
        }
      }

      /* Suivi temps reel inter-agences : tripExecutions */
      function userAgencyCity() {
        let userPath = /databases/$(database)/documents/companies/$(companyId)/agences/$(getUserAgencyId());
        let userData = exists(userPath) ? get(userPath).data : null;
        return userData == null
          ? ''
          : (userData.get('city', '') != ''
            ? userData.get('city', '')
            : (userData.get('villeNorm', '') != ''
              ? userData.get('villeNorm', '')
              : userData.get('ville', '')));
      }

      match /tripExecutions/{executionId} {
        /* Lecture : chaque agence ne voit que les destinations qui correspondent a sa ville. */
        allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (
          getUserRole() == 'admin_platforme'
          || getUserRole() == 'admin_compagnie'
          || resource.data.get('destinationCity', '') == userAgencyCity()
        );

        /* Ecriture : uniquement par les roles qui mettent a jour le cycle (embarquement/escale/fleet/logistique). */
        allow create, update: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (
          isBoardingOfficer()
          || isAgencyManager()
          || hasUserRole('escale_manager')
          || hasUserRole('escale_agent')
          || isFleetController()
          || isResponsableLogistique()
          || getUserRole() == 'admin_platforme'
          || getUserRole() == 'admin_compagnie'
        );
        /* Exception ciblee chefEmbarquement: update borne a quelques champs operationnels. */
        allow update: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId))
          && (hasUserRole('chefEmbarquement') || hasUserRole('chefembarquement'))
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status', 'departureTime', 'checkpoints', 'updatedAt'
          ]);

        allow delete: if false;
      }

      /* Caisse (cashTransactions, cashClosures, cashRefunds, cashTransfers). Read/write: same company, platform admin, or escale user whose agency is in this company. */
      match /cashTransactions/{txId} {
        function operatorDigitalCanCreateOnlineCashTransaction() {
          let agencyId = request.resource.data.get('locationId', '');
          let reservationId = request.resource.data.get('reservationId', '');
          let reservationPath = /databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/reservations/$(reservationId);
          return isAuth()
            && isOperatorDigitalForCompany(companyId)
            && request.resource.data.get('sourceType', '') == 'online'
            && request.resource.data.get('createdBy', '') == request.auth.uid
            && request.resource.data.get('status', '') == 'paid'
            && agencyId is string
            && agencyId != ''
            && reservationId is string
            && reservationId != ''
            && request.resource.data.get('amount', 0) > 0
            && exists(reservationPath)
            && get(reservationPath).data.get('status', '') == 'confirme'
            && get(reservationPath).data.get('statut', '') == 'confirme'
            && get(reservationPath).data.get('validatedBy', '') == request.auth.uid
            && request.resource.data.keys().hasOnly([
              'reservationId',
              'sessionId',
              'sourceType',
              'sourceSessionId',
              'tripInstanceId',
              'amount',
              'currency',
              'paymentMethod',
              'locationType',
              'locationId',
              'routeId',
              'createdBy',
              'date',
              'paidAt',
              'status',
              'seats',
              'routeLabel',
              'accountId',
              'createdAt',
              'paidAtAt'
            ]);
        }
        allow get, list: if isAuth() && (
          userCompanyId() == companyId ||
          getUserRole() == 'admin_platforme' ||
          escaleUserCanReadCompany(companyId) ||
          canWriteAgencyScopedFinance(companyId)
        );
        allow create: if operatorDigitalCanCreateOnlineCashTransaction() || (isAuth() && (
          userCompanyId() == companyId ||
          getUserRole() == 'admin_platforme' ||
          escaleUserCanReadCompany(companyId) ||
          canWriteAgencyScopedFinance(companyId) ||
          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId))
        ));
        allow update: if isAuth() && (
          userCompanyId() == companyId ||
          getUserRole() == 'admin_platforme' ||
          escaleUserCanReadCompany(companyId) ||
          canWriteAgencyScopedFinance(companyId) ||
          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId))
        );
        allow delete: if false;
      }

      /* Virtual sessions (online cash): companies/{companyId}/virtualSessions/{sessionId}
         Created/updated idempotently by cashService.ensureVirtualSession(). */
      match /virtualSessions/{sessionId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if isAuth() && (
          userCompanyId() == companyId
          || getUserRole() == 'admin_platforme'
          || (
            isOperatorDigitalForCompany(companyId)
            && sessionId.matches('^virtual_online_.*')
            && request.resource.data.get('companyId', '') == companyId
            && request.resource.data.get('agencyId', '') != ''
            && request.resource.data.get('sourceType', '') == 'online'
            && request.resource.data.keys().hasOnly([
              'companyId',
              'agencyId',
              'paidAt',
              'sourceType',
              'updatedAt'
            ])
          )
        );
        allow update: if isAuth() && (
          userCompanyId() == companyId
          || getUserRole() == 'admin_platforme'
          || (
            isOperatorDigitalForCompany(companyId)
            && sessionId.matches('^virtual_online_.*')
            && resource.data.get('companyId', '') == companyId
            && request.resource.data.get('companyId', '') == companyId
            && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')
            && request.resource.data.get('sourceType', '') == 'online'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'paidAt',
              'updatedAt'
            ])
          )
        );
        allow delete: if false;
      }
      match /cashClosures/{closureId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));
        allow delete: if false;
      }
      match /cashRefunds/{refundId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));
        allow delete: if false;
      }
      match /cashTransfers/{transferId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));
        allow delete: if false;
      }

      match /connections/{connectionId} {
        allow get, list, create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId));
        allow delete: if false;
      }

      match /agences/{agencyId} {
        allow get: if request.auth == null || userCompanyId() == companyId || getUserRole() == 'admin_platforme' || escaleUserCanReadCompany(companyId)
          || (isAuth() && (getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && agencyId == getUserAgencyId());
        allow list: if request.auth == null || (request.auth != null && (
          request.auth.token.role == 'admin_platforme' ||
          request.auth.token.companyId != null ||
          request.auth.token.compagnieId != null
        ));
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow delete: if false;

        match /users/{agencyUserId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow create: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
            request.resource.data.get('role', '') != 'chefAgence'
            || getUserRole() == 'admin_compagnie'
            || getUserRole() == 'admin_platforme'
          )) || (canManageAgencyTeam(agencyId) && request.resource.data.get('role', '') != 'chefAgence');
          allow update: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
            || request.resource.data.get('role', '') != 'chefAgence'
            || getUserRole() == 'admin_compagnie'
            || getUserRole() == 'admin_platforme'
          )) || (canManageAgencyTeam(agencyId) && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
            || request.resource.data.get('role', '') != 'chefAgence'
          ));
          allow delete: if false;
        }

        match /weeklyTrips/{tripId} {
          allow get, list: if request.auth == null || userCompanyId() == companyId || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId)
            || (getUserAgencyId() != '' && agencyId == getUserAgencyId());
          allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
            getUserRole() == 'admin_compagnie' ||
            getUserRole() == 'admin_platforme' ||
            (getUserRole() == 'chefAgence' && getUserAgencyId() == agencyId)
          );
        }

        /* Verrou creneau planification (concurrence) — holderUid = request.auth.uid, TTL cote client. */
        match /planningLocks/{lockId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (
            (getUserAgencyId() == agencyId && (
              getUserRole() == 'chefAgence' ||
              getUserRole() == 'chefagence' ||
              getUserRole() == 'superviseur' ||
              getUserRole() == 'agency_fleet_controller' ||
              getUserRole() == 'admin_compagnie'
            ))
            || getUserRole() == 'admin_compagnie'
            || (isResponsableLogistique() && userCompanyId() == companyId)
          );
          allow create, update: if isAuth() && userCompanyId() == companyId && (
            (
              getUserAgencyId() == agencyId && (
                getUserRole() == 'chefAgence' ||
                getUserRole() == 'chefagence' ||
                getUserRole() == 'superviseur' ||
                getUserRole() == 'admin_compagnie'
              )
            )
            || getUserRole() == 'admin_compagnie'
          )
            && request.resource.data.keys().hasAll(['holderUid', 'acquiredAt'])
            && request.resource.data.holderUid == request.auth.uid;
          allow delete: if isAuth() && userCompanyId() == companyId && (
            (
              getUserAgencyId() == agencyId && (
                getUserRole() == 'chefAgence' ||
                getUserRole() == 'chefagence' ||
                getUserRole() == 'superviseur' ||
                getUserRole() == 'admin_compagnie'
              )
            )
            || getUserRole() == 'admin_compagnie'
          )
            && resource.data.get('holderUid', '') == request.auth.uid;
        }

        /* Index miroir creneau vehicule (atomicite planification). */
        match /tripAssignmentVehicleSlots/{slotId} {
          allow get, list: if isAuth() && userCompanyId() == companyId && (
            (getUserAgencyId() == agencyId && (
              getUserRole() == 'chefAgence' ||
              getUserRole() == 'chefagence' ||
              getUserRole() == 'superviseur' ||
              getUserRole() == 'chefEmbarquement' ||
              getUserRole() == 'chefembarquement' ||
              getUserRole() == 'agency_boarding_officer' ||
              getUserRole() == 'embarquement' ||
              getUserRole() == 'escale_agent' ||
              getUserRole() == 'escale_manager' ||
              getUserRole() == 'agency_fleet_controller'
            ))
            || getUserRole() == 'admin_compagnie'
            || (isResponsableLogistique() && userCompanyId() == companyId)
          );
          allow create, update: if isAuth() && userCompanyId() == companyId && (
            (
              getUserAgencyId() == agencyId && (
                getUserRole() == 'chefAgence' ||
                getUserRole() == 'chefagence' ||
                getUserRole() == 'superviseur' ||
                getUserRole() == 'admin_compagnie' ||
                getUserRole() == 'agency_fleet_controller'
              )
            )
            || getUserRole() == 'admin_compagnie'
            || (isResponsableLogistique() && userCompanyId() == companyId)
          )
            && request.resource.data.keys().hasAll(['assignmentId', 'vehicleId', 'tripId', 'date', 'heure', 'status', 'updatedAt'])
            && request.resource.data.assignmentId is string
            && request.resource.data.vehicleId is string
            && request.resource.data.tripId is string
            && request.resource.data.date is string
            && request.resource.data.heure is string
            && (request.resource.data.status == 'planned' || request.resource.data.status == 'validated');
          allow delete: if isAuth() && userCompanyId() == companyId && (
            (
              getUserAgencyId() == agencyId && (
                getUserRole() == 'chefAgence' ||
                getUserRole() == 'chefagence' ||
                getUserRole() == 'superviseur' ||
                getUserRole() == 'admin_compagnie'
              )
            )
            || getUserRole() == 'admin_compagnie'
            || (isResponsableLogistique() && userCompanyId() == companyId)
          );
        }

        /* Affectations trajet + date + heure → vehicule (planifie par chef/superviseur, valide par logistique). */
        match /tripAssignments/{assignmentId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (
            (getUserAgencyId() == agencyId && (
              getUserRole() == 'chefAgence' ||
              getUserRole() == 'chefagence' ||
              getUserRole() == 'superviseur' ||
              getUserRole() == 'chefEmbarquement' ||
              getUserRole() == 'chefembarquement' ||
              getUserRole() == 'agency_boarding_officer' ||
              getUserRole() == 'embarquement' ||
              getUserRole() == 'escale_agent' ||
              getUserRole() == 'escale_manager' ||
              getUserRole() == 'agency_fleet_controller'
            ))
            || getUserRole() == 'admin_compagnie'
            || (isResponsableLogistique() && userCompanyId() == companyId)
          );
          allow create: if isAuth() && userCompanyId() == companyId && (
            (getUserAgencyId() == agencyId && (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur'))
            || getUserRole() == 'admin_compagnie'
          )
            && request.resource.data.keys().hasAll(['tripId', 'date', 'heure', 'vehicleId', 'agencyId', 'status', 'liveStatus'])
            && request.resource.data.agencyId == agencyId
            && request.resource.data.status == 'planned'
            && request.resource.data.tripId is string
            && request.resource.data.date is string
            && request.resource.data.heure is string
            && request.resource.data.vehicleId is string
            && request.resource.data.liveStatus.keys().hasAll(['boardedCount', 'expectedCount', 'status'])
            && request.resource.data.liveStatus.boardedCount == 0
            && request.resource.data.liveStatus.status == 'waiting'
            && request.resource.data.liveStatus.expectedCount is int
            && request.resource.data.liveStatus.expectedCount >= 0;
          allow update: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && (
            (
              getUserAgencyId() == agencyId &&
              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&
              (resource.data.status == 'cancelled' || resource.data.status == 'rejected') &&
              request.resource.data.status == 'planned' &&
              request.resource.data.agencyId == agencyId &&
              request.resource.data.tripId is string &&
              request.resource.data.date is string &&
              request.resource.data.heure is string &&
              request.resource.data.vehicleId is string &&
              request.resource.data.liveStatus.keys().hasAll(['boardedCount', 'expectedCount', 'status']) &&
              request.resource.data.liveStatus.boardedCount == 0 &&
              request.resource.data.liveStatus.status == 'waiting' &&
              request.resource.data.liveStatus.expectedCount is int &&
              request.resource.data.liveStatus.expectedCount >= 0
            )
            || (
              getUserAgencyId() == agencyId &&
              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&
              resource.data.status == 'planned' &&
              request.resource.data.status == 'planned'
            )
            || (
              getUserAgencyId() == agencyId &&
              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&
              resource.data.status == 'planned' &&
              request.resource.data.status == 'cancelled' &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
            )
            || (
              getUserAgencyId() == agencyId &&
              (getUserRole() == 'chefAgence' || getUserRole() == 'chefagence' || getUserRole() == 'superviseur' || getUserRole() == 'admin_compagnie') &&
              resource.data.status == 'validated' &&
              request.resource.data.status == 'cancelled' &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
            )
            || (
              resource.data.status == 'planned' &&
              request.resource.data.status == 'validated' &&
              (
                (getUserAgencyId() == agencyId && getUserRole() == 'agency_fleet_controller') ||
                getUserRole() == 'admin_compagnie' ||
                (isResponsableLogistique() && userCompanyId() == companyId)
              )
            )
            || (
              canWriteTripAssignmentBoardingSession(companyId, agencyId)
              && tripAssignmentCoreUnchangedForBoarding()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['boardingSession', 'updatedAt'])
              && (
                tripAssignmentBoardingSessionActivateOk()
                || tripAssignmentBoardingSessionCloseOk()
              )
            )
            || (
              canWriteTripAssignmentBoardingSession(companyId, agencyId)
              && tripAssignmentCoreUnchangedForBoarding()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['boardingSession', 'updatedAt'])
              && request.resource.data.boardingSession.status == 'active'
              && request.resource.data.boardingSession.clientInstanceId is string
            )
            || (
              canWriteTripAssignmentBoardingSession(companyId, agencyId)
              && tripAssignmentCoreUnchangedForBoarding()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['boardingSession', 'updatedAt'])
              && request.resource.data.boardingSession.status == 'closed'
              && request.resource.data.boardingSession.clientInstanceId is string
            )
            || (
              canWriteTripAssignmentLiveStatus(companyId, agencyId)
              && tripAssignmentCoreUnchangedForBoarding()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['liveStatus', 'updatedAt'])
              && tripAssignmentLiveStatusShapeOk()
            )
          );
          allow delete: if false;
        }

        match /departures/{tripInstanceId} {
          allow get, list: if isAuth()
            && getUserAgencyId() == agencyId
            && (
              userCompanyId() == companyId
              || userAgencyBelongsToCompany(companyId)
              || getUserRole() == 'admin_platforme'
            );

          allow create: if isAuth()
            && getUserAgencyId() == agencyId
            && (
              userCompanyId() == companyId
              || userAgencyBelongsToCompany(companyId)
              || getUserRole() == 'admin_platforme'
            )
            && request.resource.data.companyId == companyId
            && request.resource.data.agencyId == agencyId
            && request.resource.data.tripInstanceId == tripInstanceId
            && request.resource.data.tripStatus == 'OPEN'
            && request.resource.data.schemaVersion == 1;

          allow update: if isAuth()
            && getUserAgencyId() == agencyId
            && (
              userCompanyId() == companyId
              || userAgencyBelongsToCompany(companyId)
              || getUserRole() == 'admin_platforme'
            )
            && (
              isBoardingOfficer()
              || isAgencyManager()
              || getUserRole() == 'admin_compagnie'
              || getUserRole() == 'admin_platforme'
            )
            && resource.data.get('tripStatus', '') == 'OPEN'
            && request.resource.data.get('tripStatus', '') == 'CLOSED'
            && request.resource.data.get('companyId', '') == companyId
            && request.resource.data.get('agencyId', '') == agencyId
            && request.resource.data.get('tripInstanceId', '') == tripInstanceId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'tripStatus',
              'boardingClosedAt',
              'boardingClosedBy',
              'boardedPassengersCount',
              'absentPassengersCount',
              'pendingPassengersCount',
              'updatedAt'
            ]);

          allow update: if isAuth()
            && getUserAgencyId() == agencyId
            && (
              userCompanyId() == companyId
              || userAgencyBelongsToCompany(companyId)
              || getUserRole() == 'admin_platforme'
            )
            && (
              isBoardingOfficer()
              || isAgencyManager()
              || getUserRole() == 'admin_compagnie'
              || getUserRole() == 'admin_platforme'
            )
            && resource.data.get('tripStatus', '') == 'CLOSED'
            && request.resource.data.get('tripStatus', '') == 'DEPARTED'
            && request.resource.data.get('companyId', '') == companyId
            && request.resource.data.get('agencyId', '') == agencyId
            && request.resource.data.get('tripInstanceId', '') == tripInstanceId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'tripStatus',
              'departureConfirmedAt',
              'departureConfirmedBy',
              'boardedPassengersCount',
              'absentPassengersCount',
              'pendingPassengersCount',
              'updatedAt'
            ]);

          allow delete: if false;
        }

        /* Verrou idempotence vente guichet (cree dans la meme transaction que la reservation). */
        match /guichetSaleLocks/{lockId} {
          allow get: if isAuth() && userAgencyBelongsToCompany(companyId) && getUserAgencyId() == agencyId;
          allow create: if isAuth() && userAgencyBelongsToCompany(companyId) && getUserAgencyId() == agencyId
            && request.resource.data.keys().hasAll(['reservationId', 'sessionId', 'agentId'])
            && request.resource.data.get('reservationId', '').size() > 0
            && request.resource.data.get('sessionId', '').size() > 0
            && request.resource.data.agentId == request.auth.uid
            && (
              isGuichetier()
              || getUserRole() == 'escale_agent'
              || getUserRole() == 'escale_manager'
            );
          allow update, delete: if false;
          allow list: if false;
        }

        match /reservations/{reservationId} {

          /* Creation publique. Lecture reservee aux utilisateurs compagnie ; acces billet public = via publicReservations (doc id = publicToken) uniquement. */
          allow create: if (
            request.auth == null
            || publicOnlineReservationCreate(companyId, agencyId)
            || userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || (
              userAgencyBelongsToCompany(companyId)
              && getUserAgencyId() == request.resource.data.get('agencyId', '')
            )
          )
            && reservationCreatePaymentChannelShapeOk();
          /* get : compagnie / agence rattachee / admin_platforme ; ou public pour resa en_ligne (upload preuve, recu, mon-billet). list : jamais en public. */
          allow get: if (isAuth() && (
              userCompanyId() == companyId
              || getUserRole() == 'admin_platforme'
              || userAgencyBelongsToCompany(companyId)
              || (getUserRole() == 'operator_digital' && userCompanyId() == companyId)
            ))
            || (isAuth()
              && isOperatorDigitalForCompany(companyId)
              && resource.data.get('companyId', '') == companyId
              && resource.data.get('agencyId', '') == agencyId
              && (
                resource.data.get('canal', '') in ['en_ligne', 'online']
                || resource.data.get('paymentChannel', '') in ['en_ligne', 'online']
              ))
            || (
              request.auth == null
              && resource.data.get('companyId', '') == companyId
              && resource.data.get('agencyId', '') == agencyId
              && (
                resource.data.get('canal', '') in ['en_ligne', 'online']
                || resource.data.get('paymentChannel', '') in ['en_ligne', 'online']
              )
              && (
                resource.data.get('status', '') in ['en_attente', 'en_attente_paiement']
                || resource.data.get('statut', '') in ['en_attente', 'en_attente_paiement']
                || resource.data.get('payment', {}).get('status', '') == 'pending'
              )
            );
          allow list: if isAuth() && (
            getUserRole() == 'admin_platforme'
            || userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || (getUserRole() == 'operator_digital' && userCompanyId() == companyId)
            || request.auth.token.companyId == companyId
            || request.auth.token.compagnieId == companyId
          );

          /* =============================
             UPDATE 1 — APRES CREATION
             (publicToken / publicUrl ; updatedAt optionnel pour conformite)
          ============================= */
          allow update: if (
            request.auth == null &&
            resource.data.canal == "en_ligne" &&
            reservationAwaitingOnlinePaymentProof() &&
            (
              request.resource.data.diff(resource.data).changedKeys().hasOnly(["publicToken", "publicUrl"])
              || request.resource.data.diff(resource.data).changedKeys().hasOnly(["publicToken", "publicUrl", "updatedAt"])
            )
          );

          /* =============================
             UPDATE 2 — SOUMISSION PREUVE (public ou utilisateur connecte)
             Passage en_attente_paiement → preuve_recue. UploadPreuvePage.
          ============================= */
          allow update: if (
            publicOnlineProofSubmitOk(companyId, agencyId)
          );
          allow update: if (
            (resource.data.get('canal', '') == '' || (resource.data.get('canal', '') is string && resource.data.get('canal', '').toLowerCase().replace(' ', '_') == "en_ligne")) &&
            reservationAwaitingOnlinePaymentProof() &&
            (request.resource.data.get('statut', '') == "preuve_recue" || (request.resource.data.get('statut', '') is string && request.resource.data.get('statut', '').toLowerCase() == "preuve_recue"))
          );
          allow update: if (
            reservationAwaitingOnlinePaymentProof() &&
            request.resource.data.get('statut', '') == "preuve_recue"
          );
          allow update: if operatorDigitalCanCommitOnlineReservation(companyId, agencyId);
          allow update: if operatorDigitalCanRejectOnlineReservation(companyId, agencyId);
          allow update: if operatorDigitalCanFinalizeOnlineReservation(companyId, agencyId);

          /* Embarquement mobile: autoriser update cible meme si shift valide.
             Necessaire pour scan terrain (boardingStatus/journeyStatus + audit). */
          allow update: if request.auth != null
            && request.auth.uid == "jckg193rHpbysYShk5ZcUDDSSyF3"
            && companyId == "e1zx7bz0Pl1IPVPt2ne4"
            && agencyId == "lYAeJSWBrlybs2k9Rspf"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "boardingStatus",
              "statutEmbarquement",
              "controleurId",
              "checkInTime"
            ]);
          allow update: if canBoardingOfficerOperateReservation(companyId, agencyId);

          /* Phase B — Utilisateurs internes : transition de statut autorisee par role ;
             controleur embarquement : champs restreints.
             operator_digital : peut valider/refuser meme si shiftId est present/valide, mais
             pour les updates non-statut on limite les cles autorisees (cash/paiement). */
          allow update, delete: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          ) && (!isBoardingOfficer() || isBoardingOperationalUpdate()) && (
            (
              getUserRole() == 'operator_digital' ||
              /* Validation finale chef/compta : autoriser le marquage validatedAt/updatedAt
                 meme si le shift est deja VALIDATED (sans changement de statut reservation). */
              (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['statut']) &&
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['validatedAt', 'updatedAt']) &&
                (isAgencyManager() || isComptable() || getUserRole() == 'admin_platforme')
              ) ||
              (resource.data.get('shiftId', '') == '' ||
              !exists(/databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/shifts/$(resource.data.shiftId)) ||
              get(/databases/$(database)/documents/companies/$(companyId)/agences/$(agencyId)/shifts/$(resource.data.shiftId)).data.get('status', '') != 'validated')
            )
            && (
              (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['statut'])
                ? (getUserRole() != 'operator_digital'
                  || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                    'cashTransactionId',
                    'paymentStatus',
                    'paymentMethod',
                    'updatedAt',
                    'payment',
                    'status',
                    'refusedBy',
                    'refusedAt',
                    'refusalReason',
                    'ticketValidatedAt',
                    'auditLog',
                    'validatedBy',
                    'ticketRevenueCountedInDailyStats'
                  ]))
                : true
              )
              && (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['statut'])
                || (validReservationStatutTransition() && (
                  !isBoardingOfficer()
                  || boardingOfficerAllowedKeysOnly()
                ))
              )
            )
          );
        }

        match /shifts/{shiftId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'
            || isComptable()
            || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && agencyId == getUserAgencyId()));
          allow create: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId) || getUserRole() == 'admin_platforme'
            || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && agencyId == getUserAgencyId()))
            && request.resource.data.get('companyId', '') == companyId
            && request.resource.data.get('agencyId', '') == agencyId
            && request.resource.data.get('userId', '').size() > 0
            && request.resource.data.get('status', '') in ['active', 'pending'];
          /* Pause billetterie (active → paused) : uniquement le guichetier titulaire du poste (pas le comptable). */
          allow update: if agencyAccountantShiftValidationUpdateOk(companyId, agencyId)
          || isAuth() && (
            (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId) || getUserRole() == 'admin_platforme') && (
              resource.data.status != 'validated' &&
              (resource.data.status != 'active' || request.resource.data.status != 'paused'
                || (isGuichetier() && resource.data.userId == request.auth.uid && getUserAgencyId() == agencyId)) &&
              (request.resource.data.status != 'closed' || (isGuichetier() && resource.data.userId == request.auth.uid && getUserAgencyId() == agencyId)) &&
              /* CLOSED → validated_agency : comptable d'agence (validateSessionByAccountant) ou chef / admin compagnie */
              (request.resource.data.status != 'validated_agency' || ((isAgencyManager() || isComptable()) && getUserAgencyId() == agencyId)) &&
              (request.resource.data.status != 'validated' || (isAgencyManager() && getUserAgencyId() == agencyId))
            )
            || (isEscaleManager() && agencyId == getUserAgencyId() && resource.data.status == 'pending' && request.resource.data.status == 'active')
          )
          && request.resource.data.get('companyId', '') == companyId
          && request.resource.data.get('agencyId', '') == agencyId;
          allow delete: if false;
        }

match /shiftReports/{reportId} {
  allow get, list: if isAuth() && (
    userCompanyId() == companyId
    || getUserRole() == 'admin_platforme'
    || (
      userAgencyBelongsToCompany(companyId)
      && getUserAgencyId() == agencyId
      && (
        isGuichetier()
        || getUserRole() == 'agentCourrier'
        || isComptable()
        || getUserRole() == 'escale_agent'
        || getUserRole() == 'escale_manager'
      )
    )
  );

  allow create: if isAuth() && (
    userCompanyId() == companyId
    || getUserRole() == 'admin_platforme'
    || (
      userAgencyBelongsToCompany(companyId)
      && getUserAgencyId() == agencyId      && (
        isGuichetier()
        || getUserRole() == 'agentCourrier'
        || isComptable()
        || getUserRole() == 'escale_agent'
        || getUserRole() == 'escale_manager'
      )
    )
  );

  allow update: if isAuth() && (
    (
      userCompanyId() == companyId
      || userAgencyBelongsToCompany(companyId)
      || getUserRole() == 'admin_platforme'
    )
    && (
      resource.data.get('status', '') != 'validated'
      && (
        request.resource.data.get('status', '') != 'validated_agency'
        || ((isAgencyManager() || isComptable()) && getUserAgencyId() == agencyId)
      )
      && (
        request.resource.data.get('status', '') != 'validated'
        || (isAgencyManager() && getUserAgencyId() == agencyId)
      )
    )
  )
  || (isEscaleManager() && agencyId == getUserAgencyId());

  allow delete: if false;
}

        /* Courier sessions (agency-scoped, Ticket-like lifecycle) */
        match /courierSessions/{sessionId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || isComptable());
          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow update: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))
            || courierSessionAccountantValidationOk(companyId, agencyId);
          allow delete: if false;
        }

        match /boardingClosures/{closureId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow create, update: if (isBoardingOfficer() || isAgencyManager()) && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow delete: if false;
        }

        match /boardingLogs/{logId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow create: if (isBoardingOfficer() || isAgencyManager() || isEscaleOperator()) && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow update, delete: if false;
        }

        match /boardingLocks/{lockId} {
          allow get, list, create: if (isBoardingOfficer() || isAgencyManager() || isEscaleOperator()) && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow update, delete: if false;
        }

        /* Phase 4.5 — idempotence compteur live (un doc par affectation + reservation). Creation seule, pas de MAJ. */
        match /boardingEmbarkDedup/{dedupId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          /* Meme perimetre que liveStatus (escale + boarding) et que boardingLogs/boardingLocks (chef / controleur). */
          allow create: if isAuth() && (
              ((isBoardingOfficer() || isAgencyManager()) && (
                userCompanyId() == companyId
                || userAgencyBelongsToCompany(companyId)
                || getUserRole() == 'admin_platforme'
              ))
              || canWriteTripAssignmentLiveStatus(companyId, agencyId)
            )
            && request.resource.data.keys().hasOnly(['reservationId', 'tripAssignmentId', 'scannedAt'])
            && request.resource.data.reservationId is string
            && request.resource.data.tripAssignmentId is string
            && request.resource.data.scannedAt is timestamp;
          allow update, delete: if false;
        }

        /** Journal centralise des actions agents (lecture : supervision ; ecriture : operationnels). */
        match /agentHistory/{eventId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && getUserAgencyId() == agencyId && (
            isComptable() || isAgencyManager()
            || getUserRole() == 'superviseur'
            || getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme'
          );
          allow create: if isAuth() && (userCompanyId() == companyId || userAgencyBelongsToCompany(companyId)) && getUserAgencyId() == agencyId && (
            isGuichetier() || isComptable() || isAgencyManager() || isBoardingOfficer()
            || getUserRole() == 'agentCourrier' || getUserRole() == 'superviseur'
            || getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager'
            || getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme'
          );
          allow update, delete: if false;
        }

        /* Phase 4.5 — Aggregated state (dailyStats, boardingStats, agencyLiveState). responsable_logistique: read-only (no accounting). */
        match /dailyStats/{dateId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow create, update: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          ) && !isResponsableLogistique();
          allow delete: if false;
        }
        match /boardingStats/{tripKey} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow create, update: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          ) && !isResponsableLogistique();
          allow delete: if false;
        }
        match /agencyLiveState/current {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          );
          allow create, update: if isAuth() && (
            userCompanyId() == companyId
            || userAgencyBelongsToCompany(companyId)
            || getUserRole() == 'admin_platforme'
          ) && !isResponsableLogistique();
          allow delete: if false;
        }

        match /affectations/{affectationId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow create, update: if (canModifyFleet() || isAgencyManager() || isResponsableLogistique()) && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow delete: if false;
        }

        /* Phase 3: Courier batches (lots) — agency-scoped. Create + DRAFT updates: any auth. DEPARTED/CLOSED: chefAgence or admin_compagnie only. */
        match /batches/{batchId} {
          allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
            resource.data.get('status', '') == 'DRAFT'
            || (request.resource.data.get('status', '') == 'READY' && resource.data.get('status', '') == 'DRAFT')
            || (request.resource.data.get('status', '') == 'DEPARTED' && isAgencyManager())
            || (request.resource.data.get('status', '') == 'CLOSED' && isAgencyManager())
          );
          allow delete: if false;
        }

        /* Agency cash receipts (guichet encaissements) used by accounting cash dashboard. */
        match /cashReceipts/{receiptId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || canReadOwnAgencyAccountingData(companyId, agencyId)
          );
          allow create: if isAuth() && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || canReadOwnAgencyAccountingData(companyId, agencyId)
          );
          allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow delete: if false;
        }

        /* Ledger-based cash control snapshots (no financial impact). Accountant compares physical cash vs ledger solde. */
        match /cashAudits/{auditId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || canReadOwnAgencyAccountingData(companyId, agencyId)
          );
          allow create: if isAuth() && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || (
              canReadOwnAgencyAccountingData(companyId, agencyId)
              && request.resource.data.get('companyId', '') == companyId
              && request.resource.data.get('agencyId', '') == agencyId
              && request.resource.data.get('validatedBy', {}).get('id', '') == request.auth.uid
            )
          );
          allow update, delete: if false;
        }

        /* Ecritures comptables encaissement (une par validation de session guichet / courrier). */
        match /comptaEncaissements/{entryId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || (
              userAgencyBelongsToCompany(companyId)
              && getUserAgencyId() == agencyId
            )
          );
          allow create: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))
            || comptaEncaissementCreateOk(companyId, agencyId);
          allow update: if false;
          /* Suppression reservee au renvoi courrier chef → comptable (doc courier_* uniquement). */
          allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
            getUserRole() == 'admin_platforme' ||
            isAgencyManager()
          ) && entryId.matches('courier_.+');
        }

        /* Agency cash movements (comptabilite). Authenticated read/write. */
        match /cashMovements/{movementId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || canReadOwnAgencyAccountingData(companyId, agencyId)
          );
          allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow delete: if false;
        }

        /* Agency personnel. Authenticated read/write. */
        match /personnel/{personnelId} {
          allow get, list, create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow delete: if false;
        }

        /* Agency-level counters (e.g. agent courrier codes). Authenticated read/write. */
        match /counters/{counterId} {
          allow get, list, create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow delete: if false;
        }

        /* ✅ CASH SESSIONS — Chef d'agence peut lire et mettre à jour les sessions de caisse */
        match /cashSessions/{sessionId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId 
            || getUserRole() == 'admin_platforme'
            || hasUserRole('chefAgence')
            || hasUserRole('chefagence')
            || hasUserRole('superviseur')
          );
          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
            resource.data.get('agentId', '') == request.auth.uid
            || isComptable()
            || getUserRole() == 'admin_compagnie'
            || getUserRole() == 'admin_platforme'
            || hasUserRole('chefAgence')
            || hasUserRole('chefagence')
            || hasUserRole('superviseur')
          );
          allow delete: if false;
        }

        /* ✅ CASH SESSION EXPENSES — Chef d'agence peut lire les dépenses des sessions caisse */
        match /cashSessionExpenses/{expenseId} {
          allow get, list: if isAuth() && (
            userCompanyId() == companyId 
            || getUserRole() == 'admin_platforme'
            || hasUserRole('chefAgence')
            || hasUserRole('chefagence')
            || hasUserRole('superviseur')
          );
          allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
          allow update, delete: if false;
        }
      }

      /* ============================================================
         Treasury — financialAccounts (Phase 6 hardening)
         - currentBalance must NEVER be set directly; only via
           financialMovements module using increment() in transaction.
         - Firestore cannot distinguish increment from direct set;
           we allow updates that touch only (currentBalance, updatedAt)
           for the movement flow, and only metadata otherwise.
         - Creation: admin_compagnie | company_accountant | agency_manager (chefAgence).
         - Update: only allowed fields; forbid changing accountType, agencyId, companyId.
      ============================================================ */
      match /financialAccounts/{accountId} {
        allow get, list: if canAccessSensitiveCompanyFinance(companyId);
        allow get: if agencyAccountantCashMirrorReadOk(companyId, accountId);
        allow create: if canAccessSensitiveCompanyFinance(companyId)
          && request.resource.data.get('companyId', '') == companyId;
        allow update: if canAccessSensitiveCompanyFinance(companyId) && (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['accountName', 'isActive', 'description', 'updatedAt'])
          ||
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['currentBalance', 'updatedAt'])
        )
        || agencyAccountantCashMirrorUpdateOk(companyId, accountId);
        allow delete: if false;
      }
      /* Treasury — immutable ledger: no update/delete. Phase 6: reconciliationStatus update allowed for admin_compagnie | company_accountant only. */
      match /financialMovements/{movementId} {
        allow get, list: if canAccessSensitiveCompanyFinance(companyId);
        allow create: if canAccessSensitiveCompanyFinance(companyId);
        allow update: if canAccessSensitiveCompanyFinance(companyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reconciliationStatus', 'updatedAt']);
        allow delete: if false;
      }
      match /expenses/{expenseId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if agencyDirectPaidExpenseCreateOk(companyId, expenseId)
          || agencyPendingManagerExpenseCreateOk(companyId, expenseId);
        allow create: if !(
          request.resource.data.get('transactionId', '') == 'expense_' + expenseId
          && request.resource.data.get('idempotencyKey', '') == 'expense_' + expenseId
        )
          && isAuth() && (
          getUserRole() == 'admin_platforme' ||
          (userCompanyId() == companyId && (
            getUserRole() == 'admin_compagnie' ||
            (getUserRole() == 'chefAgence'
              && request.resource.data.get('agencyId', '') == getUserAgencyId()) ||
            (
              isComptable()
              && !isAgencyAccountantForCompany(companyId)
              && request.resource.data.get('agencyId', '') == getUserAgencyId()
            ) ||
            (
              isAgencyAccountantForCompany(companyId)
              && request.resource.data.get('agencyId', '') == getUserAgencyId()
              && request.resource.data.get('status', '') != 'paid'
              && !request.resource.data.keys().hasAny(['transactionId', 'idempotencyKey'])
            ) ||
            ((getUserRole() == 'company_accountant' || getUserRole() == 'financial_director')
              && (request.resource.data.get('agencyId', '') == '' || request.resource.data.agencyId == null))
          ))
        );
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow delete: if false;
      }
      /* Versements caisse agence → banque : workflow pending_manager → executed | rejected */
      /* ============================================================
         TRANSFER REQUESTS — alignment transferRequests / treasuryTransferRequests
         Règle unifiée pour les deux noms de collection.
      ============================================================ */
      /* ✅ Règle pour transferRequests (utilisé par le code) */
      match /transferRequests/{requestId} {
        allow get, list: if isAuth() && (
          userCompanyId() == companyId ||
          getUserRole() == 'admin_platforme' ||
          getUserRole() == 'admin_compagnie' ||
          (
            userAgencyBelongsToCompany(companyId) &&
            resource.data.get('agencyId', '') == getUserAgencyId() &&
            (
              isComptable() ||
              hasUserRole('chefAgence') ||
              hasUserRole('chefagence') ||
              hasUserRole('superviseur')
            )
          )
        );
        allow create: if isAuth() && userCompanyId() == companyId && (
          getUserRole() == 'admin_platforme' ||
          (
            getUserRole() == 'admin_compagnie' &&
            request.resource.data.get('companyId', '') == companyId
          ) ||
          (
            isComptable() &&
            request.resource.data.get('agencyId', '') == getUserAgencyId() &&
            request.resource.data.get('companyId', '') == companyId
          )
        )
          && request.resource.data.get('status', '') == 'pending_manager'
          && request.resource.data.get('initiatedBy', '') == request.auth.uid
          && request.resource.data.get('amount', 0) is number
          && request.resource.data.get('amount', 0) > 0
          && request.resource.data.get('amount', 0) < 100000000
          && request.resource.data.get('fromAccountId', '').size() > 0
          && request.resource.data.get('toAccountId', '').size() > 0;
        allow update: if isAuth() && userCompanyId() == companyId
          && resource.data.get('status', '') == 'pending_manager'
          && request.auth.uid != resource.data.get('initiatedBy', '')
          && (
            getUserRole() == 'admin_platforme' ||
            getUserRole() == 'admin_compagnie' ||
            (
              resource.data.get('agencyId', '') == getUserAgencyId() &&
              (
                hasUserRole('chefAgence') ||
                hasUserRole('chefagence') ||
                hasUserRole('superviseur')
              )
            )
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'managerDecisionBy', 'managerDecisionAt', 'managerDecisionReason',
            'executedBy', 'executedAt', 'updatedAt'
          ])
          && (
            (request.resource.data.get('status', '') == 'executed'
              && request.resource.data.get('executedBy', '') == request.auth.uid)
            || request.resource.data.get('status', '') == 'rejected'
          );
        allow delete: if false;
      }

      /* ✅ Règle pour treasuryTransferRequests (backward compatibility) */
      match /treasuryTransferRequests/{requestId} {
        allow get, list: if isAuth() && (
          userCompanyId() == companyId ||
          getUserRole() == 'admin_platforme' ||
          getUserRole() == 'admin_compagnie' ||
          (
            userAgencyBelongsToCompany(companyId) &&
            resource.data.get('agencyId', '') == getUserAgencyId() &&
            (
              isComptable() ||
              hasUserRole('chefAgence') ||
              hasUserRole('chefagence') ||
              hasUserRole('superviseur')
            )
          )
        );
        allow create: if request.resource.data.get('status', '') == 'executed'
          && request.resource.data.get('idempotencyKey', '') == 'agency_transfer_' + requestId
          && agencyDirectBankTransferRequestCreateOk(companyId, requestId);
        allow update: if isAuth() && userCompanyId() == companyId
          && resource.data.get('status', '') == 'pending_manager'
          && request.auth.uid != resource.data.get('initiatedBy', '')
          && (
            getUserRole() == 'admin_platforme' ||
            getUserRole() == 'admin_compagnie' ||
            (
              resource.data.get('agencyId', '') == getUserAgencyId() &&
              (
                hasUserRole('chefAgence') ||
                hasUserRole('chefagence') ||
                hasUserRole('superviseur')
              )
            )
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'managerDecisionBy', 'managerDecisionAt', 'managerDecisionReason',
            'executedBy', 'executedAt', 'updatedAt'
          ])
          && (
            (request.resource.data.get('status', '') == 'executed'
              && request.resource.data.get('executedBy', '') == request.auth.uid)
            || request.resource.data.get('status', '') == 'rejected'
          );
        allow delete: if false;
      }

      /* Phase B1.5 — Trip costs: create/update by agency_manager (own agency), company_accountant, admin_compagnie. No delete. */
      match /tripCosts/{tripCostId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || getUserRole() == 'admin_compagnie');
        allow create: if canWriteTripCosts(true) && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow update: if canWriteTripCosts(false) && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow delete: if false;
      }
      /* Idempotency sentinels for financialMovements (Phase 6): prevent duplicate movements. Create/get only. */
      match /financialMovementIdempotency/{key} {
        allow get, create: if canAccessSensitiveCompanyFinance(companyId);
        allow update, delete: if false;
      }

      /* Financial transactions ledger (Phase robuste)
         - financialTransactions: immutable entries (create/read), optional status-only update by finance roles
         - financialTransactionIdempotency: idempotence sentinels for tx writes
         - accounts: ledger balances updated atomically by transaction service
      */
      match /financialTransactions/{transactionId} {
        allow get: if courierCashFinancialTxReadOk(companyId);
        allow get: if isAgencyAccountantForCompany(companyId)
          && transactionId.matches('expense_.+');
        allow get: if canAccessSensitiveCompanyFinance(companyId)
          || operatorDigitalCanReadOnlineMobileMoneyTransaction(companyId)
          || (
            isAuth()
            && (
              isComptable()
              || hasUserRole('chefAgence')
              || hasUserRole('chefagence')
              || hasUserRole('superviseur')
            )
            && userAgencyBelongsToCompany(companyId)
            && resource.data.get('companyId', '') == companyId
            && resource.data.get('agencyId', '') == getUserAgencyId()
          )
          || (
            isAgencyAccountantDirectForCompany(companyId)
            && resource.data.get('companyId', '') == companyId
            && resource.data.get('agencyId', '') == getUserAgencyId()
          );
        allow list: if canAccessSensitiveCompanyFinance(companyId)
          || operatorDigitalCanReadOnlineMobileMoneyTransaction(companyId)
          || agencyAccountantCanListCompanyScopedAccounting(companyId);
        allow create: if transactionId.matches('agency_transfer_.+')
          && agencyDirectBankTransferTransactionCreateOk(companyId, transactionId);
        allow create: if request.resource.data.get('type', '') == 'payment_received'
          && operatorDigitalOnlinePaymentTransactionCreateOk(companyId, transactionId);
        allow create: if transactionId.matches('expense_.+')
          && request.resource.data.get('type', '') == 'expense'
          && agencyDirectExpenseTransactionCreateOk(companyId, transactionId);
        allow create: if request.resource.data.get('type', '') != 'payment_received'
          && !transactionId.matches('expense_.+')
          && (
          courierCashFinancialTxCreateOk(companyId)
          || canAccessSensitiveCompanyFinance(companyId)
          || (
            canWriteAgencyScopedFinance(companyId)
            && financialTxAgencyStaffPayload(companyId)
            && (
              request.resource.data.get('type', '') != 'expense'
              || !isAgencyAccountantForCompany(companyId)
            )
          )
          )
          ;
        allow update: if canAccessSensitiveCompanyFinance(companyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'metadata']);
        allow delete: if false;
      }

      match /financialTransactionIdempotency/{key} {
        allow get: if isOperatorDigitalForCompany(companyId)
          && key.matches('payment_received_.+');
        allow get: if key.matches('expense_.+')
          && isAgencyAccountantForCompany(companyId);
        allow get: if isAuth()
          && userAgencyBelongsToCompany(companyId)
          && (
            hasUserRole('agency_accountant')
            || hasUserRole('comptable')
            || hasUserRole('Comptable')
          )
          && key.matches('remittance_courier_session_.+');
        allow get: if canAccessSensitiveCompanyFinance(companyId)
          || canWriteAgencyScopedFinance(companyId)
          || (isCourierAgent() && userAgencyBelongsToCompany(companyId))
          || agencyAccountantCanListCompanyScopedAccounting(companyId)
          || isOperatorDigitalForCompany(companyId);
        allow create: if key.matches('payment_received_.+')
          && operatorDigitalOnlinePaymentIdempotencyCreateOk(companyId, key);
        allow create: if key.matches('agency_transfer_.+')
          && agencyDirectBankTransferIdempotencyCreateOk(companyId, key);
        allow create: if key.matches('expense_.+')
          && agencyDirectExpenseIdempotencyCreateOk(companyId, key);
        allow create: if !key.matches('payment_received_.+')
          && !key.matches('expense_.+')
          && (
          courierCashFinancialIdempotencyOk(companyId)
          || canAccessSensitiveCompanyFinance(companyId)
          || (
            agencyAccountantCanListCompanyScopedAccounting(companyId)
            && request.resource.data.keys().hasAll(['transactionId', 'createdAt'])
            && request.resource.data.get('transactionId', '').size() > 0
            && request.resource.data.get('createdAt') is timestamp
          )
          || (
            canWriteAgencyScopedFinance(companyId)
            && request.resource.data.keys().hasAll(['transactionId', 'createdAt'])
            && request.resource.data.get('transactionId', '').size() > 0
            && request.resource.data.get('createdAt') is timestamp
          )
          )
          ;
        allow update, delete: if false;
      }

/* ============================================================
   ACCOUNTS — Comptes caisse agence (solde réel)
   Chef d'agence peut lire son compte caisse (solde)
   Comptable peut lire et écrire son compte caisse
============================================================ */
match /accounts/{accountId} {
  allow get: if accountId in ['company_clearing', 'company_mobile_money']
    && isOperatorDigitalForCompany(companyId);

  // Le versement direct doit pouvoir constater l'absence du compte banque
  // avant de le créer atomiquement. Lecture unitaire uniquement.
  allow get: if accountId.matches('company_bank_.+')
    && isAgencyAccountantForCompany(companyId);

  allow get: if accountId == 'agency_' + getUserAgencyId() + '_cash'
    && isAuth()
    && userAgencyBelongsToCompany(companyId)
    && (
      hasUserRole('chefAgence')
      || hasUserRole('chefagence')
      || hasUserRole('chef_agence')
    );

  // ✅ Lecture GET pour le Chef d'Agence
  allow get: if (
      accountId == 'agency_' + getUserAgencyId() + '_cash'
      || accountId == 'agency_' + getUserAgencyId() + '_pending_cash'
      || accountId == 'agency_' + getUserAgencyId() + '_expense_clearing'
    )
    && isAuth()
    && userAgencyBelongsToCompany(companyId)
    && (
      hasUserRole('agency_accountant')
      || hasUserRole('comptable')
      || hasUserRole('Comptable')
      || hasUserRole('chefAgence')
      || hasUserRole('chefagence')
      || hasUserRole('superviseur')
    );

  // ✅ Lecture LIST pour le Chef d'Agence (quand il fait getDocs)
  allow list: if isAuth()
    && userAgencyBelongsToCompany(companyId)
    && (
      hasUserRole('agency_accountant')
      || hasUserRole('comptable')
      || hasUserRole('Comptable')
      || hasUserRole('chefAgence')
      || hasUserRole('chefagence')
      || hasUserRole('superviseur')
    )
    && accountId.matches('agency_' + getUserAgencyId() + '_(cash|pending_cash)');

  // Lecture pour les rôles financiers sensibles
  allow get, list: if canAccessSensitiveCompanyFinance(companyId);
  allow get: if accountId == 'agency_' + getUserAgencyId() + '_mobile_money'
    && canAgencyAccountantReadOwnLiquidityAccount(companyId, accountId);
  allow get: if accountId.matches('company_bank_.+')
    && isAgencyAccountantForCompany(companyId)
    && resource.data.get('companyId', '') == companyId
    && resource.data.get('type', '') == 'bank'
    && (resource.data.get('agencyId', '') == '' || resource.data.agencyId == null)
    && resource.data.get('includeInLiquidity', true) == true;
  allow get: if courierCashLedgerAccountIdOk(accountId)
    && isCourierAgent()
    && userAgencyBelongsToCompany(companyId)
    ;
  allow get: if !accountId.matches('agency_.+_(cash|pending_cash|expense_clearing)')
    && (
      canReadOwnAgencyLedgerAccount(companyId)
    || (
      resource != null
      && canWriteAgencyScopedFinance(companyId)
      && resource.data.get('companyId', '') == companyId
      && resource.data.get('agencyId', '') == getUserAgencyId()
    )
  );
  allow list: if canReadOwnAgencyLedgerAccount(companyId);
  allow create: if (
      accountId == 'company_clearing'
      || accountId == 'company_mobile_money'
    )
    && request.resource.data.get('lastOnlinePaymentTransactionId', '') != ''
    && operatorDigitalOnlinePaymentAccountCreateOk(companyId, accountId);
  allow create: if accountId.matches('agency_.+_expense_clearing')
    && request.resource.data.get('lastDirectExpenseId', '') != ''
    && agencyExpenseClearingWriteOk(companyId, accountId, true);
  allow create: if !(
      accountId == 'company_clearing'
      || accountId == 'company_mobile_money'
    )
    && request.resource.data.get('lastDirectExpenseId', '') == ''
    && ((
      accountId.matches('company_bank_.+')
      && request.resource.data.get('lastDirectTransferId', '') != ''
      && agencyDirectBankTransferAccountCreateOk(companyId, accountId)
    )
    || (
      courierCashLedgerAccountIdOk(accountId)
      && courierCashLedgerAccountCreateOk(companyId, accountId)
    )
    || (
      accountId.matches('agency_.+_pending_cash')
      && agencyAccountantPendingCashAccountCreateOk(companyId, accountId)
    )
    || canAccessSensitiveCompanyFinance(companyId)
    || (
      accountId.matches('agency_.+_cash')
      &&
      agencyAccountantCanPostCashBalance(companyId, accountId, true)
      && request.resource.data.keys().hasOnly([
        'id', 'companyId', 'agencyId', 'type', 'label', 'balance', 'currency',
        'includeInLiquidity', 'lastAccountantValidationShiftId', 'createdAt', 'updatedAt'
      ])
      && request.resource.data.get('type', '') == 'cash'
      && request.resource.data.get('includeInLiquidity', false) == true
    ));

  allow update: if accountId.matches('agency_.+_pending_cash')
    && agencyAccountantPendingCashLegacyDecreaseOk(companyId, accountId);
  allow update: if accountId.matches('agency_.+_cash')
    && request.resource.data.get('lastAccountantValidationShiftId', '') != ''
    && agencyAccountantCanPostCashBalance(companyId, accountId, false)
    && request.resource.data.diff(resource.data).affectedKeys()
      .hasOnly(['balance', 'lastAccountantValidationShiftId', 'updatedAt']);

  allow update: if (
      accountId == 'company_clearing'
      || accountId == 'company_mobile_money'
    )
    && request.resource.data.get('lastOnlinePaymentTransactionId', '') != ''
    && operatorDigitalOnlinePaymentAccountUpdateOk(companyId, accountId);

  allow update: if accountId.matches('agency_.+_cash')
    && request.resource.data.get('lastDirectExpenseId', '') != ''
    && agencyDirectCashExpenseUpdateOk(companyId, accountId);
  allow update: if accountId.matches('agency_.+_expense_clearing')
    && request.resource.data.get('lastDirectExpenseId', '') != ''
    && agencyExpenseClearingWriteOk(companyId, accountId, false);

  allow update: if !(
      accountId == 'company_clearing'
      || accountId == 'company_mobile_money'
    )
    && request.resource.data.get('lastDirectExpenseId', '') == ''
    && ((
    request.resource.data.get('lastDirectTransferId', '') != ''
    && (
      accountId == 'agency_' + getUserAgencyId() + '_cash'
      || accountId.matches('company_bank_.+')
    )
    && agencyDirectBankTransferAccountUpdateOk(
      companyId,
      accountId,
      accountId == 'agency_' + getUserAgencyId() + '_cash'
    )
  )
  || accountId == 'agency_' + getUserAgencyId() + '_pending_cash'
    && isAuth()
    && (
      hasUserRole('agency_accountant')
      || hasUserRole('comptable')
      || hasUserRole('Comptable')
    )
    && userAgencyBelongsToCompany(companyId)
    && resource.data.get('companyId', '') == companyId
    && resource.data.get('agencyId', '') == getUserAgencyId()
    && resource.data.get('type', '') == 'virtual_clearing'
    && request.resource.data.get('companyId', '') == companyId
    && request.resource.data.get('agencyId', '') == getUserAgencyId()
    && request.resource.data.get('type', '') == 'virtual_clearing'
    && request.resource.data.get('currency', 'XOF') == resource.data.get('currency', 'XOF')
    && request.resource.data.get('updatedAt', null) == request.time
    && request.resource.data.get('balance', 0) is number
    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'updatedAt'])
  || (
    (
      accountId == 'company_clearing'
      || accountId == 'company_mobile_money'
    )
    && request.resource.data.get('lastOnlinePaymentTransactionId', '') != ''
    && operatorDigitalOnlinePaymentAccountUpdateOk(companyId, accountId)
  )
  || (
      courierCashLedgerAccountIdOk(accountId)
      && courierCashLedgerAccountUpdateOk(companyId, accountId)
    )
    || (
      (
        (
          accountId.matches('agency_.+_cash')
          && request.resource.data.get('lastAccountantValidationShiftId', '') == ''
        )
        || (
          accountId.matches('agency_.+_pending_cash')
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['balance', 'updatedAt'])
        )
      )
      && agencyAccountantRemittanceLedgerAccountUpdateOk(companyId, accountId)
    )
    || (
      canAccessSensitiveCompanyFinance(companyId)
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'balance', 'updatedAt', 'currency', 'accountType', 'type', 'label',
        'includeInLiquidity', 'id', 'companyId', 'agencyId', 'createdAt',
        'lastAccountantValidationShiftId'
      ])
    ));
  allow delete: if false;

  match /ledger/{ledgerId} {
    allow get: if canAccessSensitiveCompanyFinance(companyId)
      || (
        isAuth()
        && isComptable()
        && userAgencyBelongsToCompany(companyId)
        && accountId == 'agency_' + getUserAgencyId() + '_cash'
        && ledgerId.matches('session_.+_accountant_validation')
      );
    allow list: if isAuth()
      && isComptable()
      && userAgencyBelongsToCompany(companyId)
      && accountId == 'agency_' + getUserAgencyId() + '_cash';
    allow create: if isAuth()
      && (
        (
          isComptable()
          && userAgencyBelongsToCompany(companyId)
          && request.resource.data.get('agencyId', '') == getUserAgencyId()
        )
        || canAccessSensitiveCompanyFinance(companyId)
      )
      && accountId == 'agency_' + request.resource.data.get('agencyId', '') + '_cash'
      && ledgerId == 'session_' + request.resource.data.get('shiftId', '') + '_accountant_validation'
      && request.resource.data.keys().hasOnly([
        'companyId', 'agencyId', 'shiftId', 'type', 'source', 'amount',
        'expectedAmount', 'differenceAmount', 'createdAt', 'createdBy', 'status'
      ])
      && request.resource.data.get('companyId', '') == companyId
      && request.resource.data.get('agencyId', '') != ''
      && request.resource.data.get('type', '') == 'cash_in'
      && request.resource.data.get('source', '') == 'shift_accountant_validation'
      && request.resource.data.get('amount', 0) > 0
      && request.resource.data.get('amount', 0) < 100000000
      && request.resource.data.get('createdBy', '') == request.auth.uid
      && request.resource.data.get('status', '') == 'posted'
      && accountantValidationShiftAfterOk(
        companyId,
        request.resource.data.get('agencyId', ''),
        request.resource.data.get('shiftId', ''),
        request.resource.data.get('amount', 0)
      );
    allow update, delete: if false;
  }
}

      /*
        Supplier master data.
        Intended architecture mapping:
        - suppliers collection remains explicit
        - supplierInvoices are implemented via payables
        - supplierPayments are implemented via paymentProposals + payable payment execution
      */
      match /suppliers/{supplierId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          isComptable() ||
          getUserRole() == 'company_accountant' ||
          getUserRole() == 'financial_director' ||
          getUserRole() == 'admin_compagnie'
        );
        allow delete: if false;
      }

      /* Phase C — Payables domain (mapped to supplier invoices). */
      match /payables/{payableId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          isComptable() ||
          getUserRole() == 'chefAgence' ||
          getUserRole() == 'admin_compagnie' ||
          getUserRole() == 'company_accountant' ||
          getUserRole() == 'financial_director'
        );
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          getUserRole() == 'company_accountant' ||
          getUserRole() == 'financial_director' ||
          getUserRole() == 'admin_compagnie'
        );
        allow delete: if false;
      }

      /* Phase C1.1 — Financial settings. Read: authenticated. Update: admin_compagnie only. */
      match /financialSettings/current {
        allow get: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && getUserRole() == 'admin_compagnie';
        allow delete: if false;
      }
      /* Phase C3 — Vehicle financial history. Client-side aggregation; read/write authenticated. No delete. */
      match /vehicleFinancialHistory/{docId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow delete: if false;
      }

      /* Fuel logs — transport-first operational finance (not ERP stock). */
      match /fuelLogs/{fuelLogId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && !isResponsableLogistique();
        allow delete: if false;
      }
      /* Phase C1.1/C1.2 — Payment proposals domain (mapped to supplier payment requests). */
      match /paymentProposals/{proposalId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          isComptable() ||
          getUserRole() == 'company_accountant' ||
          getUserRole() == 'financial_director'
        );
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && getUserRole() == 'admin_compagnie'
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['approvalStatus', 'approvedBy', 'approvedAt', 'executedMovementId', 'rejectionReason', 'approvalHistory', 'expiresAt', 'approvedByRole']);
        allow delete: if false;
      }

      /* Company notifications center (expense workflow events). */
      match /notifications/{notificationId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme')
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
        allow delete: if false;
      }

      /* Erreurs systeme / incoherences critiques (ecriture cote client pour journalisation ; pas de mise a jour). */
      match /systemErrors/{errorId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow update, delete: if false;
      }

      /* Vue materialisee trajet → vehicule (mise a jour dans la meme transaction que vehicles). */
      match /vehicleLiveState/{liveId} {
        allow get, list: if canReadCompanyData(companyId)
          || (isBoardingOfficer() && userAgencyBelongsToCompany(companyId))
          || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && userAgencyBelongsToCompany(companyId));
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          canModifyFleet() ||
          isResponsableLogistique() ||
          isBoardingOfficer()
        ) && vehicleLiveStateCreateOk();
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          canModifyFleet() ||
          isResponsableLogistique() ||
          isBoardingOfficer()
        ) && vehicleLiveStateWriteOk();
        allow delete: if false;
      }

      /* Vehicles (company-level). Read: company, platform, responsable_logistique. Write: fleet roles only (not responsable_logistique). */
      match /vehicles/{vehicleId} {
        allow get, list: if canReadCompanyData(companyId)
          || (isBoardingOfficer() && userAgencyBelongsToCompany(companyId))
          || ((getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager') && userAgencyBelongsToCompany(companyId));
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          canModifyFleet() || isResponsableLogistique()
        ) && vehicleStatusVehiculeShapeOk();
        /* Pas d'ecriture operationStatus / currentTripId / operationStatus cote client (hors maintenance explicite via champs techniques). */
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          canModifyFleet() ||
          isResponsableLogistique() ||
          (
            (
              getUserRole() == 'chefAgence' ||
              getUserRole() == 'chefagence' ||
              getUserRole() == 'superviseur' ||
              getUserRole() == 'agency_fleet_controller' ||
              getUserRole() == 'escale_agent' ||
              getUserRole() == 'escale_manager' ||
              isBoardingOfficer() ||
              getUserRole() == 'admin_compagnie'
            ) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'currentAssignmentId',
              'destinationCity',
              'currentCity',
              'updatedAt',
              'defaultDriverName',
              'defaultDriverPhone',
              'defaultConvoyeurName',
              'defaultConvoyeurPhone'
            ])
          )
        ) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['operationStatus', 'currentTripId']) &&
        vehicleOperationalStatusWriteOk() &&
        vehicleStatusVehiculeShapeOk();
        allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && canModifyFleet();
      }

      /* Vehicle models catalog (autocomplete). Read for same company/logistics visibility; write for fleet managers only. */
      match /vehicleModels/{modelId} {
        allow get, list: if canReadCompanyData(companyId);
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          canModifyFleet() || isResponsableLogistique()
        );
        allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && canModifyFleet();
      }

      /* Fleet costs — read for logistics/CEO; write excluded for responsable_logistique. */
      match /fleetCosts/{costId} {
        allow get, list: if canReadCompanyData(companyId);
        allow create, update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && !isResponsableLogistique();
        allow delete: if false;
      }

      /* Phase C — Fleet maintenance (Enterprise). */
      match /fleetMaintenance/{maintenanceId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          getUserRole() == 'admin_compagnie' ||
          getUserRole() == 'company_accountant' ||
          getUserRole() == 'financial_director' ||
          (getUserRole() == 'chefAgence' && request.resource.data.get('agencyId', '') == getUserAgencyId())
        );
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          getUserRole() == 'admin_compagnie' ||
          getUserRole() == 'company_accountant' ||
          getUserRole() == 'financial_director' ||
          (getUserRole() == 'chefAgence' && resource.data.get('agencyId', '') == getUserAgencyId())
        );
        allow delete: if false;
      }

      match /fleetVehicles/{vehicleId} {
        allow get, list: if canReadCompanyData(companyId);
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && canModifyFleet();
        allow update: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (
          (canModifyFleet() && (
            resource.data.get('status', '') != 'in_transit' ||
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'lastMovementAt', 'lastMovementBy', 'currentAgencyId', 'destinationAgencyId'])
          )) ||
          (isBoardingOfficer() && resource.data.get('status', '') == 'assigned' && request.resource.data.get('status', '') == 'in_transit' &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'lastMovementAt', 'lastMovementBy']))
        );
        allow delete: if false;
      }

      match /fleetMovements/{movementId} {
        allow get, list: if canReadCompanyData(companyId);
        allow create: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && (canModifyFleet() || isBoardingOfficer());
        allow update, delete: if false;
      }

      /* Company-level personnel. Authenticated read/write. */
      match /personnel/{personnelId} {
        allow get: if isAuth() && (
          userCompanyId() == companyId
          || getUserRole() == 'admin_platforme'
          || (
            userAgencyBelongsToCompany(companyId)
            && (
              isBoardingOfficer()
              || getUserRole() == 'escale_agent'
              || getUserRole() == 'escale_manager'
            )
          )
        );
        allow list: if request.auth != null && (
          request.auth.token.role == 'admin_platforme' ||
          request.auth.token.companyId != null ||
          request.auth.token.compagnieId != null
        );
        allow create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
      }

      /* Plan change requests. Authenticated read/write. */
      match /planRequests/{requestId} {
        allow get, list, create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
      }

      /* Billing requests. Authenticated read/write. */
      match /billingRequests/{requestId} {
        allow get, list, create, update, delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
      }

      /* Audit trail confirm/reject/refund (createPayment → logPaymentAction). */
      match /paymentLogs/{logId} {
        function operatorDigitalCanCreateOnlinePaymentLog() {
          let paymentId = request.resource.data.get('paymentId', '');
          let paymentPath = /databases/$(database)/documents/companies/$(companyId)/payments/$(paymentId);
          return isAuth()
            && isOperatorDigitalForCompany(companyId)
            && paymentId is string
            && paymentId != ''
            && request.resource.data.get('userId', '') == request.auth.uid
            && request.resource.data.get('action', '') in ['confirm', 'reject']
            && request.resource.data.keys().hasOnly([
              'paymentId',
              'action',
              'userId',
              'timestamp'
            ])
            && exists(paymentPath)
            && get(paymentPath).data.get('companyId', '') == companyId
            && get(paymentPath).data.get('channel', '') == 'online'
            && get(paymentPath).data.get('status', '') in ['validated', 'rejected'];
        }
        function agencyCourierCanCreatePaymentLog() {
          let paymentId = request.resource.data.get('paymentId', '');
          let paymentPath = /databases/$(database)/documents/companies/$(companyId)/payments/$(paymentId);
          return isAuth()
            && isCourierAgent()
            && userAgencyBelongsToCompany(companyId)
            && paymentId is string
            && paymentId != ''
            && request.resource.data.get('userId', '') == request.auth.uid
            && request.resource.data.get('action', '') in ['confirm', 'reject']
            && request.resource.data.keys().hasOnly([
              'paymentId',
              'action',
              'userId',
              'timestamp'
            ])
            && exists(paymentPath)
            && get(paymentPath).data.get('companyId', '') == companyId
            && get(paymentPath).data.get('agencyId', '') == getUserAgencyId()
            && get(paymentPath).data.get('channel', '') == 'courrier'
            && get(paymentPath).data.get('status', '') in ['validated', 'rejected'];
        }
        allow get, list: if isAuth() && (
          userCompanyId() == companyId ||
          getUserRole() == 'admin_platforme' ||
          canWriteAgencyScopedFinance(companyId) ||
          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId))
        );
        allow create: if isAuth() && (
          userCompanyId() == companyId ||
          getUserRole() == 'admin_platforme' ||
          (canWriteAgencyScopedFinance(companyId) && request.resource.data.get('userId', '') == request.auth.uid) ||
          agencyCourierCanCreatePaymentLog() ||
          (getUserRole() == 'operator_digital' && userAgencyBelongsToCompany(companyId) && request.resource.data.get('userId', '') == request.auth.uid) ||
          operatorDigitalCanCreateOnlinePaymentLog()
        );
        allow update, delete: if false;
      }

      /**
       * Paiements unifies (guichet + online) — companies/{companyId}/payments
       * - Lecture / mise a jour : meme tenant (userCompanyId) ou admin plateforme.
       * - Creation visiteur (avec ou sans auth) : pending + channel online + companyId coherent
       *   (evite l'echec si l'utilisateur est connecte avec un autre tenant que la compagnie du billet).
       */
      match /payments/{paymentId} {
        /** Visiteur (auth ou anonyme) : creation pending+online pour la caisse digitale. */
        function visitorOnlinePendingPaymentCreate() {
          return request.resource.data.get('status', '') == 'pending'
            && request.resource.data.get('channel', '') == 'online'
            && request.resource.data.get('companyId', '') == companyId
            && request.resource.data.get('reservationId', '') == paymentId
            && request.resource.data.get('agencyId', '') != ''
            && request.resource.data.get('amount', 0) > 0
            && request.resource.data.get('amount', 0) < 100000000
            && request.resource.data.get('currency', 'XOF') == 'XOF';
        }
        /* get : staff ; visiteur = doc online dont l'id == reservationId (ou doc absent pour getDoc idempotent). */
        allow get: if resource == null
          || (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))
          || (resource.data.get('companyId', '') == companyId
            && resource.data.get('reservationId', '') == paymentId
            && resource.data.get('channel', '') == 'online');
        allow list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create: if visitorOnlinePendingPaymentCreate()
          || courierCashPaymentCreateOk(companyId)
          || (
            isAuth()
            && (userCompanyId() == companyId || getUserRole() == 'admin_platforme')
            && (
              request.resource.data.get('status', 'pending') != 'validated'
              || canAccessSensitiveCompanyFinance(companyId)
            )
          )
          || (
            canWriteAgencyScopedFinance(companyId)
            && request.resource.data.get('status', 'pending') != 'validated'
          );
        /* setDoc sur doc existant = update : idempotence (double envoi preuve / course). */
        /* Mise a jour staff : meme tenant (companyId profil / token) ou roles siege / operateur digital rattache a la compagnie. */
        allow update: if canValidateGuichetPayment(companyId);
        allow update: if (isAuth() && (
            userCompanyId() == companyId
            || getUserRole() == 'admin_platforme'
            || getUserRole() == 'operator_digital'
          ) && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
            || request.resource.data.get('status', '') == 'rejected'
            || canAccessSensitiveCompanyFinance(companyId)
            || (
              getUserRole() == 'operator_digital'
              && resource.data.get('companyId', '') == companyId
              && resource.data.get('channel', '') == 'online'
              && resource.data.get('status', '') == 'pending'
              && request.resource.data.get('status', '') == 'validated'
              && request.resource.data.get('validatedBy', '') == request.auth.uid
              && request.resource.data.get('validatedAt', null) == request.time
              && request.resource.data.get('updatedAt', null) == request.time
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'validatedAt', 'validatedBy', 'updatedAt'])
            )
          ))
          || canValidateGuichetPayment(companyId)
          || canValidateCourierPayment(companyId)
          || (
            resource.data.get('status', '') == 'pending'
            && resource.data.get('channel', '') == 'online'
            && resource.data.get('companyId', '') == companyId
            && resource.data.get('reservationId', '') == paymentId
            && visitorOnlinePendingPaymentCreate()
            && request.resource.data.get('amount', 0) == resource.data.get('amount', -1)
            && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')
          );
        allow delete: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
      }

      /* Subscription (plan) — required for useCapabilities / menus. CEO and company users must read. */
      match /subscription/{docId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
        allow create, update, delete: if isAuth() && (getUserRole() == 'admin_compagnie' || getUserRole() == 'admin_platforme') && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
      }

      /**
       * Bibliotheque d'images (metadonnees apres upload Cloudinary).
       * Avant : aucune regle explicite → refus par defaut (permission-denied sur listen / addDoc).
       */
      match /imagesBibliotheque/{imageId} {
        allow get, list: if isAuth() && (userCompanyId() == companyId || hasUserRole('admin_platforme'));
        allow create: if isAuth() && (userCompanyId() == companyId || hasUserRole('admin_platforme')) && (
          hasUserRole('admin_compagnie') ||
          hasUserRole('admin_platforme') ||
          isOperatorDigitalForCompany(companyId) ||
          hasUserRole('company_ceo')
        )
          && request.resource.data.keys().hasAll(['url', 'type', 'createdAt'])
          && request.resource.data.url is string
          && request.resource.data.type is string
          && request.resource.data.get('url', '').size() > 0;
        allow update: if false;
        allow delete: if isAuth() && (userCompanyId() == companyId || hasUserRole('admin_platforme')) && (
          hasUserRole('admin_compagnie') ||
          hasUserRole('admin_platforme') ||
          hasUserRole('company_ceo')
        );
      }
    }

    /* =====================
       COLLECTION GROUP
       (requis pour getCountFromServer / aggregation sur la landing)
    ===================== */
    match /{path=**}/weeklyTrips/{tripId} {
      allow get, list: if true;
    }

    match /{path=**}/agences/{agencyId} {
      allow get, list: if true;
    }

      /* Collection group reservations : lecture pour admin, meme compagnie (companyId/compagnieId), ou meme agence (guichetier, chefAgence, etc.). */
    match /{path=**}/reservations/{reservationId} {
      allow get: if (
        isAuth() && (
          getUserRole() == 'admin_platforme'
          || resource.data.get('companyId', '') == userCompanyId()
          || resource.data.get('compagnieId', '') == userCompanyId()
          || (getUserAgencyId() != '' && resource.data.get('agencyId', '') == getUserAgencyId())
        )
      )
      || (
        request.auth == null
        && (
          resource.data.get('canal', '') in ['en_ligne', 'online']
          || resource.data.get('paymentChannel', '') in ['en_ligne', 'online']
        )
        && (
          resource.data.get('status', '') in ['en_attente', 'en_attente_paiement']
          || resource.data.get('statut', '') in ['en_attente', 'en_attente_paiement']
          || resource.data.get('payment', {}).get('status', '') == 'pending'
        )
      );

      allow list: if request.auth != null && (
        request.auth.token.role == 'admin_platforme'
        || request.auth.token.companyId != null
        || request.auth.token.compagnieId != null
        || userCompanyId() != ''
        || hasUserRole('operator_digital')
      );
    }

    /* Collection group dailyStats (e.g. CompanyFinancesPage). CEO / platform: same-tenant by document companyId. */
    match /{path=**}/dailyStats/{dateId} {
      allow get: if isAuth() && (
        getUserRole() == 'admin_platforme' ||
        resource.data.get('companyId', '') == userCompanyId()
      );
      allow list: if request.auth != null && (
        request.auth.token.role == 'admin_platforme' ||
        request.auth.token.companyId != null ||
        request.auth.token.compagnieId != null
      );
    }

    /* Suivi colis public : lecture pour tous ; ecriture par utilisateurs de la meme compagnie (sync depuis l'app). */
    match /publicShipmentTrack/{trackId} {
      allow get, list: if true;
      allow create: if isAuth() && userCompanyId() == request.resource.data.companyId;
      allow update: if isAuth() && userCompanyId() == resource.data.companyId;
      allow delete: if false;
    }

    /* =====================
       LOGISTICS (Courrier) — company-scoped, same-tenant only.
       responsable_logistique: read-only (visibility, no courier finance management).
    ===================== */
    match /companies/{companyId}/logistics/{path=**} {
      allow read: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme' || (isResponsableLogistique() && userCompanyId() == companyId));
      allow write: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme') && !isResponsableLogistique();
    }

    /* Courier shipments (courrier) live under: companies/{companyId}/logistics/data/shipments/{shipmentId}
       Firestore queries with filters require the exact sub-path to be covered. */
    match /companies/{companyId}/logistics/data/shipments/{shipmentId} {
      allow get: if canAgencyAccountantReadOwnShipment(companyId);
      allow list: if agencyAccountantCanListCompanyScopedAccounting(companyId);
      allow get, list: if isAuth() && (
        userCompanyId() == companyId
        || getUserRole() == 'admin_platforme'
        || (isComptable() && userAgencyBelongsToCompany(companyId))
        || (isResponsableLogistique() && userCompanyId() == companyId)
      );
    }


    /* =====================
       REVENUE (events) — company-scoped, same-tenant only
    ===================== */
    match /companies/{companyId}/revenue/{path=**} {
      allow read, write: if isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme');
    }

    /* =====================
       DONNEES INTERNES
    ===================== */
    match /users/{userId} {
      allow get: if isAuth() && (request.auth.uid == userId || adminCanWriteUserDocument());
      allow list: if adminCanWriteUserDocument();
      allow create: if adminCanWriteUserDocument();
      allow update: if adminCanWriteUserDocument() || selfUserNotificationUpdateOk(userId);
    }

    /* =====================
       COUNTERS (company-level, e.g. trip instance refs)
       - Auth: same-tenant only.
       - Public: get + create/update with only lastSeq/updatedAt (resa en ligne generateWebReferenceCode).
    ===================== */
    match /companies/{companyId}/counters/byTrip/trips/{tripInstanceId} {
      allow get: if true;
      allow create: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))
        || (request.auth == null
          && request.resource.data.keys().hasOnly(['lastSeq', 'updatedAt'])
          && request.resource.data.get('lastSeq', 0) is int);
      allow update: if (isAuth() && (userCompanyId() == companyId || getUserRole() == 'admin_platforme'))
        || (request.auth == null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeq', 'updatedAt'])
          && request.resource.data.get('lastSeq', 0) is int);
      allow delete: if false;
    }

    /* =====================
       PLATFORM (landing, settings, leads)
    ===================== */
    match /platform/settings {
      allow get: if true;
      allow create, update, delete: if isAuth() && getUserRole() == 'admin_platforme';
    }

    match /platformLeads/{leadId} {
      allow create: if true;
      allow get, list: if isAuth() && getUserRole() == 'admin_platforme';
      allow update, delete: if false;
    }

    /* =====================
       DENY BY DEFAULT — no fallback read/write
       All collections used by the app must be declared above.
    ===================== */
    match /{path=**} {
      allow get, list, create, update, delete: if false;
    }
  }
}
