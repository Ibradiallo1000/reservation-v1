rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let raw = exists(path) ? get(path).data.get('role', '') : '';
      let tokenRole = request.auth != null ? request.auth.token.get('role', '') : '';
      return raw != '' ? raw : tokenRole;
    }
    function hasUserRole(role) {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let raw = exists(path) ? get(path).data.get('role', '') : '';
      let rawRoles = exists(path) ? get(path).data.get('roles', []) : [];
      let tokenRole = request.auth != null ? request.auth.token.get('role', '') : '';
      let tokenRoles = request.auth != null ? request.auth.token.get('roles', []) : [];
      return (raw is string && raw == role)
        || (rawRoles is list && rawRoles.hasAny([role]))
        || (tokenRole is string && tokenRole == role)
        || (tokenRoles is list && tokenRoles.hasAny([role]));
    }
    function isPlatformAdmin() {
      return isAuth() && hasUserRole('admin_platforme');
    }
    function validSystemPlanValues(plan) {
      return plan is map
        && plan.keys().hasOnly(['price', 'includedOperations', 'overage'])
        && plan.keys().hasAll(['price', 'includedOperations', 'overage'])
        && plan.price is number
        && plan.includedOperations is number
        && plan.overage is number
        && plan.price >= 0
        && plan.includedOperations >= 0
        && plan.overage >= 0;
    }
    function validSystemPlansSettings() {
      return request.resource.data.keys().hasOnly(['standard', 'premium'])
        && request.resource.data.keys().hasAll(['standard', 'premium'])
        && validSystemPlanValues(request.resource.data.standard)
        && validSystemPlanValues(request.resource.data.premium);
    }
    function validOperationQuotaIncrementOnly() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let previousUsage = resource.data.get('currentMonthOperations', 0);
      let previousMonth = resource.data.get('currentMonth', resource.data.get('currentOperationsMonth', ''));
      let nextMonth = request.resource.data.currentMonth;
      return changed.hasOnly(['currentMonthOperations', 'currentMonth', 'currentOperationsMonth', 'operationsUpdatedAt'])
        && previousUsage is number
        && request.resource.data.currentMonthOperations is number
        && request.resource.data.currentMonth is string
        && request.resource.data.currentOperationsMonth is string
        && request.resource.data.currentMonth == request.resource.data.currentOperationsMonth
        && request.resource.data.operationsUpdatedAt == request.time
        && (
          (
            nextMonth == previousMonth
            && request.resource.data.currentMonthOperations == previousUsage + 1
          )
          || (
            nextMonth != previousMonth
            && request.resource.data.currentMonthOperations == 1
          )
        );
    }
    function isComptable() {
      return isAuth() && (
        hasUserRole('agency_accountant') ||
        hasUserRole('comptable') ||
        hasUserRole('Comptable') ||
        hasUserRole('admin_compagnie')
      );
    }
    function isGuichetier() {
      return isAuth() && hasUserRole('guichetier');
    }
    function isCourierAgent() {
      return isAuth() && (
        hasUserRole('agentCourrier') ||
        hasUserRole('agentcourrier') ||
        hasUserRole('agent_courrier') ||
        hasUserRole('agentCourier') ||
        hasUserRole('courier_agent')
      );
    }
    function isBoardingOfficer() {
      return isAuth() && (
        hasUserRole('agency_boarding_officer') ||
        hasUserRole('embarquement') ||
        hasUserRole('chefEmbarquement') ||
        hasUserRole('chefembarquement') ||
        hasUserRole('chef_embarquement') ||
        hasUserRole('controleur_embarquement') ||
        hasUserRole('agent_embarquement') ||
        hasUserRole('boarding_officer')
      );
    }
    function isFleetController() {
      return isAuth() && hasUserRole('agency_fleet_controller');
    }
    function isAgencyManager() {
      return isAuth() && (
        hasUserRole('chefAgence') ||
        hasUserRole('chefagence') ||
        hasUserRole('admin_compagnie')
      );
    }
    function isEscaleManager() {
      return isAuth() && hasUserRole('escale_manager');
    }
    function isEscaleOperator() {
      return isAuth() && (hasUserRole('escale_agent') || hasUserRole('escale_manager'));
    }
    /* Chef d'agence ou chef d'escale : peuvent gerer l'equipe de leur agence. */
    function canManageAgencyTeam(agencyId) {
      return isAuth() && (hasUserRole('admin_compagnie') || hasUserRole('admin_platforme')
        || ((hasUserRole('chefAgence') || hasUserRole('chefagence')) && getUserAgencyId() == agencyId)
        || (hasUserRole('escale_manager') && getUserAgencyId() == agencyId));
    }
    /* Fleet & vehicle operations (ex chef_garage). Backward compat: accept both role names. */
    function isResponsableLogistique() {
      return isAuth() && (hasUserRole('responsable_logistique') || hasUserRole('chef_garage'));
    }
    /* Phase B — transition de statut reservation (guichetier, chef_agence, comptable, embarquement, validation en ligne). Valeurs canoniques uniquement. */
    function validReservationStatutTransition() {
      let oldS = resource.data.get('statut', '');
      let newS = request.resource.data.get('statut', '');
      return (isGuichetier() && (oldS == 'confirme' || oldS == 'paye' || oldS == 'paye') && newS == 'annulation_en_attente')
        || (isGuichetier() && (oldS == 'paye' || oldS == 'paye') && newS == 'finance_side_effects_failed')
        || (isAgencyManager() && oldS == 'annulation_en_attente' && newS == 'annule')
        || (isComptable() && oldS == 'annule' && newS == 'rembourse')
        || (isBoardingOfficer() && (
          oldS == 'confirme' ||
          oldS == 'confirme' ||
          oldS == 'paye' ||
          oldS == 'paye' ||
          oldS == 'valide' ||
          oldS == 'valide' ||
          oldS == 'preuve_recue'
        ) && (
          newS == 'embarque' ||
          newS == 'embarque'
        ))
        || ((hasUserRole('admin_compagnie') || hasUserRole('company_accountant') || isAgencyManager() || isComptable() || hasUserRole('operator_digital')) && (oldS == 'preuve_recue' || oldS == 'verification') && (newS == 'confirme' || newS == 'refuse'));
    }
    function isOperatorDigitalForCompany(companyId) {
      return isAuth()
        && hasUserRole('operator_digital')
        && userCompanyId() == companyId;
    }
    function operatorDigitalCanCommitOnlineReservation(companyId, agencyId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let online = resource.data.get('canal', '') in ['en_ligne', 'online']
        || resource.data.get('paymentChannel', '') in ['en_ligne', 'online'];
      let pending = resource.data.get('status', '') in ['preuve_recue', 'verification']
        || resource.data.get('statut', '') in ['preuve_recue', 'verification'];
      return isAuth()
        && isOperatorDigitalForCompany(companyId)
        && resource.data.get('companyId', '') == companyId
        && resource.data.get('agencyId', '') == agencyId
        && online
        && pending
        && request.resource.data.get('status', '') == 'confirme'
        && request.resource.data.get('statut', '') == 'confirme'
        && request.resource.data.get('validatedBy', '') == request.auth.uid
        && request.resource.data.get('paymentStatus', '') == 'paid'
        && request.resource.data.get('payment', {}).get('status', '') == 'validated'
        && request.resource.data.get('ticketValidatedAt', null) == request.time
        && request.resource.data.get('seatHoldOnly', true) == false
        && request.resource.data.get('seatsHeld', -1) == 0
        && (
          request.resource.data.get('seatsCommittedAt', null) == request.time
          || (
            resource.data.get('seatsCommittedAt', null) != null
            && request.resource.data.get('seatsCommittedAt', null) == resource.data.get('seatsCommittedAt', null)
          )
        )
        && request.resource.data.get('updatedAt', null) == request.time
        && changed.hasAll([
          'status',
          'statut',
          'paymentStatus',
          'payment',
          'ticketValidatedAt',
          'validatedBy',
          'auditLog',
          'updatedAt'
        ])
        && changed.hasOnly([
  'status',
  'statut',
  'paymentStatus',
  'payment',
  'reservation',
  'boardingStatus',
  'statutEmbarquement',
  'checkInTime',
  'controleurId',
  'ticketValidatedAt',
  'validatedBy',
  'auditLog',
  'seatHoldOnly',
  'seatsHeld',
  'seatsCommittedAt',
  'ticketRevenueCountedInDailyStats',
  'updatedAt'
])
    }
function operatorDigitalCanRejectOnlineReservation(companyId, agencyId) {
  let changed = request.resource.data.diff(resource.data).affectedKeys();
  let online = resource.data.get('canal', '') in ['en_ligne', 'online']
    || resource.data.get('paymentChannel', '') in ['en_ligne', 'online'];
  let pending = resource.data.get('status', '') in ['preuve_recue', 'verification']
    || resource.data.get('statut', '') in ['preuve_recue', 'verification'];

  return isAuth()
    && isOperatorDigitalForCompany(companyId)
    && resource.data.get('companyId', '') == companyId
    && resource.data.get('agencyId', '') == agencyId
    && online
    && pending
    && request.resource.data.get('status', '') in ['refuse', 'refused']
    && request.resource.data.get('statut', '') in ['refuse', 'refused']
    && request.resource.data.get('updatedAt', null) == request.time
    && (
      request.resource.data.get('refusedBy', '') == request.auth.uid
      || request.resource.data.get('rejectedBy', '') == request.auth.uid
    )
    && (
      request.resource.data.get('refusedAt', null) == request.time
      || request.resource.data.get('rejectedAt', null) == request.time
    )
    && changed.hasOnly([
  'status',
  'statut',
  'paymentStatus',
  'payment',
  'reservation',
  'refusalReason',
  'rejectionReason',
  'refusedBy',
  'refusedAt',
  'rejectedBy',
  'rejectedAt',
  'boardingStatus',
  'statutEmbarquement',
  'checkInTime',
  'controleurId',
  'seatHoldOnly',
  'seatsHeld',
  'seatsCommittedAt',
  'auditLog',
  'updatedAt'
]);
   }
    function operatorDigitalCanFinalizeOnlineReservation(companyId, agencyId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let online = resource.data.get('canal', '') in ['en_ligne', 'online']
        || resource.data.get('paymentChannel', '') in ['en_ligne', 'online'];
      return isAuth()
        && isOperatorDigitalForCompany(companyId)
        && resource.data.get('companyId', '') == companyId
        && resource.data.get('agencyId', '') == agencyId
        && online
        && resource.data.get('status', '') == 'confirme'
        && resource.data.get('statut', '') == 'confirme'
        && resource.data.get('paymentStatus', '') == 'paid'
        && resource.data.get('validatedBy', '') == request.auth.uid
        && request.resource.data.get('cashTransactionId', '') is string
        && request.resource.data.get('cashTransactionId', '').size() > 0
        && request.resource.data.get('paymentStatus', '') == 'paid'
        && request.resource.data.get('paymentMethod', '') in [
          'cash',
          'mobile_money',
          'card',
          'bank_transfer',
          'transfer',
          'online'
        ]
        && request.resource.data.get('updatedAt', null) == request.time
        && changed.hasOnly([
          'cashTransactionId',
          'paymentStatus',
          'paymentMethod',
          'updatedAt'
        ]);
    }
    /* Phase B — controleur embarquement : ne peut modifier que statut, statutEmbarquement, controleurId, checkInTime, auditLog, updatedAt */
    function boardingOfficerAllowedKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "statut", "statutEmbarquement", "boardingStatus", "journeyStatus", "controleurId", "checkInTime", "auditLog", "updatedAt"
      ]);
    }
    function boardingRoleValueIsAccepted(role) {
      return role == 'agency_boarding_officer'
        || role == 'embarquement'
        || role == 'chefEmbarquement'
        || role == 'chefembarquement'
        || role == 'chef_embarquement'
        || role == 'controleur_embarquement'
        || role == 'agent_embarquement'
        || role == 'boarding_officer';
    }
    function boardingOfficerStatutUpdateOk() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let oldStatut = resource.data.get('statut', '');
      let newStatut = request.resource.data.get('statut', oldStatut);
      return !changed.hasAny(['statut'])
        || (
          (
            oldStatut == 'confirme'
            || oldStatut == 'confirme'
            || oldStatut == 'paye'
            || oldStatut == 'paye'
            || oldStatut == 'valide'
            || oldStatut == 'valide'
            || oldStatut == 'preuve_recue'
            || oldStatut == 'embarque'
            || oldStatut == 'embarque'
          )
          && (
            newStatut == 'embarque'
            || newStatut == 'embarque'
          )
        );
    }
    function boardingOfficerBoardingStatusOk() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let boardingStatus = request.resource.data.get('boardingStatus', '');
      return !changed.hasAny(['boardingStatus'])
        || boardingStatus == 'boarded'
        || boardingStatus == 'pending'
        || boardingStatus == 'no_show';
    }
    function boardingOfficerStatutEmbarquementOk() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let statutEmbarquement = request.resource.data.get('statutEmbarquement', '');
      return !changed.hasAny(['statutEmbarquement'])
        || statutEmbarquement == 'embarque'
        || statutEmbarquement == 'embarque'
        || statutEmbarquement == 'en_attente'
        || statutEmbarquement == 'absent';
    }
    function boardingOfficerCanUpdateReservation(companyId, agencyId) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userData = get(userPath).data;
      return isAuth()
        && exists(userPath)
        && boardingRoleValueIsAccepted(userData.get('role', ''))
        && userData.get('agencyId', '') == agencyId
        && (
          userData.get('companyId', '') == companyId
          || userData.get('compagnieId', '') == companyId
        )
        && boardingOfficerAllowedKeysOnly()
        && boardingOfficerStatutUpdateOk()
        && boardingOfficerBoardingStatusOk()
        && boardingOfficerStatutEmbarquementOk();
    }
    function isSameAgencyReservation(companyId, agencyId) {
      return isAuth()
        && getUserAgencyId() == agencyId
        && (
          userCompanyId() == companyId
          || userAgencyBelongsToCompany(companyId)
          || getUserRole() == 'admin_platforme'
        );
    }
    function isBoardingOperationalUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return changed.hasOnly([
        'boardingStatus',
        'statutEmbarquement',
        'controleurId',
        'checkInTime'
      ])
      && request.resource.data.get('boardingStatus', resource.data.get('boardingStatus', '')) in [
        'pending',
        'boarded',
        'no_show'
      ]
      && request.resource.data.get('statutEmbarquement', resource.data.get('statutEmbarquement', '')) in [
        'en_attente',
        'embarque',
        'embarque',
        'absent'
      ];
    }
    function canBoardingOfficerOperateReservation(companyId, agencyId) {
      return isAuth()
        && isBoardingOfficer()
        && getUserAgencyId() == agencyId
        && (
          userCompanyId() == companyId
          || userAgencyBelongsToCompany(companyId)
          || getUserRole() == 'admin_platforme'
        )
        && isBoardingOperationalUpdate();
    }
    function getUserAgencyId() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userData = exists(userPath) ? get(userPath).data : null;
      let docAgencyId = userData == null ? '' : userData.get('agencyId', '');
      let tokenAgencyId = request.auth != null ? request.auth.token.get('agencyId', '') : '';
      return (docAgencyId is string && docAgencyId != '')
        ? docAgencyId
        : (tokenAgencyId is string ? tokenAgencyId : '');
    }
    /* Escale roles: allow read company data (agences, routes, stops) when their agency is under this company. */
    function escaleUserCanReadCompany(companyId) {
      return isAuth() && (getUserRole() == 'escale_agent' || getUserRole() == 'escale_manager')
        && getUserAgencyId() != ''
        && exists(/databases/$(database)/documents/companies/$(companyId)/agences/$(getUserAgencyId()));
    }
    function userCompanyId() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let userData = exists(path) ? get(path).data : null;
      let docCompanyId = userData == null
        ? ''
        : (
            userData.get('companyId', '') is string && userData.get('companyId', '') != ''
              ? userData.get('companyId', '')
              : (userData.get('compagnieId', '') is string ? userData.get('compagnieId', '') : '')
          );
      let tokenCompanyId = request.auth != null
        ? (
            request.auth.token.get('companyId', '') is string && request.auth.token.get('companyId', '') != ''
              ? request.auth.token.get('companyId', '')
              : (request.auth.token.get('compagnieId', '') is string ? request.auth.token.get('compagnieId', '') : '')
          )
        : '';
      return docCompanyId != '' ? docCompanyId : tokenCompanyId;
    }
    function sensitiveUserDocumentKeys() {
      return [
        'role',
        'roles',
        'userRole',
        'companyId',
        'compagnieId',
        'companyIds',
        'agencyId',
        'agenceId',
        'agencyIds',
        'permissions',
        'isAdmin',
        'active',
        'status',
        'disabled',
        'enabled',
        'claims',
        'customClaims',
        'accessScope',
        'accessScopes',
        'managedCompanyIds'
      ];
    }
    function selfWritableUserDocumentKeys() {
      return [
        'fcmToken',
        'fcmTokens',
        'pushToken',
        'pushTokens',
        'notificationToken',
        'notificationTokens',
        'notificationsEnabled',
        'fcmUpdatedAt',
        'lastPushTokenAt',
        'pushTokenUpdatedAt',
        'updatedAt'
      ];
    }
    function targetUserCompanyId() {
      return request.resource.data.get('companyId', '') is string
        && request.resource.data.get('companyId', '') != ''
        ? request.resource.data.get('companyId', '')
        : (request.resource.data.get('compagnieId', '') is string ? request.resource.data.get('compagnieId', '') : '');
    }
    function targetUserHasPrivilegedAdminRole() {
      let role = request.resource.data.get('role', '');
      let roles = request.resource.data.get('roles', []);
      return role in ['admin_platforme', 'admin_compagnie']
        || (roles is list && roles.hasAny(['admin_platforme', 'admin_compagnie']));
    }
    function adminCanWriteUserDocument() {
      return isAuth() && (
        isPlatformAdmin()
        || (
          getUserRole() == 'admin_compagnie'
          && userCompanyId() != ''
          && targetUserCompanyId() == userCompanyId()
          && !targetUserHasPrivilegedAdminRole()
        )
      );
    }
    function selfUserNotificationUpdateOk(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuth()
        && request.auth.uid == userId
        && changed.hasOnly(selfWritableUserDocumentKeys())
        && !changed.hasAny(sensitiveUserDocumentKeys());
    }

    /**
     * Agence rattachee a la compagnie (guichet / escale / chef) — evite les 403 quand
     * users/{uid}.companyId est absent ou desynchronise mais agencyId est correct.
     */
    function userAgencyBelongsToCompany(companyId) {
      return isAuth() && getUserAgencyId() != ''
        && exists(/databases/$(database)/documents/companies/$(companyId)/agences/$(getUserAgencyId()));
    }
    /**
     * Si paymentChannel est renseigne : en ligne sans poste/vendeur ; guichet avec agentId + sessionId.
     * Les documents sans paymentChannel restent acceptes (donnees historiques).
     */
    function reservationCreatePaymentChannelShapeOk() {
      let pc = request.resource.data.get('paymentChannel', '');
      return pc == ''
        || (
          (pc == 'online' || pc == 'en_ligne')
          && request.resource.data.get('agentId', '').size() == 0
          && request.resource.data.get('sessionId', '').size() == 0
          && request.resource.data.get('shiftId', '').size() == 0
          && request.resource.data.get('guichetierId', '').size() == 0
          && request.resource.data.get('createdInSessionId', '').size() == 0
        )
        || (
          pc == 'guichet'
          && request.resource.data.get('agentId', '').size() > 0
          && request.resource.data.get('createdBy', '').size() > 0
          && request.resource.data.get('agencyId', '').size() > 0
          && request.resource.data.get('agencyId', '') == getUserAgencyId()
          && request.resource.data.get('sessionId', '').size() > 0
          && request.resource.data.get('shiftId', '').size() == 0
          && request.resource.data.get('createdInSessionId', '').size() == 0
          && request.resource.data.get('idempotencyKey', '').size() > 0
        );
    }
    /** Ecriture tresorerie / paiements guichet : meme agence que le payload. */
    function publicOnlineReservationCreate(companyId, agencyId) {
      let canal = request.resource.data.get('canal', '');
      let status = request.resource.data.get('status', '');
      let statut = request.resource.data.get('statut', '');
      return request.resource.data.get('paymentChannel', '') == 'online'
        && canal is string
        && canal.toLowerCase().replace(' ', '_') == 'en_ligne'
        && request.resource.data.get('companyId', '') == companyId
        && request.resource.data.get('compagnieId', companyId) == companyId
        && request.resource.data.get('agencyId', '') == agencyId
        && status is string
        && status.toLowerCase().replace(' ', '_') == 'en_attente'
        && statut is string
        && statut.toLowerCase().replace(' ', '_') == 'en_attente'
        && request.resource.data.get('publicToken', '').size() > 0
        && request.resource.data.get('publicUrl', '').size() > 0
        && request.resource.data.get('seatHoldOnly', false) == true
        && request.resource.data.get('seatsHeld', 0) > 0;
    }
    function publicOnlineProofSubmitOk(companyId, agencyId) {
      let canal = resource.data.get('canal', '');
      let paymentChannel = resource.data.get('paymentChannel', '');
      let nextStatus = request.resource.data.get('status', '');

      return (
        paymentChannel == 'online'
        || paymentChannel == 'en_ligne'
        || (
          canal is string
          && (
            canal.toLowerCase().replace(' ', '_') == 'en_ligne'
            || canal.toLowerCase().replace(' ', '_') == 'online'
          )
        )
      )
      && reservationAwaitingOnlinePaymentProof()
      && request.resource.data.get('companyId', '') == companyId
      && request.resource.data.get('compagnieId', companyId) == companyId
      && request.resource.data.get('agencyId', '') == agencyId
      && nextStatus is string
      && (nextStatus == 'preuve_recue' || nextStatus == 'verification')
      && request.resource.data.get('updatedAt') is timestamp
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'statut',
        'canal',
        'paymentChannel',
        'preuveMessage',
        'paymentReference',
        'transactionReference',
        'preuveVia',
        'payment',
        'proofSubmittedAt',
        'seatHoldOnly',
        'seatsHeld',
        'updatedAt'
      ]);
    }
    function canWriteAgencyScopedFinance(companyId) {
      return userAgencyBelongsToCompany(companyId) && (
        isGuichetier() ||
        hasUserRole('escale_agent') ||
        hasUserRole('escale_manager') ||
        (hasUserRole('chefAgence') && getUserAgencyId() != '') ||
        isComptable()
      );
    }
    function validPendingPaymentValidationPayload(companyId) {
      return resource.data.get('status', '') == 'pending'
        && request.resource.data.get('status', '') == 'validated'
        && request.resource.data.get('companyId', '') == companyId
        && request.resource.data.get('agencyId', '') == resource.data.get('agencyId', '')
        && request.resource.data.get('reservationId', '') == resource.data.get('reservationId', '')
        && request.resource.data.get('amount', 0) == resource.data.get('amount', 0)
        && request.resource.data.get('currency', 'XOF') == resource.data.get('currency', 'XOF')
        && request.resource.data.get('validatedBy', '') == request.auth.uid
        && request.resource.data.get('validatedAt', null) == request.time
